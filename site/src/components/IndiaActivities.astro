---
---

<div id="ia-wrap">

  <!-- Add / Edit form -->
  <form id="ia-form" class="ia-form">
    <div class="ia-form__fields">
      <div class="ia-form__field ia-form__field--title">
        <label class="ia-label" for="ia-title">Activity / Idea</label>
        <input id="ia-title" class="ia-input" type="text"
          placeholder="e.g. Classical Bharatanatyam with local troupe" required />
      </div>
      <div class="ia-form__field">
        <label class="ia-label" for="ia-category">Category</label>
        <select id="ia-category" class="ia-select">
          <option value="">— Pick a category —</option>
          <option>Cultural &amp; Heritage</option>
          <option>Language</option>
          <option>Volunteer / Service</option>
          <option>Programs in India</option>
          <option>Diaspora Networks</option>
          <option>Other</option>
        </select>
      </div>
      <div class="ia-form__field">
        <label class="ia-label" for="ia-status-form">Status</label>
        <select id="ia-status-form" class="ia-select">
          <option value="Open">Open</option>
          <option value="Interested">Interested</option>
          <option value="Cancelled">Cancelled</option>
          <option value="Complete">Complete</option>
        </select>
      </div>
    </div>
    <div class="ia-form__field">
      <label class="ia-label" for="ia-details">Details &amp; Notes</label>
      <textarea id="ia-details" class="ia-textarea"
        placeholder="Context, contacts, links, next steps…" rows="3"></textarea>
    </div>
    <div class="ia-form__actions">
      <button type="submit" class="ia-btn ia-btn--primary" id="ia-submit">Add Activity</button>
      <button type="button" class="ia-btn ia-btn--export" id="ia-export">⬇ Export CSV</button>
      <button type="button" class="ia-btn ia-btn--import" id="ia-import-btn">⬆ Import JSON</button>
      <input type="file" id="ia-import-file" accept=".json" style="display:none" />
      <button type="button" class="ia-btn ia-btn--cancel" id="ia-cancel" style="display:none">Cancel</button>
      <span id="ia-error" class="ia-error" style="display:none"></span>
    </div>
    <div id="ia-import-preview" class="ia-import-preview" style="display:none">
      <span id="ia-import-msg" class="ia-import-msg"></span>
      <button type="button" class="ia-btn ia-btn--primary" id="ia-import-confirm">Import</button>
      <button type="button" class="ia-btn ia-btn--cancel" id="ia-import-cancel">Cancel</button>
    </div>
    <details class="ia-import-format">
      <summary>JSON format reference</summary>
      <pre class="ia-import-pre" is:raw>[
  {
    "title": "Classical Bharatanatyam with local troupe",  // required
    "category": "Cultural &amp; Heritage",  // Cultural &amp; Heritage | Language | Volunteer / Service | Programs in India | Diaspora Networks | Other
    "details": "Performing at temple events and cultural festivals",
    "status": "Open",          // Open | Interested | Cancelled | Complete
    "starred": false,
    "shortlisted": false
  }
]</pre>
    </details>
  </form>

  <!-- Table area -->
  <div class="ia-toolbar">
    <span id="ia-count" class="ia-count"></span>
  </div>
  <div class="ia-table-wrap">
    <table class="ia-table">
      <thead>
        <tr>
          <th class="ia-th ia-th--star">★</th>
          <th class="ia-th ia-th--pin" title="Shortlist">📌</th>
          <th class="ia-th ia-th--title">Activity / Idea</th>
          <th class="ia-th ia-th--cat">Category</th>
          <th class="ia-th ia-th--status">Status</th>
          <th class="ia-th ia-th--date">Date</th>
          <th class="ia-th ia-th--actions"></th>
        </tr>
      </thead>
      <tbody id="ia-tbody">
        <tr><td colspan="7" class="ia-td-msg">Loading…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  let familyId  = '';
  let editingId: number | null = null;
  let allItems: any[] = [];
  let filterStatus  = 'all';
  let filterCat     = 'all';
  let filterStarred = false;
  let sortMode      = 'newest';

  const form         = document.getElementById('ia-form')        as HTMLFormElement;
  const titleEl      = document.getElementById('ia-title')       as HTMLInputElement;
  const categoryEl   = document.getElementById('ia-category')    as HTMLSelectElement;
  const statusFormEl = document.getElementById('ia-status-form') as HTMLSelectElement;
  const detailsEl    = document.getElementById('ia-details')     as HTMLTextAreaElement;
  const submitBtn    = document.getElementById('ia-submit')      as HTMLButtonElement;
  const cancelBtn    = document.getElementById('ia-cancel')      as HTMLButtonElement;
  const errorEl      = document.getElementById('ia-error')       as HTMLElement;
  const tbody   = document.getElementById('ia-tbody') as HTMLElement;
  const countEl = document.getElementById('ia-count') as HTMLElement;

  const CAT_COLOR = {
    'Cultural & Heritage': '#f59e0b',
    'Language':            '#3b82f6',
    'Volunteer / Service': '#22c55e',
    'Programs in India':   '#8b5cf6',
    'Diaspora Networks':   '#ec4899',
    'Other':               '#94a3b8',
  };

  const STATUS_COLOR = {
    'Open':       '#3b82f6',
    'Interested': '#f59e0b',
    'Cancelled':  '#94a3b8',
    'Complete':   '#22c55e',
  };

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function visibleItems() {
    let list = allItems.filter(i => {
      if (filterStatus !== 'all' && i.status !== filterStatus) return false;
      if (filterCat    !== 'all' && i.category !== filterCat)  return false;
      if (filterStarred && !i.starred) return false;
      return true;
    });
    const statusOrder = ['Open','Interested','Complete','Cancelled'];
    list.sort((a, b) => {
      if (sortMode === 'newest') return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
      if (sortMode === 'oldest') return new Date(a.created_at).getTime() - new Date(b.created_at).getTime();
      if (sortMode === 'az')     return a.title.localeCompare(b.title);
      if (sortMode === 'za')     return b.title.localeCompare(a.title);
      if (sortMode === 'status') return statusOrder.indexOf(a.status ?? 'Open') - statusOrder.indexOf(b.status ?? 'Open');
      return 0;
    });
    return list;
  }

  function renderTable() {
    const items = visibleItems();
    countEl.textContent = `${items.length} activit${items.length !== 1 ? 'ies' : 'y'}`;

    if (items.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="ia-td-msg">No activities match. Try adjusting filters.</td></tr>';
      return;
    }

    tbody.innerHTML = items.map(i => {
      const catColor = CAT_COLOR[i.category] ?? '#94a3b8';
      const sc       = STATUS_COLOR[i.status ?? 'Open'] ?? '#3b82f6';
      return `
        <tr class="ia-row${i.status === 'Cancelled' ? ' ia-row--cancelled' : ''}${i.status === 'Complete' ? ' ia-row--complete' : ''}">
          <td class="ia-td ia-td--star">
            <button class="ia-star${i.starred ? ' ia-star--on' : ''}" data-id="${i.id}" data-starred="${!!i.starred}" title="Star">${i.starred ? '★' : '☆'}</button>
          </td>
          <td class="ia-td ia-td--pin">
            <button class="ia-pin${i.shortlisted ? ' ia-pin--on' : ''}" data-id="${i.id}" data-shortlisted="${!!i.shortlisted}" title="Toggle shortlist">📌</button>
          </td>
          <td class="ia-td ia-td--title">
            <span class="ia-row-title">${esc(i.title)}</span>
            ${i.details ? `<span class="ia-row-sub">${esc(i.details)}</span>` : ''}
          </td>
          <td class="ia-td ia-td--cat">
            ${i.category
              ? `<span class="ia-cat-badge" style="background:${catColor}20;color:${catColor};border-color:${catColor}40">${esc(i.category)}</span>`
              : '<span class="ia-none">—</span>'}
          </td>
          <td class="ia-td ia-td--status">
            <select class="ia-status-sel" data-id="${i.id}" data-status="${i.status ?? 'Open'}" style="--sc:${sc}">
              <option value="Open"       ${(i.status ?? 'Open') === 'Open'       ? 'selected' : ''}>Open</option>
              <option value="Interested" ${i.status === 'Interested' ? 'selected' : ''}>Interested</option>
              <option value="Cancelled"  ${i.status === 'Cancelled'  ? 'selected' : ''}>Cancelled</option>
              <option value="Complete"   ${i.status === 'Complete'   ? 'selected' : ''}>Complete</option>
            </select>
          </td>
          <td class="ia-td ia-td--date">${formatDate(i.created_at)}</td>
          <td class="ia-td ia-td--actions">
            <button class="ia-act ia-act--edit"   data-id="${i.id}">Edit</button>
            <button class="ia-act ia-act--delete" data-id="${i.id}">Delete</button>
          </td>
        </tr>`;
    }).join('');
  }

  document.addEventListener('click', e => {
    const chip = (e.target as Element).closest<HTMLElement>('.filter-chip[data-filter]');
    if (!chip) return;
    const filter = chip.dataset.filter!;
    const value  = chip.dataset.value!;
    if (filter === 'status') filterStatus = value;
    if (filter === 'cat')    filterCat    = value;
    document.querySelectorAll<HTMLElement>(`.filter-chip[data-filter="${filter}"]`).forEach(c =>
      c.classList.toggle('active', c.dataset.value === value));
    renderTable();
  });

  document.addEventListener('change', e => {
    const target = e.target as HTMLElement;
    if (target.id === 'bs-sort')    { sortMode = (target as HTMLSelectElement).value; renderTable(); }
    if (target.id === 'bs-starred') { filterStarred = (target as HTMLInputElement).checked; renderTable(); }
  });

  tbody.addEventListener('change', async e => {
    const sel = (e.target as HTMLElement).closest<HTMLSelectElement>('.ia-status-sel');
    if (!sel) return;
    const id     = Number(sel.dataset.id);
    const status = sel.value;
    sel.dataset.status = status;
    sel.style.setProperty('--sc', STATUS_COLOR[status] ?? '#3b82f6');
    await supabase.from('india_activities').update({ status }).eq('id', id).eq('family_id', familyId);
    const item = allItems.find(i => i.id === id);
    if (item) { item.status = status; renderTable(); }
  });

  tbody.addEventListener('click', async e => {
    const target = e.target as HTMLElement;

    const starBtn = target.closest<HTMLElement>('.ia-star');
    if (starBtn) {
      const id      = Number(starBtn.dataset.id);
      const starred = starBtn.dataset.starred !== 'true';
      await supabase.from('india_activities').update({ starred }).eq('id', id).eq('family_id', familyId);
      const item = allItems.find(i => i.id === id);
      if (item) { item.starred = starred; renderTable(); }
      return;
    }

    const pinBtn = target.closest<HTMLElement>('.ia-pin');
    if (pinBtn) {
      const id          = Number(pinBtn.dataset.id);
      const shortlisted = pinBtn.dataset.shortlisted !== 'true';
      await supabase.from('india_activities').update({ shortlisted }).eq('id', id).eq('family_id', familyId);
      const item = allItems.find(i => i.id === id);
      if (item) { item.shortlisted = shortlisted; renderTable(); }
      return;
    }

    if (target.classList.contains('ia-act--delete')) {
      const id = Number(target.dataset.id);
      if (!confirm('Delete this activity?')) return;
      await supabase.from('india_activities').delete().eq('id', id).eq('family_id', familyId);
      allItems = allItems.filter(i => i.id !== id);
      renderTable();
    }

    if (target.classList.contains('ia-act--edit')) {
      const id   = Number(target.dataset.id);
      const item = allItems.find(i => i.id === id);
      if (!item) return;
      editingId            = id;
      titleEl.value        = item.title;
      categoryEl.value     = item.category ?? '';
      statusFormEl.value   = item.status   ?? 'Open';
      detailsEl.value      = item.details  ?? '';
      submitBtn.textContent = 'Save Changes';
      submitBtn.classList.add('ia-btn--save');
      cancelBtn.style.display = 'inline-block';
      titleEl.focus();
      titleEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  form.addEventListener('submit', async e => {
    e.preventDefault();
    if (!familyId) return;
    const title    = titleEl.value.trim();
    const category = categoryEl.value || null;
    const status   = statusFormEl.value;
    const details  = detailsEl.value.trim() || null;
    if (!title) return;
    errorEl.style.display = 'none';
    submitBtn.disabled = true;

    if (editingId !== null) {
      const { error } = await supabase.from('india_activities')
        .update({ title, category, status, details, updated_at: new Date().toISOString() })
        .eq('id', editingId).eq('family_id', familyId);
      if (error) { errorEl.textContent = error.message; errorEl.style.display = 'inline'; }
      else { resetForm(); await loadItems(); }
    } else {
      const { error } = await supabase.from('india_activities')
        .insert({ family_id: familyId, title, category, status, details });
      if (error) { errorEl.textContent = error.message; errorEl.style.display = 'inline'; }
      else { resetForm(); await loadItems(); }
    }
    submitBtn.disabled = false;
  });

  function resetForm() {
    editingId = null;
    titleEl.value = ''; categoryEl.value = ''; statusFormEl.value = 'Open'; detailsEl.value = '';
    submitBtn.textContent = 'Add Activity';
    submitBtn.classList.remove('ia-btn--save');
    cancelBtn.style.display = 'none';
  }
  cancelBtn.addEventListener('click', resetForm);

  document.getElementById('ia-export')!.addEventListener('click', () => {
    if (!allItems.length) return;
    const cell = (v: any) => `"${(v ?? '').toString().replace(/"/g,'""')}"`;
    const lines = [
      ['Starred','Category','Activity / Idea','Details','Status','Date'].map(cell).join(','),
      ...allItems.map(i => [
        i.starred ? 'Yes' : 'No', i.category ?? '', i.title, i.details ?? '',
        i.status ?? 'Open',
        new Date(i.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),
      ].map(cell).join(','))
    ];
    const blob = new Blob([lines.join('\n')], { type:'text/csv' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'india-activities.csv'; a.click();
    URL.revokeObjectURL(url);
  });

  /* ── Import JSON ── */
  let pendingImport: any[] = [];

  function showIaError(msg: string) { errorEl.textContent = msg; errorEl.style.display = 'inline'; }

  document.getElementById('ia-import-btn')!.addEventListener('click', () => {
    (document.getElementById('ia-import-file') as HTMLInputElement).click();
  });

  document.getElementById('ia-import-file')!.addEventListener('change', async e => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    (e.target as HTMLInputElement).value = '';
    let parsed: any;
    try { parsed = JSON.parse(await file.text()); } catch {
      showIaError('Invalid JSON file — could not parse.'); return;
    }
    if (!Array.isArray(parsed)) {
      showIaError('JSON must be an array of objects.'); return;
    }
    const valid = parsed.filter((i: any) => i && typeof i.title === 'string' && i.title.trim());
    if (!valid.length) {
      showIaError('No valid items found. Each item needs at least a "title" string.'); return;
    }
    pendingImport = valid;
    const preview = valid.slice(0, 3).map((i: any) => i.title.trim()).join(', ');
    document.getElementById('ia-import-msg')!.textContent =
      `${valid.length} item${valid.length !== 1 ? 's' : ''}: ${preview}${valid.length > 3 ? '…' : ''}`;
    document.getElementById('ia-import-preview')!.style.display = 'flex';
  });

  document.getElementById('ia-import-confirm')!.addEventListener('click', async () => {
    if (!familyId || !pendingImport.length) return;
    const btn = document.getElementById('ia-import-confirm') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Importing…';
    const VALID_CATS = new Set(['Cultural & Heritage','Language','Volunteer / Service','Programs in India','Diaspora Networks','Other']);
    const VALID_STATUSES = new Set(['Open','Interested','Cancelled','Complete']);
    const rows = pendingImport.map((i: any) => ({
      family_id:   familyId,
      title:       i.title.trim(),
      category:    VALID_CATS.has(i.category)   ? i.category : null,
      details:     i.details   ? String(i.details).trim()  || null : null,
      status:      VALID_STATUSES.has(i.status) ? i.status  : 'Open',
      starred:     !!i.starred,
      shortlisted: !!i.shortlisted,
    }));
    const { error } = await supabase.from('india_activities').insert(rows);
    btn.disabled = false; btn.textContent = 'Import';
    document.getElementById('ia-import-preview')!.style.display = 'none';
    pendingImport = [];
    if (error) { showIaError('Import failed: ' + error.message); return; }
    await loadItems();
  });

  document.getElementById('ia-import-cancel')!.addEventListener('click', () => {
    document.getElementById('ia-import-preview')!.style.display = 'none';
    pendingImport = [];
  });

  async function loadItems() {
    if (!familyId) return;
    const { data, error } = await supabase.from('india_activities').select('*')
      .eq('family_id', familyId).order('created_at', { ascending: false });
    if (error) {
      tbody.innerHTML = '<tr><td colspan="7" class="ia-td-msg" style="color:var(--sl-color-red)">Failed to load.</td></tr>';
      return;
    }
    allItems = data ?? [];
    renderTable();
  }

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      document.addEventListener('data-loaded', async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', s.user.id).single();
          familyId = p?.family_id ?? '';
          await loadItems();
        }
      }, { once: true });
      return;
    }
    const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', session.user.id).single();
    familyId = p?.family_id ?? '';
    await loadItems();
  }

  init();
</script>

<style is:global>
  #ia-wrap { max-width: 100%; }

  .ia-form {
    display: flex; flex-direction: column; gap: 0.75rem;
    padding: 1.25rem; border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem; background: var(--sl-color-bg-nav); margin-bottom: 1.5rem;
  }
  .ia-form__fields { display: grid; grid-template-columns: 1fr auto auto; gap: 0.75rem; align-items: end; }
  .ia-form__field  { display: flex; flex-direction: column; gap: 0.25rem; }
  .ia-label {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--sl-color-gray-2);
  }
  .ia-input, .ia-select, .ia-textarea {
    padding: 0.5rem 0.65rem; border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.375rem; background: var(--sl-color-bg);
    color: var(--sl-color-text); font-size: 0.875rem; font-family: inherit; width: 100%;
  }
  .ia-input:focus, .ia-select:focus, .ia-textarea:focus {
    outline: 2px solid var(--sl-color-accent); border-color: var(--sl-color-accent);
  }
  .ia-textarea { resize: vertical; min-height: 72px; }
  .ia-form__actions { display: flex; align-items: center; gap: 0.65rem; flex-wrap: wrap; }
  .ia-btn {
    padding: 0.45rem 1rem; border-radius: 0.375rem; font-size: 0.85rem;
    font-family: inherit; cursor: pointer; border: 1px solid transparent; white-space: nowrap;
  }
  .ia-btn--primary { background: var(--sl-color-accent); color: #fff; border-color: var(--sl-color-accent); }
  .ia-btn--primary:hover { opacity: 0.88; }
  .ia-btn--save { background: #16a34a; border-color: #16a34a; color: #fff; }
  .ia-btn--export { background: transparent; border-color: var(--sl-color-accent); color: var(--sl-color-accent); }
  .ia-btn--export:hover { background: var(--sl-color-accent); color: #fff; }
  .ia-btn--cancel { background: transparent; border-color: var(--sl-color-gray-4); color: var(--sl-color-gray-2); }
  .ia-btn--cancel:hover { border-color: #ef4444; color: #ef4444; }
  .ia-btn--import { background: transparent; border-color: var(--sl-color-gray-4); color: var(--sl-color-gray-2); }
  .ia-btn--import:hover { border-color: var(--sl-color-accent); color: var(--sl-color-accent); }
  .ia-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .ia-error { font-size: 0.82rem; color: #ef4444; }
  .ia-import-preview {
    display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    margin-top: 0.5rem; padding: 0.6rem 0.9rem;
    background: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.4rem; font-size: 0.82rem;
  }
  .ia-import-msg { color: var(--sl-color-gray-2); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ia-import-format { margin-top: 0.5rem; font-size: 0.8rem; color: var(--sl-color-gray-2); }
  .ia-import-format summary {
    cursor: pointer; user-select: none; color: var(--sl-color-gray-3);
    font-size: 0.75rem; padding: 0.2rem 0;
  }
  .ia-import-format summary:hover { color: var(--sl-color-accent); }
  .ia-import-pre {
    margin: 0.4rem 0 0; padding: 0.75rem 1rem;
    background: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem; font-size: 0.75rem; line-height: 1.6;
    overflow-x: auto; white-space: pre; color: var(--sl-color-text);
  }

  .ia-toolbar { display: flex; align-items: center; margin-bottom: 0.65rem; }
  .ia-count { font-size: 0.82rem; color: var(--sl-color-gray-2); }

  .ia-table-wrap { overflow-x: auto; }
  .ia-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .ia-th {
    padding: 0.45rem 0.75rem; text-align: left; font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--sl-color-gray-2);
    border-bottom: 2px solid var(--sl-color-gray-5); white-space: nowrap;
  }
  .ia-th--star    { width: 36px; text-align: center; }
  .ia-th--pin     { width: 36px; text-align: center; }
  .ia-th--cat     { width: 150px; }
  .ia-th--status  { width: 130px; }
  .ia-th--date    { width: 88px; }
  .ia-th--actions { width: 100px; }

  .ia-td { padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--sl-color-gray-6); vertical-align: middle; }
  .ia-td--star  { text-align: center; }
  .ia-td--pin   { text-align: center; }
  .ia-td--title { vertical-align: top; padding-top: 0.65rem; }
  .ia-td--date  { white-space: nowrap; color: var(--sl-color-gray-3); font-size: 0.8rem; }
  .ia-td-msg    { padding: 2rem; text-align: center; color: var(--sl-color-gray-2); }

