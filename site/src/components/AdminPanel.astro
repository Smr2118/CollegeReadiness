---
---

<div id="admin-check" class="admin-status">Verifying access…</div>
<div id="admin-denied" class="admin-status" style="display:none">⛔ Admin access required.</div>

<div id="admin-ui" style="display:none">

  <!-- ── Tab nav ── -->
  <div class="admin-tabs" role="tablist">
    <button class="admin-tab active" data-tab="families" role="tab">👨‍👩‍👧 Families</button>
    <button class="admin-tab" data-tab="users"    role="tab">👤 Users</button>
    <button class="admin-tab" data-tab="programs" role="tab">📚 Programs</button>
    <button class="admin-tab" data-tab="nav"      role="tab">🔒 Nav Access</button>
    <button class="admin-tab" data-tab="stats"    role="tab">📊 Stats</button>
  </div>

  <!-- ══ Families tab ══════════════════════════════════════════════════════ -->
  <div id="tab-families" class="admin-tab-panel">

    <section class="admin-section">
      <h2 class="admin-section__title">Family Groups</h2>
      <div id="families-list" class="admin-table-wrap">Loading…</div>

      <form id="create-family-form" class="admin-form">
        <h3 class="admin-form__subtitle">Create Family Group</h3>
        <div class="admin-form__row">
          <label class="admin-label">ID <span class="admin-hint">(slug, e.g. "sant")</span></label>
          <input id="fam-id" class="admin-input" type="text" placeholder="sant" required />
        </div>
        <div class="admin-form__row">
          <label class="admin-label">Display Name</label>
          <input id="fam-name" class="admin-input" type="text" placeholder="Sant Family" required />
        </div>
        <div class="admin-form__row">
          <label class="admin-label" style="display:flex;align-items:center;gap:0.5rem">
            <input id="fam-readonly" type="checkbox" />
            Read-Only <span class="admin-hint">(demo — blocks all data writes via RLS)</span>
          </label>
        </div>
        <button class="admin-btn" type="submit">Create Family</button>
        <p id="fam-msg" class="admin-msg" style="display:none"></p>
      </form>
    </section>

  </div>

  <!-- ══ Users tab ═════════════════════════════════════════════════════════ -->
  <div id="tab-users" class="admin-tab-panel" style="display:none">

    <section class="admin-section">
      <h2 class="admin-section__title">Users</h2>
      <div id="users-list" class="admin-table-wrap">Loading…</div>

      <form id="create-user-form" class="admin-form">
        <h3 class="admin-form__subtitle">Create User</h3>
        <div class="admin-form__row">
          <label class="admin-label">Email</label>
          <input id="new-email" class="admin-input" type="email" required />
        </div>
        <div class="admin-form__row">
          <label class="admin-label">Password</label>
          <input id="new-password" class="admin-input" type="password" required minlength="8" />
        </div>
        <div class="admin-form__row">
          <label class="admin-label">Display Name</label>
          <input id="new-display" class="admin-input" type="text" placeholder="Mom" required minlength="2" />
        </div>
        <div class="admin-form__row">
          <label class="admin-label">Family Group</label>
          <select id="new-family" class="admin-select"></select>
        </div>
        <button id="create-user-btn" class="admin-btn" type="submit">Create User</button>
        <p id="user-msg" class="admin-msg" style="display:none"></p>
      </form>
    </section>

  </div>

  <!-- ══ Programs tab ══════════════════════════════════════════════════════ -->
  <div id="tab-programs" class="admin-tab-panel" style="display:none">

    <section class="admin-section">
      <h2 class="admin-section__title">Programs</h2>
      <div id="programs-list" class="admin-table-wrap">Loading…</div>

      <details class="admin-details" id="program-form-wrap">
        <summary class="admin-details__summary" id="program-form-title">+ Add New Program</summary>
        <form id="program-form" class="admin-form" style="margin-top:1rem">
          <input type="hidden" id="prog-id" />

          <div class="admin-form__grid">
            <div class="admin-form__row">
              <label class="admin-label">Name *</label>
              <input id="prog-name" class="admin-input" type="text" required />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Org *</label>
              <input id="prog-org" class="admin-input" type="text" required />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Category *</label>
              <select id="prog-category" class="admin-select">
                <option>Math &amp; Physics</option>
                <option>Computer Science &amp; Engineering</option>
                <option>Robotics &amp; AI</option>
                <option>General STEM</option>
                <option>Life Sciences</option>
                <option>Quantum Computing</option>
                <option>Humanities</option>
                <option>Environmental Science</option>
                <option>Miscellaneous</option>
              </select>
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Status *</label>
              <select id="prog-status" class="admin-select">
                <option value="open">Open</option>
                <option value="closed">Closed</option>
                <option value="nextyear">Next Year</option>
                <option value="conflict">Conflict</option>
              </select>
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Tier (1–4) *</label>
              <input id="prog-tier" class="admin-input" type="number" min="1" max="4" required />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Rating (0–5)</label>
              <input id="prog-rating" class="admin-input" type="number" min="0" max="5" step="0.5" />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Selectivity</label>
              <select id="prog-selectivity" class="admin-select">
                <option value="">—</option>
                <option value="elite">elite</option>
                <option value="very">very</option>
                <option value="competitive">competitive</option>
                <option value="moderate">moderate</option>
                <option value="open">open</option>
              </select>
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Selectivity Label</label>
              <input id="prog-selectivity-label" class="admin-input" type="text" placeholder="e.g. Very Competitive (<10%)" />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">College Impact (1–5)</label>
              <input id="prog-college-impact" class="admin-input" type="number" min="1" max="5" />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">College Impact Label</label>
              <input id="prog-college-impact-label" class="admin-input" type="text" placeholder="e.g. Transformative" />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Format</label>
              <select id="prog-format" class="admin-select">
                <option value="">—</option>
                <option value="In-Person">In-Person</option>
                <option value="Virtual">Virtual</option>
                <option value="Hybrid">Hybrid</option>
              </select>
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Cost</label>
              <select id="prog-cost" class="admin-select">
                <option value="">—</option>
                <option value="Free">Free</option>
                <option value="Stipend">Stipend</option>
                <option value="Paid">Paid</option>
              </select>
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Duration</label>
              <input id="prog-duration" class="admin-input" type="text" placeholder="e.g. 6 weeks (residential)" />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Grades</label>
              <input id="prog-grades" class="admin-input" type="text" placeholder="e.g. Rising Juniors/Seniors" />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">URL</label>
              <input id="prog-url" class="admin-input" type="url" placeholder="https://…" />
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Deadline</label>
              <input id="prog-deadline" class="admin-input" type="text" placeholder="e.g. April 27, 2026" />
            </div>
            <div class="admin-form__row" style="grid-column:1/-1">
              <label class="admin-label">Description</label>
              <textarea id="prog-description" class="admin-input" rows="3" style="resize:vertical"></textarea>
            </div>
            <div class="admin-form__row" style="grid-column:1/-1">
              <label class="admin-label">Note</label>
              <textarea id="prog-note" class="admin-input" rows="2" style="resize:vertical"></textarea>
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Note Type</label>
              <select id="prog-note-type" class="admin-select">
                <option value="">—</option>
                <option value="priority">priority</option>
                <option value="deadline">deadline</option>
                <option value="info">info</option>
                <option value="warning">warning</option>
                <option value="conflict">conflict</option>
                <option value="nextyear">nextyear</option>
              </select>
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Access Level</label>
              <select id="prog-access-level" class="admin-select">
                <option value="public">🌐 Public (all families)</option>
                <option value="basic">🔹 Basic (basic + premium families)</option>
                <option value="premium">⭐ Premium (premium families only)</option>
              </select>
            </div>
            <div class="admin-form__row">
              <label class="admin-label">Sort Order</label>
              <input id="prog-sort-order" class="admin-input" type="number" min="0" value="0" />
            </div>
            <div class="admin-form__row" style="grid-column:1/-1">
              <label class="admin-label">Tags <span class="admin-hint">(comma-separated)</span></label>
              <input id="prog-tags" class="admin-input" type="text" placeholder="MIT, Research, Residential" />
            </div>
          </div>

          <div style="display:flex;gap:0.75rem;margin-top:1rem;flex-wrap:wrap">
            <button class="admin-btn" type="submit" id="prog-save-btn">Save Program</button>
            <button class="admin-btn admin-btn--secondary" type="button" id="prog-cancel-btn">Cancel</button>
          </div>
          <p id="prog-msg" class="admin-msg" style="display:none"></p>
        </form>
      </details>
    </section>

  </div>

  <!-- ══ Nav Access tab ══════════════════════════════════════════════════════ -->
  <div id="tab-nav" class="admin-tab-panel" style="display:none">

    <section class="admin-section">
      <h2 class="admin-section__title">Navigation Access</h2>
      <p style="color:var(--sl-color-gray-2);font-size:0.9rem;margin-bottom:1.25rem">
        Set the minimum plan required to see each sidebar link. Admins always see all links regardless of this setting.
      </p>
      <div id="nav-access-list" class="admin-table-wrap">Loading…</div>
    </section>

  </div>

  <!-- ══ Stats tab ══════════════════════════════════════════════════════════ -->
  <div id="tab-stats" class="admin-tab-panel" style="display:none">

    <section class="admin-section">
      <h2 class="admin-section__title">Login Stats</h2>

      <div style="display:flex;gap:2rem;flex-wrap:wrap;margin-bottom:1.5rem">
        <div class="admin-stat-card">
          <div class="admin-stat-card__value" id="stat-total-logins">—</div>
          <div class="admin-stat-card__label">Total Logins</div>
        </div>
        <div class="admin-stat-card">
          <div class="admin-stat-card__value" id="stat-logins-7d">—</div>
          <div class="admin-stat-card__label">Last 7 Days</div>
        </div>
        <div class="admin-stat-card">
          <div class="admin-stat-card__value" id="stat-unique-users">—</div>
          <div class="admin-stat-card__label">Unique Users</div>
        </div>
      </div>

      <h3 class="admin-form__subtitle">Per-User Summary</h3>
      <div id="stats-by-user" class="admin-table-wrap">Loading…</div>

      <h3 class="admin-form__subtitle" style="margin-top:1.5rem">Recent Logins</h3>
      <div id="stats-recent" class="admin-table-wrap">Loading…</div>
    </section>

  </div>

</div>

<script>
  import { supabase } from '../lib/supabase';

  let families: { id: string; name: string }[] = [];

  /* ── Tabs ── */
  document.querySelectorAll<HTMLButtonElement>('.admin-tab').forEach(btn => {
    btn.addEventListener('click', () => switchTab(btn.dataset.tab!));
  });

  function switchTab(name: string) {
    document.querySelectorAll<HTMLButtonElement>('.admin-tab').forEach(b => {
      b.classList.toggle('active', b.dataset.tab === name);
    });
    document.querySelectorAll<HTMLElement>('.admin-tab-panel').forEach(p => {
      p.style.display = p.id === `tab-${name}` ? '' : 'none';
    });
  }

  /* ── Boot ── */
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { window.location.href = '../programs/'; return; }

    const { data: profile } = await supabase
      .from('user_profiles')
      .select('role')
      .eq('user_id', session.user.id)
      .single();

    const isAdmin = profile?.role === 'admin' || session.user.user_metadata?.role === 'admin';

    if (!isAdmin) {
      show('admin-check', false); show('admin-denied', true); return;
    }

    show('admin-check', false); show('admin-ui', true);
    await Promise.all([loadFamilies(), loadUsers(), loadPrograms(), loadNavAccess(), loadStats()]);
  }

  /* ── Programs ── */
  async function loadPrograms() {
    const { data, error } = await supabase
      .from('programs')
      .select('id, name, org, tier, status, deadline, access_level, sort_order')
      .order('sort_order', { ascending: true });
    const el = document.getElementById('programs-list')!;
    if (error || !data?.length) { el.textContent = error?.message ?? 'No programs yet.'; return; }

    el.innerHTML = `<table class="admin-table">
      <thead><tr><th>Name</th><th>Org</th><th>Tier</th><th>Status</th><th>Access</th><th>Deadline</th><th></th></tr></thead>
      <tbody>
        ${data.map(p => `
          <tr>
            <td>${escCell(p.name)}</td>
            <td style="font-size:0.8rem;color:var(--sl-color-gray-2)">${escCell(p.org)}</td>
            <td>T${p.tier}</td>
            <td>
              <select class="admin-select prog-status-sel" data-pid="${p.id}" style="font-size:0.8rem;padding:0.2rem 0.4rem">
                <option value="open"      ${p.status === 'open'      ? 'selected' : ''}>Open</option>
                <option value="closed"    ${p.status === 'closed'    ? 'selected' : ''}>Closed</option>
                <option value="nextyear"  ${p.status === 'nextyear'  ? 'selected' : ''}>Next Year</option>
                <option value="conflict"  ${p.status === 'conflict'  ? 'selected' : ''}>Conflict</option>
              </select>
            </td>
            <td style="white-space:nowrap">
              <select class="admin-select prog-access-sel" data-pid="${p.id}" style="font-size:0.8rem;padding:0.2rem 0.4rem">
                <option value="public"  ${(p.access_level ?? 'public') === 'public'  ? 'selected' : ''}>🌐 Public</option>
                <option value="basic"   ${p.access_level === 'basic'   ? 'selected' : ''}>🔹 Basic</option>
                <option value="premium" ${p.access_level === 'premium' ? 'selected' : ''}>⭐ Premium</option>
              </select>
            </td>
            <td>
              <input class="admin-input prog-deadline-input" data-pid="${p.id}" type="text" value="${escAttr(p.deadline ?? '')}" placeholder="e.g. April 27, 2026" style="font-size:0.8rem;padding:0.2rem 0.4rem;width:9rem" />
            </td>
            <td style="white-space:nowrap">
              <button class="admin-btn admin-btn--sm prog-inline-save-btn" data-pid="${p.id}">Save</button>
              <button class="admin-btn admin-btn--sm prog-edit-btn" data-pid="${p.id}">Edit</button>
              <button class="admin-btn admin-btn--sm admin-btn--danger prog-del-btn" data-pid="${p.id}" data-pname="${escAttr(p.name)}">Del</button>
            </td>
          </tr>`).join('')}
      </tbody></table>`;

    document.querySelectorAll<HTMLButtonElement>('.prog-inline-save-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const pid          = btn.dataset.pid!;
        const access_level = document.querySelector<HTMLSelectElement>(`.prog-access-sel[data-pid="${pid}"]`)!.value;
        const status       = document.querySelector<HTMLSelectElement>(`.prog-status-sel[data-pid="${pid}"]`)!.value;
        const deadline     = (document.querySelector<HTMLInputElement>(`.prog-deadline-input[data-pid="${pid}"]`)!.value.trim()) || null;
        btn.textContent = '…'; btn.disabled = true;
        const { error } = await supabase.from('programs').update({ access_level, status, deadline }).eq('id', pid);
        btn.textContent = error ? 'Error' : '✓';
        setTimeout(() => { btn.textContent = 'Save'; btn.disabled = false; }, 2000);
      });
    });
    document.querySelectorAll<HTMLButtonElement>('.prog-edit-btn').forEach(btn => {
      btn.addEventListener('click', () => openEditProgram(btn.dataset.pid!));
    });
    document.querySelectorAll<HTMLButtonElement>('.prog-del-btn').forEach(btn => {
      btn.addEventListener('click', () => deleteProgram(btn.dataset.pid!, btn.dataset.pname!));
    });
  }

  async function openEditProgram(id: string) {
    const { data, error } = await supabase.from('programs').select('*').eq('id', id).single();
    if (error || !data) { alert('Failed to load program: ' + (error?.message ?? 'Unknown error')); return; }

    (document.getElementById('prog-id') as HTMLInputElement).value = data.id;
    setInput('prog-name',                 data.name ?? '');
    setInput('prog-org',                  data.org ?? '');
    setSelect('prog-category',            data.category ?? '');
    setSelect('prog-status',              data.status ?? 'open');
    setInput('prog-tier',                 String(data.tier ?? ''));
    setInput('prog-rating',               String(data.rating ?? ''));
    setSelect('prog-selectivity',         data.selectivity ?? '');
    setInput('prog-selectivity-label',    data.selectivity_label ?? '');
    setInput('prog-college-impact',       String(data.college_impact ?? ''));
    setInput('prog-college-impact-label', data.college_impact_label ?? '');
    setSelect('prog-format',              data.format ?? '');
    setSelect('prog-cost',                data.cost ?? '');
    setInput('prog-duration',             data.duration ?? '');
    setInput('prog-grades',               data.grades ?? '');
    setInput('prog-url',                  data.url ?? '');
    setInput('prog-deadline',             data.deadline ?? '');
    setTextarea('prog-description',       data.description ?? '');
    setTextarea('prog-note',              data.note ?? '');
    setSelect('prog-note-type',           data.note_type ?? '');
    setSelect('prog-access-level',        data.access_level ?? 'public');
    setInput('prog-sort-order',           String(data.sort_order ?? 0));
    setInput('prog-tags',                 (data.tags ?? []).join(', '));

    document.getElementById('program-form-title')!.textContent = `✏️ Edit: ${data.name}`;
    const wrap = document.getElementById('program-form-wrap') as HTMLDetailsElement;
    wrap.open = true;

    // Switch to Programs tab and scroll to form
    switchTab('programs');
    setTimeout(() => wrap.scrollIntoView({ behavior: 'smooth', block: 'start' }), 50);
  }

  async function deleteProgram(id: string, name: string) {
    if (!confirm(`Delete "${name}"? This cannot be undone.`)) return;
    const { error } = await supabase.from('programs').delete().eq('id', id);
    if (error) { alert('Delete failed: ' + error.message); return; }
    await loadPrograms();
  }

  document.getElementById('program-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('prog-save-btn') as HTMLButtonElement;
    btn.textContent = 'Saving…'; btn.disabled = true;

    const id   = (document.getElementById('prog-id') as HTMLInputElement).value.trim();
    const tags = val('prog-tags').split(',').map(t => t.trim()).filter(Boolean);

    const payload = {
      name:                 val('prog-name'),
      org:                  val('prog-org'),
      category:             val('prog-category'),
      status:               val('prog-status'),
      tier:                 parseInt(val('prog-tier')) || 1,
      rating:               parseFloat(val('prog-rating')) || null,
      selectivity:          val('prog-selectivity') || null,
      selectivity_label:    val('prog-selectivity-label') || null,
      college_impact:       parseInt(val('prog-college-impact')) || null,
      college_impact_label: val('prog-college-impact-label') || null,
      format:               val('prog-format') || null,
      cost:                 val('prog-cost') || null,
      duration:             val('prog-duration') || null,
      grades:               val('prog-grades') || null,
      url:                  val('prog-url') || null,
      deadline:             val('prog-deadline') || null,
      description:          val('prog-description') || null,
      note:                 val('prog-note') || null,
      note_type:            val('prog-note-type') || null,
      access_level:         val('prog-access-level') || 'public',
      sort_order:           parseInt(val('prog-sort-order')) || 0,
      tags,
      updated_at:           new Date().toISOString(),
    };

    const { error } = id
      ? await supabase.from('programs').update(payload).eq('id', id)
      : await supabase.from('programs').insert(payload);

    btn.textContent = 'Save Program'; btn.disabled = false;
    setMsg('prog-msg', error ? `Error: ${error.message}` : `Program "${payload.name}" saved.`, !error);
    if (!error) { resetProgramForm(); await loadPrograms(); }
  });

  document.getElementById('prog-cancel-btn')!.addEventListener('click', resetProgramForm);

  function resetProgramForm() {
    (document.getElementById('program-form') as HTMLFormElement).reset();
    (document.getElementById('prog-id') as HTMLInputElement).value = '';
    document.getElementById('program-form-title')!.textContent = '+ Add New Program';
    (document.getElementById('program-form-wrap') as HTMLDetailsElement).open = false;
    (document.getElementById('prog-msg') as HTMLElement).style.display = 'none';
  }

  /* ── Families ── */
  async function loadFamilies() {
    const { data, error } = await supabase.from('families').select('*').order('name');
    const el = document.getElementById('families-list')!;
    if (error || !data?.length) { el.textContent = error?.message ?? 'No families yet.'; return; }

    families = data;
    el.innerHTML = `<table class="admin-table">
      <thead><tr><th>ID</th><th>Name</th><th>Plan</th><th>Read-Only</th><th>Created</th><th></th></tr></thead>
      <tbody>
        ${data.map(f => `
          <tr>
            <td><code>${escCell(f.id)}</code></td>
            <td>${escCell(f.name)}</td>
            <td>
              <select class="admin-select fam-plan-sel" data-fid="${f.id}">
                <option value="standard" ${(f.plan ?? 'standard') === 'standard' ? 'selected' : ''}>Standard</option>
                <option value="basic"    ${f.plan === 'basic'    ? 'selected' : ''}>🔹 Basic</option>
                <option value="premium"  ${f.plan === 'premium'  ? 'selected' : ''}>⭐ Premium</option>
              </select>
            </td>
            <td>
              <select class="admin-select fam-readonly-sel" data-fid="${f.id}">
                <option value="false" ${!f.is_readonly ? 'selected' : ''}>No</option>
                <option value="true"  ${f.is_readonly  ? 'selected' : ''}>Yes — Demo</option>
              </select>
            </td>
            <td>${fmt(f.created_at)}</td>
            <td><button class="admin-btn admin-btn--sm fam-save-btn" data-fid="${f.id}">Save</button></td>
          </tr>`).join('')}
      </tbody></table>`;

    document.querySelectorAll<HTMLButtonElement>('.fam-save-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const fid         = btn.dataset.fid!;
        const plan        = document.querySelector<HTMLSelectElement>(`.fam-plan-sel[data-fid="${fid}"]`)!.value;
        const is_readonly = document.querySelector<HTMLSelectElement>(`.fam-readonly-sel[data-fid="${fid}"]`)!.value === 'true';
        btn.textContent = '…'; btn.disabled = true;
        const { error } = await supabase.from('families').update({ plan, is_readonly }).eq('id', fid);
        btn.textContent = error ? 'Error' : '✓';
        setTimeout(() => { btn.textContent = 'Save'; btn.disabled = false; }, 2000);
      });
    });

    populateFamilySelects();
  }

  document.getElementById('create-family-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id          = val('fam-id').toLowerCase().replace(/\s+/g, '-');
    const name        = val('fam-name');
    const is_readonly = (document.getElementById('fam-readonly') as HTMLInputElement).checked;
    const { error }   = await supabase.from('families').insert({ id, name, is_readonly });
    setMsg('fam-msg', error ? `Error: ${error.message}` : `Family "${name}" created.`, !error);
    if (!error) { (e.target as HTMLFormElement).reset(); await loadFamilies(); }
  });

  /* ── Users ── */
  async function loadUsers() {
    const { data, error } = await supabase.from('user_profiles').select('*').order('display_name');
    const el = document.getElementById('users-list')!;
    if (error || !data?.length) { el.textContent = error?.message ?? 'No users yet.'; return; }

    el.innerHTML = `<table class="admin-table">
      <thead><tr><th>Name</th><th>Email</th><th>Family</th><th>Role</th><th></th></tr></thead>
      <tbody>
        ${data.map(u => `
          <tr>
            <td>${u.display_name ?? '—'}</td>
            <td>${u.email ?? '—'}</td>
            <td>
              <select class="admin-select assign-sel" data-uid="${u.user_id}" data-current="${u.family_id ?? ''}"></select>
            </td>
            <td>
              <select class="admin-select role-sel" data-uid="${u.user_id}">
                <option value="member" ${u.role === 'member' ? 'selected' : ''}>Member</option>
                <option value="admin"  ${u.role === 'admin'  ? 'selected' : ''}>Admin</option>
              </select>
            </td>
            <td style="white-space:nowrap">
              <button class="admin-btn admin-btn--sm save-user-btn" data-uid="${u.user_id}">Save</button>
              <button class="admin-btn admin-btn--sm reset-pass-btn" data-email="${escAttr(u.email ?? '')}">Reset PW</button>
              <button class="admin-btn admin-btn--sm admin-btn--danger del-user-btn" data-uid="${u.user_id}" data-uname="${escAttr(u.display_name ?? u.email ?? '')}">Del</button>
            </td>
          </tr>`).join('')}
      </tbody></table>`;

    populateFamilySelects();

    document.querySelectorAll<HTMLButtonElement>('.save-user-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const uid       = btn.dataset.uid!;
        const familySel = document.querySelector<HTMLSelectElement>(`.assign-sel[data-uid="${uid}"]`)!;
        const roleSel   = document.querySelector<HTMLSelectElement>(`.role-sel[data-uid="${uid}"]`)!;
        btn.textContent = '…'; btn.disabled = true;

        const { error: famErr } = await supabase.from('user_profiles')
          .update({ family_id: familySel.value })
          .eq('user_id', uid);

        const { data: roleData, error: roleErr } = await supabase.functions.invoke('set-user-role', {
          body: { user_id: uid, role: roleSel.value },
        });
        const err = famErr?.message ?? roleErr?.message ?? roleData?.error;

        btn.textContent = err ? 'Error' : '✓ Saved';
        setTimeout(() => { btn.textContent = 'Save'; btn.disabled = false; }, 2000);
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.reset-pass-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const email = btn.dataset.email!;
        if (!email) { alert('No email address for this user.'); return; }
        btn.textContent = '…'; btn.disabled = true;
        const redirectTo = window.location.origin + '/CollegeReadiness/';
        const { error } = await supabase.auth.resetPasswordForEmail(email, { redirectTo });
        btn.textContent = error ? 'Error' : '✓ Sent';
        setTimeout(() => { btn.textContent = 'Reset PW'; btn.disabled = false; }, 3000);
      });
    });

    document.querySelectorAll<HTMLButtonElement>('.del-user-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const uid   = btn.dataset.uid!;
        const uname = btn.dataset.uname!;
        if (!confirm(`Delete user "${uname}"? This cannot be undone.`)) return;
        btn.textContent = '…'; btn.disabled = true;
        const { data, error } = await supabase.functions.invoke('delete-user', {
          body: { user_id: uid },
        });
        const err = error?.message ?? data?.error;
        if (err) {
          btn.textContent = 'Error';
          setTimeout(() => { btn.textContent = 'Del'; btn.disabled = false; }, 2000);
          alert('Delete failed: ' + err);
        } else {
          await loadUsers();
        }
      });
    });
  }

  document.getElementById('create-user-form')!.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = document.getElementById('create-user-btn') as HTMLButtonElement;
    btn.textContent = 'Creating…'; btn.disabled = true;

    const { data, error } = await supabase.functions.invoke('create-user', {
      body: {
        email:        val('new-email'),
        password:     val('new-password'),
        display_name: val('new-display'),
        family_id:    (document.getElementById('new-family') as HTMLSelectElement).value,
      },
    });

    btn.textContent = 'Create User'; btn.disabled = false;
    const err = error?.message ?? data?.error;
    setMsg('user-msg', err ? `Error: ${err}` : `User "${val('new-display')}" created.`, !err);
    if (!err) { (e.target as HTMLFormElement).reset(); await loadUsers(); }
  });

  /* ── Nav Access ── */
  const ALL_NAV_LINKS = [
    { path: '/',                  label: 'Home' },
    { path: '/programs/',         label: '☀️ College Summer Programs' },
    { path: '/internships/',      label: '💼 Internships' },
    { path: '/extracurriculars/', label: '🏆 Extra Curriculars' },
    { path: '/india-activities/', label: '🇮🇳 India Activities' },
    { path: '/calendar/',         label: '📅 Deadline Calendar' },
    { path: '/todos/',            label: '✅ Family To-Do' },
    { path: '/notes/',            label: '📓 Notes' },
    { path: '/essay-topics/',     label: '✍️ Essay Ideas' },
    { path: '/robotics-ideas/',   label: '🤖 Robotics Ideas' },
    { path: '/ideas/',            label: '💡 Ideas Board' },
    { path: '/references/',       label: '🔗 Reference Links' },
  ];

  async function loadNavAccess() {
    const { data } = await supabase.from('nav_access').select('path, min_plan');
    const ruleMap = new Map((data ?? []).map((r: any) => [r.path, r.min_plan]));
    const el = document.getElementById('nav-access-list')!;

    el.innerHTML = `<table class="admin-table">
      <thead><tr><th>Link</th><th>Path</th><th>Minimum Plan</th><th></th></tr></thead>
      <tbody>
        ${ALL_NAV_LINKS.map(link => {
          const cur = ruleMap.get(link.path) ?? 'standard';
          return `
          <tr>
            <td>${escCell(link.label)}</td>
            <td><code>${escCell(link.path)}</code></td>
            <td>
              <select class="admin-select nav-plan-sel" data-path="${escAttr(link.path)}" style="font-size:0.85rem">
                <option value="standard" ${cur === 'standard' ? 'selected' : ''}>🌐 Standard (all)</option>
                <option value="basic"    ${cur === 'basic'    ? 'selected' : ''}>🔹 Basic+</option>
                <option value="premium"  ${cur === 'premium'  ? 'selected' : ''}>⭐ Premium only</option>
              </select>
            </td>
            <td>
              <button class="admin-btn admin-btn--sm nav-save-btn" data-path="${escAttr(link.path)}">Save</button>
            </td>
          </tr>`;
        }).join('')}
      </tbody></table>`;

    document.querySelectorAll<HTMLButtonElement>('.nav-save-btn').forEach(btn => {
      btn.addEventListener('click', async () => {
        const path     = btn.dataset.path!;
        const min_plan = document.querySelector<HTMLSelectElement>(`.nav-plan-sel[data-path="${path}"]`)!.value;
        btn.textContent = '…'; btn.disabled = true;
        const { error } = await supabase
          .from('nav_access')
          .upsert({ path, min_plan }, { onConflict: 'path' });
        btn.textContent = error ? 'Error' : '✓';
        setTimeout(() => { btn.textContent = 'Save'; btn.disabled = false; }, 2000);
      });
    });
  }

  /* ── Stats ── */
  async function loadStats() {
    const { data, error } = await supabase
      .from('login_events')
      .select('user_id, display_name, family_id, logged_in_at')
      .order('logged_in_at', { ascending: false });

    if (error || !data) {
      document.getElementById('stats-by-user')!.textContent = error?.message ?? 'No data.';
      document.getElementById('stats-recent')!.textContent = '';
      return;
    }

    // Summary counts
    const cutoff = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000).toISOString();
    document.getElementById('stat-total-logins')!.textContent  = String(data.length);
    document.getElementById('stat-logins-7d')!.textContent     = String(data.filter(r => r.logged_in_at >= cutoff).length);
    document.getElementById('stat-unique-users')!.textContent  = String(new Set(data.map(r => r.user_id)).size);

    // Per-user summary
    const byUser = new Map<string, { name: string; family: string; count: number; last: string }>();
    for (const r of data) {
      if (!byUser.has(r.user_id)) {
        byUser.set(r.user_id, { name: r.display_name ?? '—', family: r.family_id ?? '—', count: 0, last: r.logged_in_at });
      }
      byUser.get(r.user_id)!.count++;
    }
    const userRows = [...byUser.values()].sort((a, b) => b.count - a.count);

    document.getElementById('stats-by-user')!.innerHTML = userRows.length
      ? `<table class="admin-table">
          <thead><tr><th>User</th><th>Family</th><th>Total Logins</th><th>Last Login</th></tr></thead>
          <tbody>${userRows.map(u => `
            <tr>
              <td>${escCell(u.name)}</td>
              <td>${escCell(u.family)}</td>
              <td>${u.count}</td>
              <td>${fmt(u.last)}</td>
            </tr>`).join('')}
          </tbody></table>`
      : 'No login data yet.';

    // Recent 30 logins
    const recent = data.slice(0, 30);
    document.getElementById('stats-recent')!.innerHTML = recent.length
      ? `<table class="admin-table">
          <thead><tr><th>User</th><th>Family</th><th>Time</th></tr></thead>
          <tbody>${recent.map(r => `
            <tr>
              <td>${escCell(r.display_name ?? '—')}</td>
              <td>${escCell(r.family_id ?? '—')}</td>
              <td>${new Date(r.logged_in_at).toLocaleString()}</td>
            </tr>`).join('')}
          </tbody></table>`
      : 'No logins recorded yet.';
  }

  /* ── Helpers ── */
  function escCell(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function escAttr(s: string | null | undefined) {
    return (s ?? '').replace(/"/g,'&quot;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function setInput(id: string, v: string) {
    (document.getElementById(id) as HTMLInputElement).value = v;
  }
  function setSelect(id: string, v: string) {
    const sel = document.getElementById(id) as HTMLSelectElement;
    const opt = Array.from(sel.options).find(o => o.value === v);
    if (opt) sel.value = v; else sel.selectedIndex = 0;
  }
  function setTextarea(id: string, v: string) {
    (document.getElementById(id) as HTMLTextAreaElement).value = v;
  }
  function populateFamilySelects() {
    document.querySelectorAll<HTMLSelectElement>('.assign-sel, #new-family').forEach(sel => {
      const current = sel.dataset.current ?? '';
      sel.innerHTML = families.map(f =>
        `<option value="${f.id}" ${f.id === current ? 'selected' : ''}>${f.name}</option>`
      ).join('');
    });
  }
  function val(id: string) {
    return (document.getElementById(id) as HTMLInputElement).value.trim();
  }
  function show(id: string, visible: boolean) {
    document.getElementById(id)!.style.display = visible ? 'block' : 'none';
  }
  function setMsg(id: string, text: string, ok: boolean) {
    const el = document.getElementById(id)!;
    el.textContent = text;
    el.className = `admin-msg ${ok ? 'admin-msg--ok' : 'admin-msg--error'}`;
    el.style.display = 'block';
  }
  function fmt(iso: string) { return new Date(iso).toLocaleDateString(); }

  init();
</script>
