---
---

<div id="et-wrap">

  <!-- Add / Edit form -->
  <form id="et-form" class="et-form">
    <div class="et-form__fields">
      <div class="et-form__field et-form__field--title">
        <label class="et-label" for="et-title">Point / Story</label>
        <input
          id="et-title"
          class="et-input"
          type="text"
          placeholder="e.g. Led robotics team to state finals despite losing half the team"
          required
        />
      </div>
      <div class="et-form__field et-form__field--cat">
        <label class="et-label" for="et-category">Theme</label>
        <select id="et-category" class="et-select">
          <option value="">— Pick a theme —</option>
          <option>Identity &amp; Background</option>
          <option>Leadership &amp; Impact</option>
          <option>Challenges &amp; Resilience</option>
          <option>Community &amp; Relationships</option>
          <option>Academic Passion</option>
          <option>Extracurricular</option>
          <option>Values &amp; Beliefs</option>
          <option>Creative &amp; Artistic</option>
          <option>Goals &amp; Future</option>
          <option>Humor &amp; Personality</option>
          <option>Other</option>
        </select>
      </div>
    </div>
    <div class="et-form__field">
      <label class="et-label" for="et-details">Details &amp; Examples</label>
      <textarea
        id="et-details"
        class="et-textarea"
        placeholder="Specific memories, feelings, people involved, what you learned…"
        rows="3"
      ></textarea>
    </div>
    <div class="et-form__actions">
      <button type="submit" class="et-btn et-btn--primary" id="et-submit">Add Point</button>
      <button type="button" class="et-btn et-btn--export" id="et-export">⬇ Export CSV</button>
      <button type="button" class="et-btn et-btn--cancel" id="et-cancel" style="display:none">Cancel</button>
      <span id="et-error" class="et-error" style="display:none"></span>
    </div>
  </form>

  <!-- Filter bar -->
  <div class="et-filter-bar" id="et-filter-bar" style="display:none">
    <span class="et-filter-label">Filter:</span>
    <div id="et-filter-chips" class="et-filter-chips">
      <button class="et-chip et-chip--active" data-cat="">All</button>
    </div>
  </div>

  <!-- Topics list -->
  <div id="et-list" class="et-list">
    <p id="et-loading" class="et-empty">Loading…</p>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  let familyId  = '';
  let editingId: number | null = null;
  let allTopics: any[] = [];
  let activeCategory = '';

  const form       = document.getElementById('et-form')     as HTMLFormElement;
  const titleEl    = document.getElementById('et-title')    as HTMLInputElement;
  const categoryEl = document.getElementById('et-category') as HTMLSelectElement;
  const detailsEl  = document.getElementById('et-details')  as HTMLTextAreaElement;
  const submitBtn  = document.getElementById('et-submit')   as HTMLButtonElement;
  const cancelBtn  = document.getElementById('et-cancel')   as HTMLButtonElement;
  const errorEl    = document.getElementById('et-error')    as HTMLElement;
  const listEl     = document.getElementById('et-list')     as HTMLElement;
  const filterBar  = document.getElementById('et-filter-bar')   as HTMLElement;
  const filterChips = document.getElementById('et-filter-chips') as HTMLElement;

  /* ── Category colour map ── */
  const CAT_COLOR: Record<string, string> = {
    'Identity & Background':      '#8b5cf6',
    'Leadership & Impact':        '#f59e0b',
    'Challenges & Resilience':    '#ef4444',
    'Community & Relationships':  '#22c55e',
    'Academic Passion':           '#3b82f6',
    'Extracurricular':            '#06b6d4',
    'Values & Beliefs':           '#ec4899',
    'Creative & Artistic':        '#f97316',
    'Goals & Future':             '#6366f1',
    'Humor & Personality':        '#84cc16',
    'Other':                      '#94a3b8',
  };

  function catColor(cat: string | null) {
    return CAT_COLOR[cat ?? ''] ?? '#94a3b8';
  }

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  /* ── Render ── */
  function renderTopics() {
    const filtered = activeCategory
      ? allTopics.filter(t => t.category === activeCategory)
      : allTopics;

    if (filtered.length === 0) {
      listEl.innerHTML = '<p class="et-empty">No points yet. Add one above.</p>';
      return;
    }

    listEl.innerHTML = filtered.map(t => {
      const color = catColor(t.category);
      return `
        <div class="et-card" data-id="${t.id}" style="--cat-color:${color}">
          <div class="et-card__header">
            <p class="et-card__title">${esc(t.title)}</p>
            <div class="et-card__meta">
              ${t.category ? `<span class="et-card__cat" style="background:${color}20;color:${color};border-color:${color}40">${esc(t.category)}</span>` : ''}
              <span class="et-card__date">${formatDate(t.created_at)}</span>
            </div>
          </div>
          ${t.details ? `<p class="et-card__details">${esc(t.details)}</p>` : ''}
          <div class="et-card__footer">
            <button class="et-action et-action--edit" data-id="${t.id}">Edit</button>
            <button class="et-action et-action--delete" data-id="${t.id}">Delete</button>
          </div>
        </div>`;
    }).join('');
  }

  /* ── Render filter chips ── */
  function renderFilters() {
    const categories = [...new Set(allTopics.map(t => t.category).filter(Boolean))].sort();
    if (categories.length === 0) { filterBar.style.display = 'none'; return; }

    filterBar.style.display = 'flex';
    filterChips.innerHTML = `<button class="et-chip${activeCategory === '' ? ' et-chip--active' : ''}" data-cat="">All (${allTopics.length})</button>` +
      categories.map(c => {
        const count = allTopics.filter(t => t.category === c).length;
        const active = activeCategory === c ? ' et-chip--active' : '';
        return `<button class="et-chip${active}" data-cat="${esc(c)}" style="--chip-color:${catColor(c)}">${esc(c)} (${count})</button>`;
      }).join('');
  }

  /* ── Load ── */
  async function loadTopics() {
    if (!familyId) return;
    const { data, error } = await supabase
      .from('essay_topics')
      .select('*')
      .eq('family_id', familyId)
      .order('created_at', { ascending: false });

    document.getElementById('et-loading')?.remove();

    if (error) {
      listEl.innerHTML = '<p class="et-empty" style="color:var(--sl-color-red)">Failed to load topics.</p>';
      return;
    }
    allTopics = data ?? [];
    renderFilters();
    renderTopics();
  }

  /* ── Submit ── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!familyId) return;

    const title    = titleEl.value.trim();
    const category = categoryEl.value || null;
    const details  = detailsEl.value.trim() || null;
    if (!title) return;

    errorEl.style.display = 'none';
    submitBtn.disabled = true;

    if (editingId !== null) {
      const { error } = await supabase
        .from('essay_topics')
        .update({ title, category, details, updated_at: new Date().toISOString() })
        .eq('id', editingId)
        .eq('family_id', familyId);
      if (error) { showError(error.message); }
      else { resetForm(); await loadTopics(); }
    } else {
      const { error } = await supabase
        .from('essay_topics')
        .insert({ family_id: familyId, title, category, details });
      if (error) { showError(error.message); }
      else { resetForm(); await loadTopics(); }
    }
    submitBtn.disabled = false;
  });

  function showError(msg: string) {
    errorEl.textContent = msg;
    errorEl.style.display = 'inline';
  }

  function resetForm() {
    editingId = null;
    titleEl.value    = '';
    categoryEl.value = '';
    detailsEl.value  = '';
    submitBtn.textContent = 'Add Point';
    submitBtn.classList.remove('et-btn--save');
    cancelBtn.style.display = 'none';
  }

  cancelBtn.addEventListener('click', resetForm);

  /* ── Edit / Delete ── */
  listEl.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;

    if (target.classList.contains('et-action--delete')) {
      const id = Number(target.dataset.id);
      if (!confirm('Delete this point?')) return;
      await supabase.from('essay_topics').delete().eq('id', id).eq('family_id', familyId);
      await loadTopics();
    }

    if (target.classList.contains('et-action--edit')) {
      const id    = Number(target.dataset.id);
      const topic = allTopics.find(t => t.id === id);
      if (!topic) return;

      editingId = id;
      titleEl.value    = topic.title;
      categoryEl.value = topic.category ?? '';
      detailsEl.value  = topic.details  ?? '';
      submitBtn.textContent = 'Save Changes';
      submitBtn.classList.add('et-btn--save');
      cancelBtn.style.display = 'inline-block';
      titleEl.focus();
      titleEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  /* ── Filter chips ── */
  filterChips.addEventListener('click', (e) => {
    const chip = (e.target as Element).closest<HTMLElement>('.et-chip');
    if (!chip) return;
    activeCategory = chip.dataset.cat ?? '';
    renderFilters();
    renderTopics();
  });

  /* ── Export CSV ── */
  document.getElementById('et-export')!.addEventListener('click', () => {
    if (allTopics.length === 0) return;
    const csvCell = (v: any) => `"${(v ?? '').toString().replace(/"/g, '""')}"`;
    const headers = ['Theme', 'Point / Story', 'Details', 'Date'];
    const lines = [
      headers.map(csvCell).join(','),
      ...allTopics.map(t => [
        t.category ?? '',
        t.title,
        t.details ?? '',
        new Date(t.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
      ].map(csvCell).join(','))
    ];
    const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'essay-topics.csv'; a.click();
    URL.revokeObjectURL(url);
  });

  /* ── Init ── */
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      document.addEventListener('data-loaded', async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          const { data: profile } = await supabase
            .from('user_profiles').select('family_id').eq('user_id', s.user.id).single();
          familyId = profile?.family_id ?? '';
          await loadTopics();
        }
      }, { once: true });
      return;
    }
    const { data: profile } = await supabase
      .from('user_profiles').select('family_id').eq('user_id', session.user.id).single();
    familyId = profile?.family_id ?? '';
    await loadTopics();
  }

  init();
</script>

<style>
  #et-wrap { max-width: 780px; }

  /* ── Form ── */
  .et-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
    margin-bottom: 1.5rem;
  }

  .et-form__fields {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    align-items: end;
  }

  .et-form__field { display: flex; flex-direction: column; gap: 0.25rem; }
  .et-form__field--cat { min-width: 200px; }

  .et-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-2);
  }

  .et-input, .et-select, .et-textarea {
    padding: 0.5rem 0.65rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.375rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    font-size: 0.875rem;
    font-family: inherit;
    width: 100%;
  }

  .et-input:focus, .et-select:focus, .et-textarea:focus {
    outline: 2px solid var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  .et-textarea { resize: vertical; min-height: 72px; }

  .et-form__actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .et-btn {
    padding: 0.45rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .et-btn--primary {
    background: var(--sl-color-accent);
    color: #fff;
    border-color: var(--sl-color-accent);
  }
  .et-btn--primary:hover { opacity: 0.88; }
  .et-btn--save {
    background: #16a34a;
    border-color: #16a34a;
  }
  .et-btn--export {
    background: transparent;
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }
  .et-btn--export:hover {
    background: var(--sl-color-accent);
    color: #fff;
  }
  .et-btn--cancel {
    background: transparent;
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-gray-2);
  }
  .et-btn--cancel:hover { border-color: #ef4444; color: #ef4444; }
  .et-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .et-error { font-size: 0.82rem; color: #ef4444; }

  /* ── Filter bar ── */
  .et-filter-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .et-filter-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    flex-shrink: 0;
  }

  .et-filter-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  .et-chip {
    padding: 0.22rem 0.65rem;
    border-radius: 9999px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-bg);
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.1s;
  }

  .et-chip--active {
    background: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    color: #fff;
  }

  .et-chip:not(.et-chip--active):hover {
    border-color: var(--chip-color, var(--sl-color-accent));
    color: var(--chip-color, var(--sl-color-accent));
  }

  /* ── Cards ── */
  .et-list { display: flex; flex-direction: column; gap: 0.75rem; }

  .et-empty { color: var(--sl-color-gray-2); font-size: 0.9rem; }

  .et-card {
    padding: 1rem 1.1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-left: 4px solid var(--cat-color, var(--sl-color-gray-4));
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .et-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .et-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--sl-color-text);
    margin: 0;
    flex: 1;
    line-height: 1.4;
  }

  .et-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .et-card__cat {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .et-card__date {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
  }

  .et-card__details {
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    line-height: 1.55;
    margin: 0;
    white-space: pre-wrap;
  }

  .et-card__footer { display: flex; gap: 0.5rem; }

  .et-action {
    font-size: 0.75rem;
    background: none;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.3rem;
    padding: 0.18rem 0.55rem;
    cursor: pointer;
    color: var(--sl-color-text);
    font-family: inherit;
  }
  .et-action--delete { color: #ef4444; border-color: #ef4444; }
  .et-action:hover { opacity: 0.7; }

  @media (max-width: 600px) {
    .et-form__fields { grid-template-columns: 1fr; }
    .et-form__field--cat { min-width: unset; }
  }
</style>
