---
---

<div id="et-wrap">

  <!-- Add / Edit form -->
  <form id="et-form" class="et-form">
    <div class="et-form__fields">
      <div class="et-form__field et-form__field--title">
        <label class="et-label" for="et-title">Point / Story</label>
        <input id="et-title" class="et-input" type="text"
          placeholder="e.g. Led robotics team to state finals despite losing half the team" required />
      </div>
      <div class="et-form__field">
        <label class="et-label" for="et-category">Theme</label>
        <select id="et-category" class="et-select">
          <option value="">— Pick a theme —</option>
          <option>STEM</option>
          <option>Political</option>
          <option>Family</option>
          <option>Other</option>
        </select>
      </div>
      <div class="et-form__field">
        <label class="et-label" for="et-status-form">Status</label>
        <select id="et-status-form" class="et-select">
          <option value="Open">Open</option>
          <option value="Interested">Interested</option>
          <option value="Cancelled">Cancelled</option>
          <option value="Complete">Complete</option>
        </select>
      </div>
    </div>
    <div class="et-form__field">
      <label class="et-label" for="et-details">Details &amp; Examples</label>
      <textarea id="et-details" class="et-textarea"
        placeholder="Specific memories, feelings, people involved, what you learned…" rows="3"></textarea>
    </div>
    <div class="et-form__actions">
      <button type="submit" class="et-btn et-btn--primary" id="et-submit">Add Point</button>
      <button type="button" class="et-btn et-btn--export" id="et-export">⬇ Export CSV</button>
      <button type="button" class="et-btn et-btn--cancel" id="et-cancel" style="display:none">Cancel</button>
      <span id="et-error" class="et-error" style="display:none"></span>
    </div>
  </form>

  <!-- Table area -->
  <div class="et-toolbar">
    <span id="et-count" class="et-count"></span>
  </div>
  <div class="et-table-wrap">
    <table class="et-table">
      <thead>
        <tr>
          <th class="et-th et-th--star">★</th>
          <th class="et-th et-th--title">Point / Story</th>
          <th class="et-th et-th--cat">Theme</th>
          <th class="et-th et-th--status">Status</th>
          <th class="et-th et-th--date">Date</th>
          <th class="et-th et-th--actions"></th>
        </tr>
      </thead>
      <tbody id="et-tbody">
        <tr><td colspan="6" class="et-td-msg">Loading…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  let familyId  = '';
  let editingId: number | null = null;
  let allTopics: any[] = [];
  let filterStatus  = 'all';
  let filterCat     = 'all';
  let filterStarred = false;
  let sortMode      = 'newest';

  const form       = document.getElementById('et-form')        as HTMLFormElement;
  const titleEl    = document.getElementById('et-title')       as HTMLInputElement;
  const categoryEl = document.getElementById('et-category')    as HTMLSelectElement;
  const statusFormEl = document.getElementById('et-status-form') as HTMLSelectElement;
  const detailsEl  = document.getElementById('et-details')     as HTMLTextAreaElement;
  const submitBtn  = document.getElementById('et-submit')      as HTMLButtonElement;
  const cancelBtn  = document.getElementById('et-cancel')      as HTMLButtonElement;
  const errorEl    = document.getElementById('et-error')       as HTMLElement;
  const tbody      = document.getElementById('et-tbody') as HTMLElement;
  const countEl    = document.getElementById('et-count') as HTMLElement;

  const CAT_COLOR: Record<string, string> = {
    'STEM':      '#3b82f6',
    'Political': '#ef4444',
    'Family':    '#22c55e',
    'Other':     '#94a3b8',
  };

  const STATUS_COLOR: Record<string, string> = {
    'Open':       '#3b82f6',
    'Interested': '#f59e0b',
    'Cancelled':  '#94a3b8',
    'Complete':   '#22c55e',
  };

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  /* ── Visible + sorted ── */
  function visibleTopics() {
    let list = allTopics.filter(t => {
      if (filterStatus !== 'all' && t.status !== filterStatus) return false;
      if (filterCat    !== 'all' && t.category !== filterCat)  return false;
      if (filterStarred && !t.starred) return false;
      return true;
    });
    const statusOrder = ['Open','Interested','Complete','Cancelled'];
    list.sort((a, b) => {
      if (sortMode === 'newest') return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
      if (sortMode === 'oldest') return new Date(a.created_at).getTime() - new Date(b.created_at).getTime();
      if (sortMode === 'az')     return a.title.localeCompare(b.title);
      if (sortMode === 'za')     return b.title.localeCompare(a.title);
      if (sortMode === 'status') return statusOrder.indexOf(a.status ?? 'Open') - statusOrder.indexOf(b.status ?? 'Open');
      return 0;
    });
    return list;
  }

  /* ── Render ── */
  function renderTable() {
    const topics = visibleTopics();
    countEl.textContent = `${topics.length} point${topics.length !== 1 ? 's' : ''}`;

    if (topics.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="et-td-msg">No points match. Try adjusting filters.</td></tr>';
      return;
    }

    tbody.innerHTML = topics.map(t => {
      const catColor = CAT_COLOR[t.category] ?? '#94a3b8';
      const sc       = STATUS_COLOR[t.status ?? 'Open'] ?? '#3b82f6';
      return `
        <tr class="et-row${t.status === 'Cancelled' ? ' et-row--cancelled' : ''}${t.status === 'Complete' ? ' et-row--complete' : ''}">
          <td class="et-td et-td--star">
            <button class="et-star${t.starred ? ' et-star--on' : ''}" data-id="${t.id}" data-starred="${!!t.starred}" title="Star">${t.starred ? '★' : '☆'}</button>
          </td>
          <td class="et-td et-td--title">
            <span class="et-row-title">${esc(t.title)}</span>
            ${t.details ? `<span class="et-row-sub">${esc(t.details)}</span>` : ''}
          </td>
          <td class="et-td et-td--cat">
            ${t.category
              ? `<span class="et-cat-badge" style="background:${catColor}20;color:${catColor};border-color:${catColor}40">${esc(t.category)}</span>`
              : '<span class="et-none">—</span>'}
          </td>
          <td class="et-td et-td--status">
            <select class="et-status-sel" data-id="${t.id}" data-status="${t.status ?? 'Open'}" style="--sc:${sc}">
              <option value="Open"       ${(t.status ?? 'Open') === 'Open'       ? 'selected' : ''}>Open</option>
              <option value="Interested" ${t.status === 'Interested' ? 'selected' : ''}>Interested</option>
              <option value="Cancelled"  ${t.status === 'Cancelled'  ? 'selected' : ''}>Cancelled</option>
              <option value="Complete"   ${t.status === 'Complete'   ? 'selected' : ''}>Complete</option>
            </select>
          </td>
          <td class="et-td et-td--date">${formatDate(t.created_at)}</td>
          <td class="et-td et-td--actions">
            <button class="et-act et-act--edit"   data-id="${t.id}">Edit</button>
            <button class="et-act et-act--delete" data-id="${t.id}">Delete</button>
          </td>
        </tr>`;
    }).join('');
  }

  /* ── Filter chips + sort + starred (in right sidebar) ── */
  document.addEventListener('click', e => {
    const chip = (e.target as Element).closest<HTMLElement>('.filter-chip[data-filter]');
    if (!chip) return;
    const filter = chip.dataset.filter!;
    const value  = chip.dataset.value!;
    if (filter === 'status') filterStatus = value;
    if (filter === 'cat')    filterCat    = value;
    document.querySelectorAll<HTMLElement>(`.filter-chip[data-filter="${filter}"]`).forEach(c =>
      c.classList.toggle('active', c.dataset.value === value));
    renderTable();
  });

  document.addEventListener('change', e => {
    const target = e.target as HTMLElement;
    if (target.id === 'bs-sort')    { sortMode = (target as HTMLSelectElement).value; renderTable(); }
    if (target.id === 'bs-starred') { filterStarred = (target as HTMLInputElement).checked; renderTable(); }
  });

  /* ── Table interactions ── */
  tbody.addEventListener('change', async e => {
    const sel = (e.target as HTMLElement).closest<HTMLSelectElement>('.et-status-sel');
    if (!sel) return;
    const id     = Number(sel.dataset.id);
    const status = sel.value;
    sel.dataset.status = status;
    sel.style.setProperty('--sc', STATUS_COLOR[status] ?? '#3b82f6');
    await supabase.from('essay_topics').update({ status }).eq('id', id).eq('family_id', familyId);
    const t = allTopics.find(t => t.id === id);
    if (t) { t.status = status; renderTable(); }
  });

  tbody.addEventListener('click', async e => {
    const target = e.target as HTMLElement;

    const starBtn = target.closest<HTMLElement>('.et-star');
    if (starBtn) {
      const id      = Number(starBtn.dataset.id);
      const starred = starBtn.dataset.starred !== 'true';
      await supabase.from('essay_topics').update({ starred }).eq('id', id).eq('family_id', familyId);
      const t = allTopics.find(t => t.id === id);
      if (t) { t.starred = starred; renderTable(); }
      return;
    }

    if (target.classList.contains('et-act--delete')) {
      const id = Number(target.dataset.id);
      if (!confirm('Delete this point?')) return;
      await supabase.from('essay_topics').delete().eq('id', id).eq('family_id', familyId);
      allTopics = allTopics.filter(t => t.id !== id);
      renderTable();
    }

    if (target.classList.contains('et-act--edit')) {
      const id    = Number(target.dataset.id);
      const topic = allTopics.find(t => t.id === id);
      if (!topic) return;
      editingId            = id;
      titleEl.value        = topic.title;
      categoryEl.value     = topic.category ?? '';
      statusFormEl.value   = topic.status   ?? 'Open';
      detailsEl.value      = topic.details  ?? '';
      submitBtn.textContent = 'Save Changes';
      submitBtn.classList.add('et-btn--save');
      cancelBtn.style.display = 'inline-block';
      titleEl.focus();
      titleEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  /* ── Submit ── */
  form.addEventListener('submit', async e => {
    e.preventDefault();
    if (!familyId) return;
    const title    = titleEl.value.trim();
    const category = categoryEl.value || null;
    const status   = statusFormEl.value;
    const details  = detailsEl.value.trim() || null;
    if (!title) return;
    errorEl.style.display = 'none';
    submitBtn.disabled = true;

    if (editingId !== null) {
      const { error } = await supabase.from('essay_topics')
        .update({ title, category, status, details, updated_at: new Date().toISOString() })
        .eq('id', editingId).eq('family_id', familyId);
      if (error) showError(error.message); else { resetForm(); await loadTopics(); }
    } else {
      const { error } = await supabase.from('essay_topics')
        .insert({ family_id: familyId, title, category, status, details });
      if (error) showError(error.message); else { resetForm(); await loadTopics(); }
    }
    submitBtn.disabled = false;
  });

  function showError(msg: string) { errorEl.textContent = msg; errorEl.style.display = 'inline'; }

  function resetForm() {
    editingId = null;
    titleEl.value = ''; categoryEl.value = ''; statusFormEl.value = 'Open'; detailsEl.value = '';
    submitBtn.textContent = 'Add Point';
    submitBtn.classList.remove('et-btn--save');
    cancelBtn.style.display = 'none';
  }
  cancelBtn.addEventListener('click', resetForm);

  /* ── Export CSV ── */
  document.getElementById('et-export')!.addEventListener('click', () => {
    if (!allTopics.length) return;
    const cell = (v: any) => `"${(v ?? '').toString().replace(/"/g,'""')}"`;
    const lines = [
      ['Starred','Theme','Point / Story','Details','Status','Date'].map(cell).join(','),
      ...allTopics.map(t => [
        t.starred ? 'Yes' : 'No', t.category ?? '', t.title, t.details ?? '',
        t.status ?? 'Open',
        new Date(t.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),
      ].map(cell).join(','))
    ];
    const blob = new Blob([lines.join('\n')], { type:'text/csv' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'essay-ideas.csv'; a.click();
    URL.revokeObjectURL(url);
  });

  /* ── Load ── */
  async function loadTopics() {
    if (!familyId) return;
    const { data, error } = await supabase.from('essay_topics').select('*')
      .eq('family_id', familyId).order('created_at', { ascending: false });
    if (error) {
      tbody.innerHTML = '<tr><td colspan="6" class="et-td-msg" style="color:var(--sl-color-red)">Failed to load.</td></tr>';
      return;
    }
    allTopics = data ?? [];
    renderTable();
  }

  /* ── Init ── */
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      document.addEventListener('data-loaded', async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', s.user.id).single();
          familyId = p?.family_id ?? '';
          await loadTopics();
        }
      }, { once: true });
      return;
    }
    const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', session.user.id).single();
    familyId = p?.family_id ?? '';
    await loadTopics();
  }

  init();
</script>

<style>
  #et-wrap { max-width: 100%; }

  /* ── Form ── */
  .et-form {
    display: flex; flex-direction: column; gap: 0.75rem;
    padding: 1.25rem; border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem; background: var(--sl-color-bg-nav);
    margin-bottom: 1.5rem;
  }
  .et-form__fields {
    display: grid; grid-template-columns: 1fr auto auto;
    gap: 0.75rem; align-items: end;
  }
  .et-form__field { display: flex; flex-direction: column; gap: 0.25rem; }
  .et-label {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--sl-color-gray-2);
  }
  .et-input, .et-select, .et-textarea {
    padding: 0.5rem 0.65rem; border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.375rem; background: var(--sl-color-bg);
    color: var(--sl-color-text); font-size: 0.875rem; font-family: inherit; width: 100%;
  }
  .et-input:focus, .et-select:focus, .et-textarea:focus {
    outline: 2px solid var(--sl-color-accent); border-color: var(--sl-color-accent);
  }
  .et-textarea { resize: vertical; min-height: 72px; }
  .et-form__actions { display: flex; align-items: center; gap: 0.65rem; flex-wrap: wrap; }
  .et-btn {
    padding: 0.45rem 1rem; border-radius: 0.375rem; font-size: 0.85rem;
    font-family: inherit; cursor: pointer; border: 1px solid transparent; white-space: nowrap;
  }
  .et-btn--primary { background: var(--sl-color-accent); color: #fff; border-color: var(--sl-color-accent); }
  .et-btn--primary:hover, .et-btn--save:hover { opacity: 0.88; }
  .et-btn--save { background: #16a34a; border-color: #16a34a; color: #fff; }
  .et-btn--export { background: transparent; border-color: var(--sl-color-accent); color: var(--sl-color-accent); }
  .et-btn--export:hover { background: var(--sl-color-accent); color: #fff; }
  .et-btn--cancel { background: transparent; border-color: var(--sl-color-gray-4); color: var(--sl-color-gray-2); }
  .et-btn--cancel:hover { border-color: #ef4444; color: #ef4444; }
  .et-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .et-error { font-size: 0.82rem; color: #ef4444; }

  /* ── Toolbar ── */
  .et-toolbar { display: flex; align-items: center; margin-bottom: 0.65rem; }
  .et-count { font-size: 0.82rem; color: var(--sl-color-gray-2); }

  /* ── Table ── */
  .et-table-wrap { overflow-x: auto; }
  .et-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .et-th {
    padding: 0.45rem 0.75rem; text-align: left;
    font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--sl-color-gray-2);
    border-bottom: 2px solid var(--sl-color-gray-5); white-space: nowrap;
  }
  .et-th--star    { width: 36px; text-align: center; }
  .et-th--cat     { width: 100px; }
  .et-th--status  { width: 130px; }
  .et-th--date    { width: 88px; }
  .et-th--actions { width: 100px; }

  .et-td {
    padding: 0.6rem 0.75rem;
    border-bottom: 1px solid var(--sl-color-gray-6);
    vertical-align: middle;
  }
  .et-td--star    { text-align: center; }
  .et-td--title   { vertical-align: top; padding-top: 0.65rem; }
  .et-td--date    { white-space: nowrap; color: var(--sl-color-gray-3); font-size: 0.8rem; }
  .et-td-msg      { padding: 2rem; text-align: center; color: var(--sl-color-gray-2); }

  .et-row:hover { background: var(--sl-color-gray-7, rgba(0,0,0,0.02)); }
  .et-row--cancelled .et-row-title { opacity: 0.5; text-decoration: line-through; }
  .et-row--complete  .et-row-title { opacity: 0.7; }

  .et-row-title { display: block; font-weight: 600; color: var(--sl-color-text); line-height: 1.4; }
  .et-row-sub {
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; font-size: 0.78rem; color: var(--sl-color-gray-2);
    margin-top: 0.1rem; line-height: 1.4;
  }
  .et-none { color: var(--sl-color-gray-4); }

  /* ── Star ── */
  .et-star {
    background: none; border: none; cursor: pointer;
    font-size: 1.15rem; color: var(--sl-color-gray-4);
    padding: 0; line-height: 1; transition: color 0.1s;
  }
  .et-star--on, .et-star:hover { color: #f59e0b; }

  /* ── Category badge ── */
  .et-cat-badge {
    font-size: 0.71rem; font-weight: 600; padding: 0.15rem 0.5rem;
    border-radius: 9999px; border: 1px solid transparent; white-space: nowrap;
  }

  /* ── Status select ── */
  .et-status-sel {
    padding: 0.22rem 0.45rem; border-radius: 0.3rem;
    border: 1px solid var(--sc, #3b82f6);
    background: transparent; color: var(--sc, #3b82f6);
    font-size: 0.78rem; font-family: inherit; cursor: pointer; font-weight: 600; width: 100%;
  }
  .et-status-sel:focus { outline: 2px solid var(--sl-color-accent); }

  /* ── Actions ── */
  .et-act {
    font-size: 0.72rem; background: none; border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.25rem; padding: 0.15rem 0.5rem;
    cursor: pointer; color: var(--sl-color-text); font-family: inherit; margin-right: 0.25rem;
  }
  .et-act--delete { color: #ef4444; border-color: #ef4444; }
  .et-act:hover { opacity: 0.7; }

  @media (max-width: 680px) {
    .et-form__fields { grid-template-columns: 1fr; }
  }
</style>
