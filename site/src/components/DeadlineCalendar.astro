---
// Deadlines are fetched from Supabase at runtime
---

<div id="cal-wrap" class="cal-wrap">

  <!-- Calendar header -->
  <div class="cal-header">
    <button id="cal-prev" class="cal-nav-btn" aria-label="Previous month">‹</button>
    <span id="cal-title" class="cal-title"></span>
    <button id="cal-next" class="cal-nav-btn" aria-label="Next month">›</button>
  </div>

  <!-- Day-of-week labels -->
  <div class="cal-dow-row">
    {['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].map(d => (
      <div class="cal-dow">{d}</div>
    ))}
  </div>

  <!-- Day grid -->
  <div id="cal-grid" class="cal-grid">
    <p id="cal-loading" style="grid-column:1/-1;padding:2rem 0;color:var(--sl-color-gray-2)">Loading…</p>
  </div>

  <!-- Selected day detail -->
  <div id="cal-detail" class="cal-detail" style="display:none">
    <div class="cal-detail__header">
      <span id="cal-detail-date" class="cal-detail__date"></span>
      <button id="cal-detail-close" class="cal-detail__close" aria-label="Close">✕</button>
    </div>
    <ul id="cal-detail-list" class="cal-detail__list"></ul>
  </div>

  <!-- Upcoming deadlines list -->
  <div class="cal-upcoming">
    <h3 class="cal-upcoming__title">Upcoming Deadlines</h3>
    <div id="cal-upcoming-list" class="cal-upcoming__list"></div>
  </div>

</div>

<script>
  import { supabase } from '../lib/supabase';

  const today = new Date();
  today.setHours(0, 0, 0, 0);

  const MONTHS = ['January','February','March','April','May','June',
                  'July','August','September','October','November','December'];
  const tierColor: Record<number,string> = { 1:'#d4a017', 2:'#3b82f6', 3:'#22c55e', 4:'#9ca3af' };

  function isoOf(y: number, m: number, d: number): string {
    return `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
  }

  function escHtml(str: string | null | undefined): string {
    return (str ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  interface DeadlineEntry { name:string; org:string; tier:number; status:string; url:string; dateISO:string; }

  let entries:  DeadlineEntry[] = [];
  let byDate:   Record<string, DeadlineEntry[]> = {};
  let viewYear  = today.getFullYear();
  let viewMonth = today.getMonth();

  // ── Render calendar grid ─────────────────────────────────────────────────
  function renderCalendar() {
    document.getElementById('cal-title')!.textContent = `${MONTHS[viewMonth]} ${viewYear}`;
    const grid = document.getElementById('cal-grid')!;
    grid.innerHTML = '';

    const firstDow   = new Date(viewYear, viewMonth, 1).getDay();
    const daysInMonth= new Date(viewYear, viewMonth + 1, 0).getDate();
    const todayISO   = isoOf(today.getFullYear(), today.getMonth(), today.getDate());

    for (let i = 0; i < firstDow; i++) {
      const blank = document.createElement('div');
      blank.className = 'cal-cell cal-cell--blank';
      grid.appendChild(blank);
    }

    for (let day = 1; day <= daysInMonth; day++) {
      const iso    = isoOf(viewYear, viewMonth, day);
      const events = byDate[iso] ?? [];
      const isPast  = iso < todayISO;
      const isToday = iso === todayISO;

      const cell = document.createElement('div');
      cell.className = 'cal-cell' +
        (isToday        ? ' cal-cell--today'      : '') +
        (isPast         ? ' cal-cell--past'        : '') +
        (events.length  ? ' cal-cell--has-events'  : '');

      const num = document.createElement('span');
      num.className  = 'cal-cell__num';
      num.textContent = String(day);
      cell.appendChild(num);

      if (events.length) {
        const dots = document.createElement('div');
        dots.className = 'cal-cell__dots';
        events.slice(0,3).forEach(e => {
          const dot = document.createElement('span');
          dot.className  = 'cal-dot';
          dot.style.background = tierColor[e.tier] ?? '#9ca3af';
          dots.appendChild(dot);
        });
        if (events.length > 3) {
          const more = document.createElement('span');
          more.className  = 'cal-dot-more';
          more.textContent = `+${events.length - 3}`;
          dots.appendChild(more);
        }
        cell.appendChild(dots);
        cell.addEventListener('click', () => showDetail(iso, events));
        cell.style.cursor = 'pointer';
      }
      grid.appendChild(cell);
    }
  }

  function showDetail(iso: string, events: DeadlineEntry[]) {
    const detail = document.getElementById('cal-detail')!;
    document.getElementById('cal-detail-date')!.textContent =
      new Date(iso + 'T12:00:00').toLocaleDateString('en-US',
        { weekday:'long', month:'long', day:'numeric', year:'numeric' });

    document.getElementById('cal-detail-list')!.innerHTML = events.map(e => `
      <li class="cal-detail__item">
        <span class="cal-detail__dot" style="background:${tierColor[e.tier] ?? '#9ca3af'}"></span>
        <div class="cal-detail__info">
          <a class="cal-detail__name" href="${escHtml(e.url)}" target="_blank" rel="noopener">${escHtml(e.name)}</a>
          <span class="cal-detail__org">${escHtml(e.org)}</span>
        </div>
        <span class="cal-badge cal-badge--t${e.tier}">T${e.tier}</span>
      </li>`).join('');

    detail.style.display = 'block';
  }

  function renderUpcoming() {
    const todayISO = isoOf(today.getFullYear(), today.getMonth(), today.getDate());
    const upcoming = entries
      .filter(e => e.dateISO >= todayISO)
      .sort((a,b) => a.dateISO.localeCompare(b.dateISO));

    const wrap = document.getElementById('cal-upcoming-list')!;
    if (!upcoming.length) {
      wrap.innerHTML = '<p class="cal-upcoming__empty">No upcoming deadlines found.</p>';
      return;
    }

    const groups: Record<string,{ label:string; items:DeadlineEntry[] }> = {};
    for (const e of upcoming) {
      const d = new Date(e.dateISO + 'T12:00:00');
      const key   = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
      const label = d.toLocaleDateString('en-US', { month:'long', year:'numeric' });
      if (!groups[key]) groups[key] = { label, items:[] };
      groups[key].items.push(e);
    }

    wrap.innerHTML = Object.values(groups).map(g => `
      <div class="cal-upcoming__group">
        <div class="cal-upcoming__month">${g.label}</div>
        ${g.items.map(e => {
          const d        = new Date(e.dateISO + 'T12:00:00');
          const dayStr   = d.toLocaleDateString('en-US', { weekday:'short', month:'short', day:'numeric' });
          const daysLeft = Math.round((new Date(e.dateISO + 'T12:00:00').getTime() - today.getTime()) / 86400000);
          const urgency  = daysLeft <= 7 ? 'cal-upcoming__days--urgent'
                         : daysLeft <= 21 ? 'cal-upcoming__days--soon' : '';
          return `
            <div class="cal-upcoming__item">
              <span class="cal-upcoming__daystr">${dayStr}</span>
              <div class="cal-upcoming__item-info">
                <a class="cal-upcoming__name" href="${escHtml(e.url)}" target="_blank" rel="noopener">${escHtml(e.name)}</a>
              </div>
              <span class="cal-badge cal-badge--t${e.tier}">T${e.tier}</span>
              <span class="cal-upcoming__days ${urgency}">${daysLeft}d</span>
            </div>`;
        }).join('')}
      </div>`).join('');
  }

  // ── Load from Supabase ───────────────────────────────────────────────────
  async function init() {
    const { data, error } = await supabase
      .from('programs')
      .select('name, org, tier, status, url, deadline')
      .not('deadline', 'is', null);

    document.getElementById('cal-loading')?.remove();

    if (error || !data) {
      document.getElementById('cal-grid')!.innerHTML =
        '<p style="grid-column:1/-1;color:var(--sl-color-red)">Failed to load deadlines.</p>';
      return;
    }

    // Parse dates
    for (const p of data) {
      if (!p.deadline) continue;
      const d = new Date(p.deadline);
      if (isNaN(d.getTime())) continue;
      entries.push({
        name:    p.name,
        org:     p.org,
        tier:    p.tier,
        status:  p.status,
        url:     p.url ?? '',
        dateISO: d.toISOString().slice(0,10),
      });
    }

    byDate = {};
    for (const e of entries) {
      if (!byDate[e.dateISO]) byDate[e.dateISO] = [];
      byDate[e.dateISO].push(e);
    }

    renderCalendar();
    renderUpcoming();
  }

  // ── Nav buttons ──────────────────────────────────────────────────────────
  document.getElementById('cal-prev')!.addEventListener('click', () => {
    viewMonth--;
    if (viewMonth < 0) { viewMonth = 11; viewYear--; }
    renderCalendar();
  });
  document.getElementById('cal-next')!.addEventListener('click', () => {
    viewMonth++;
    if (viewMonth > 11) { viewMonth = 0; viewYear++; }
    renderCalendar();
  });

  document.getElementById('cal-detail-close')!.addEventListener('click', () => {
    document.getElementById('cal-detail')!.style.display = 'none';
  });

  init();
</script>
