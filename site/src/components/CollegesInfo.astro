---
---

<div id="ci-wrap">

  <!-- Add / Edit form -->
  <form id="ci-form" class="ci-form">
    <div class="ci-form__fields">
      <div class="ci-form__field ci-form__field--name">
        <label class="ci-label" for="ci-name">College Name</label>
        <input id="ci-name" class="ci-input" type="text"
          placeholder="e.g. MIT, Stanford, UMich" required />
      </div>
      <div class="ci-form__field">
        <label class="ci-label" for="ci-location">Location</label>
        <input id="ci-location" class="ci-input" type="text"
          placeholder="City, State" />
      </div>
      <div class="ci-form__field">
        <label class="ci-label" for="ci-type">Type</label>
        <select id="ci-type" class="ci-select">
          <option value="">— Pick a type —</option>
          <option>Ivy League</option>
          <option>Liberal Arts</option>
          <option>Research University</option>
          <option>State University</option>
          <option>Other</option>
        </select>
      </div>
      <div class="ci-form__field">
        <label class="ci-label" for="ci-status-form">Status</label>
        <select id="ci-status-form" class="ci-select">
          <option value="Researching">Researching</option>
          <option value="Applying">Applying</option>
          <option value="Applied">Applied</option>
          <option value="Accepted">Accepted</option>
          <option value="Waitlisted">Waitlisted</option>
          <option value="Deferred">Deferred</option>
          <option value="Rejected">Rejected</option>
        </select>
      </div>
    </div>
    <div class="ci-form__field">
      <label class="ci-label" for="ci-notes">Notes</label>
      <textarea id="ci-notes" class="ci-textarea"
        placeholder="Deadlines, fit notes, contacts, scholarship info…" rows="3"></textarea>
    </div>
    <div class="ci-form__actions">
      <button type="submit" class="ci-btn ci-btn--primary" id="ci-submit">Add College</button>
      <button type="button" class="ci-btn ci-btn--export" id="ci-export">⬇ Export CSV</button>
      <button type="button" class="ci-btn ci-btn--import" id="ci-import-btn">⬆ Import JSON</button>
      <input type="file" id="ci-import-file" accept=".json" style="display:none" />
      <button type="button" class="ci-btn ci-btn--cancel" id="ci-cancel" style="display:none">Cancel</button>
      <span id="ci-error" class="ci-error" style="display:none"></span>
    </div>
    <div id="ci-import-preview" class="ci-import-preview" style="display:none">
      <span id="ci-import-msg" class="ci-import-msg"></span>
      <button type="button" class="ci-btn ci-btn--primary" id="ci-import-confirm">Import</button>
      <button type="button" class="ci-btn ci-btn--cancel" id="ci-import-cancel">Cancel</button>
    </div>
    <details class="ci-import-format">
      <summary>JSON format reference</summary>
      <pre class="ci-import-pre" is:raw>[
  {
    "name": "MIT",                       // required
    "location": "Cambridge, MA",
    "type": "Research University",       // Ivy League | Liberal Arts | Research University | State University | Other
    "status": "Researching",             // Researching | Applying | Applied | Accepted | Waitlisted | Deferred | Rejected
    "notes": "EA deadline Nov 1. Need to research CS program specifics.",
    "starred": false,
    "shortlisted": false
  }
]</pre>
    </details>
  </form>

  <!-- Cards area -->
  <div class="ci-toolbar">
    <span id="ci-count" class="ci-count"></span>
  </div>
  <div id="ci-cards" class="ci-cards">
    <p class="ci-msg">Loading…</p>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  let familyId  = '';
  let editingId: number | null = null;
  let allColleges: any[] = [];
  let filterStatus  = 'all';
  let filterType    = 'all';
  let filterStarred = false;
  let sortMode      = 'newest';

  const form         = document.getElementById('ci-form')        as HTMLFormElement;
  const nameEl       = document.getElementById('ci-name')        as HTMLInputElement;
  const locationEl   = document.getElementById('ci-location')    as HTMLInputElement;
  const typeEl       = document.getElementById('ci-type')        as HTMLSelectElement;
  const statusFormEl = document.getElementById('ci-status-form') as HTMLSelectElement;
  const notesEl      = document.getElementById('ci-notes')       as HTMLTextAreaElement;
  const submitBtn    = document.getElementById('ci-submit')      as HTMLButtonElement;
  const cancelBtn    = document.getElementById('ci-cancel')      as HTMLButtonElement;
  const errorEl      = document.getElementById('ci-error')       as HTMLElement;
  const cardsEl      = document.getElementById('ci-cards')       as HTMLElement;
  const countEl      = document.getElementById('ci-count')       as HTMLElement;

  const TYPE_COLOR = {
    'Ivy League':          '#7c3aed',
    'Liberal Arts':        '#0891b2',
    'Research University': '#1d4ed8',
    'State University':    '#047857',
    'Other':               '#94a3b8',
  };

  const STATUS_COLOR = {
    'Researching': '#3b82f6',
    'Applying':    '#8b5cf6',
    'Applied':     '#f59e0b',
    'Accepted':    '#22c55e',
    'Waitlisted':  '#f97316',
    'Deferred':    '#94a3b8',
    'Rejected':    '#ef4444',
  };

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function visibleColleges() {
    let list = allColleges.filter(c => {
      if (filterStatus !== 'all' && c.status !== filterStatus) return false;
      if (filterType   !== 'all' && c.type   !== filterType)   return false;
      if (filterStarred && !c.starred) return false;
      return true;
    });
    const statusOrder = ['Researching','Applying','Applied','Accepted','Waitlisted','Deferred','Rejected'];
    list.sort((a, b) => {
      if (sortMode === 'newest') return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
      if (sortMode === 'oldest') return new Date(a.created_at).getTime() - new Date(b.created_at).getTime();
      if (sortMode === 'az')     return a.name.localeCompare(b.name);
      if (sortMode === 'za')     return b.name.localeCompare(a.name);
      if (sortMode === 'status') return statusOrder.indexOf(a.status ?? 'Researching') - statusOrder.indexOf(b.status ?? 'Researching');
      return 0;
    });
    return list;
  }

  function render() {
    const colleges = visibleColleges();
    countEl.textContent = `${colleges.length} college${colleges.length !== 1 ? 's' : ''}`;

    if (colleges.length === 0) {
      cardsEl.innerHTML = '<p class="ci-msg">No colleges match. Try adjusting filters.</p>';
      return;
    }

    cardsEl.innerHTML = colleges.map(c => {
      const tc = TYPE_COLOR[c.type] ?? '#94a3b8';
      const sc = STATUS_COLOR[c.status ?? 'Researching'] ?? '#3b82f6';
      const rejected    = c.status === 'Rejected';
      const accepted    = c.status === 'Accepted';
      return `
        <div class="ci-card${rejected ? ' ci-card--rejected' : ''}${accepted ? ' ci-card--accepted' : ''}" style="--tc:${tc}">
          <div class="ci-card__top">
            <div class="ci-card__badges">
              ${c.type ? `<span class="ci-type-badge" style="background:${tc}18;color:${tc};border-color:${tc}40">${esc(c.type)}</span>` : ''}
              <select class="ci-status-sel" data-id="${c.id}" data-status="${c.status ?? 'Researching'}" style="--sc:${sc}">
                <option value="Researching" ${(c.status ?? 'Researching') === 'Researching' ? 'selected' : ''}>Researching</option>
                <option value="Applying"    ${c.status === 'Applying'    ? 'selected' : ''}>Applying</option>
                <option value="Applied"     ${c.status === 'Applied'     ? 'selected' : ''}>Applied</option>
                <option value="Accepted"    ${c.status === 'Accepted'    ? 'selected' : ''}>Accepted</option>
                <option value="Waitlisted"  ${c.status === 'Waitlisted'  ? 'selected' : ''}>Waitlisted</option>
                <option value="Deferred"    ${c.status === 'Deferred'    ? 'selected' : ''}>Deferred</option>
                <option value="Rejected"    ${c.status === 'Rejected'    ? 'selected' : ''}>Rejected</option>
              </select>
            </div>
            <div class="ci-card__icons">
              <button class="ci-star${c.starred ? ' ci-star--on' : ''}" data-id="${c.id}" data-starred="${!!c.starred}" title="Star">${c.starred ? '★' : '☆'}</button>
              <button class="ci-pin${c.shortlisted ? ' ci-pin--on' : ''}" data-id="${c.id}" data-shortlisted="${!!c.shortlisted}" title="Shortlist">📌</button>
            </div>
          </div>
          <div class="ci-card__title-row${c.notes ? ' ci-card__title-row--toggle' : ''}" data-action="toggle">
            <div class="ci-card__name-block">
              <p class="ci-card__name">${esc(c.name)}</p>
              ${c.location ? `<span class="ci-card__location">📍 ${esc(c.location)}</span>` : ''}
            </div>
            ${c.notes ? `<span class="ci-card__chevron">▶</span>` : ''}
          </div>
          ${c.notes ? `<p class="ci-card__notes">${esc(c.notes)}</p>` : ''}
          <div class="ci-card__footer">
            <span class="ci-card__date">${formatDate(c.created_at)}</span>
            <div class="ci-card__actions">
              <button class="ci-act ci-act--edit"   data-id="${c.id}">Edit</button>
              <button class="ci-act ci-act--delete" data-id="${c.id}">Delete</button>
            </div>
          </div>
        </div>`;
    }).join('');
  }

  /* ── Filter chips + sort ── */
  document.addEventListener('click', e => {
    const chip = (e.target as Element).closest<HTMLElement>('.filter-chip[data-filter]');
    if (!chip) return;
    const filter = chip.dataset.filter!;
    const value  = chip.dataset.value!;
    if (filter === 'status') filterStatus = value;
    if (filter === 'type')   filterType   = value;
    document.querySelectorAll<HTMLElement>(`.filter-chip[data-filter="${filter}"]`).forEach(c =>
      c.classList.toggle('active', c.dataset.value === value));
    render();
  });

  document.addEventListener('change', e => {
    const target = e.target as HTMLElement;
    if (target.id === 'bs-sort')    { sortMode = (target as HTMLSelectElement).value; render(); }
    if (target.id === 'bs-starred') { filterStarred = (target as HTMLInputElement).checked; render(); }
  });

  /* ── Card interactions ── */
  cardsEl.addEventListener('click', async e => {
    const toggleRow = (e.target as HTMLElement).closest('.ci-card__title-row--toggle');
    if (toggleRow) {
      toggleRow.closest('.ci-card')?.classList.toggle('ci-card--open');
      return;
    }

    const target = e.target as HTMLElement;

    const starBtn = target.closest<HTMLElement>('.ci-star');
    if (starBtn) {
      const id      = Number(starBtn.dataset.id);
      const starred = starBtn.dataset.starred !== 'true';
      await supabase.from('colleges').update({ starred }).eq('id', id).eq('family_id', familyId);
      const c = allColleges.find(c => c.id === id);
      if (c) { c.starred = starred; render(); }
      return;
    }

    const pinBtn = target.closest<HTMLElement>('.ci-pin');
    if (pinBtn) {
      const id          = Number(pinBtn.dataset.id);
      const shortlisted = pinBtn.dataset.shortlisted !== 'true';
      await supabase.from('colleges').update({ shortlisted }).eq('id', id).eq('family_id', familyId);
      const c = allColleges.find(c => c.id === id);
      if (c) { c.shortlisted = shortlisted; render(); }
      return;
    }

    if (target.classList.contains('ci-act--delete')) {
      const id = Number(target.dataset.id);
      if (!confirm('Delete this college?')) return;
      await supabase.from('colleges').delete().eq('id', id).eq('family_id', familyId);
      allColleges = allColleges.filter(c => c.id !== id);
      render();
      return;
    }

    if (target.classList.contains('ci-act--edit')) {
      const id = Number(target.dataset.id);
      const c  = allColleges.find(c => c.id === id);
      if (!c) return;
      editingId            = id;
      nameEl.value         = c.name;
      locationEl.value     = c.location  ?? '';
      typeEl.value         = c.type      ?? '';
      statusFormEl.value   = c.status    ?? 'Researching';
      notesEl.value        = c.notes     ?? '';
      submitBtn.textContent = 'Save Changes';
      submitBtn.classList.add('ci-btn--save');
      cancelBtn.style.display = 'inline-block';
      nameEl.focus();
      nameEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  cardsEl.addEventListener('change', async e => {
    const sel = (e.target as HTMLElement).closest<HTMLSelectElement>('.ci-status-sel');
    if (!sel) return;
    const id     = Number(sel.dataset.id);
    const status = sel.value;
    sel.dataset.status = status;
    sel.style.setProperty('--sc', STATUS_COLOR[status] ?? '#3b82f6');
    await supabase.from('colleges').update({ status }).eq('id', id).eq('family_id', familyId);
    const c = allColleges.find(c => c.id === id);
    if (c) { c.status = status; render(); }
  });

  /* ── Form submit ── */
  form.addEventListener('submit', async e => {
    e.preventDefault();
    if (!familyId) return;
    const name     = nameEl.value.trim();
    const location = locationEl.value.trim() || null;
    const type     = typeEl.value || null;
    const status   = statusFormEl.value;
    const notes    = notesEl.value.trim() || null;
    if (!name) return;
    errorEl.style.display = 'none';
    submitBtn.disabled = true;

    if (editingId !== null) {
      const { error } = await supabase.from('colleges')
        .update({ name, location, type, status, notes, updated_at: new Date().toISOString() })
        .eq('id', editingId).eq('family_id', familyId);
      if (error) { errorEl.textContent = error.message; errorEl.style.display = 'inline'; }
      else { resetForm(); await loadColleges(); }
    } else {
      const { error } = await supabase.from('colleges')
        .insert({ family_id: familyId, name, location, type, status, notes });
      if (error) { errorEl.textContent = error.message; errorEl.style.display = 'inline'; }
      else { resetForm(); await loadColleges(); }
    }
    submitBtn.disabled = false;
  });

  function resetForm() {
    editingId = null;
    nameEl.value = ''; locationEl.value = ''; typeEl.value = '';
    statusFormEl.value = 'Researching'; notesEl.value = '';
    submitBtn.textContent = 'Add College';
    submitBtn.classList.remove('ci-btn--save');
    cancelBtn.style.display = 'none';
  }
  cancelBtn.addEventListener('click', resetForm);

  /* ── Export CSV ── */
  document.getElementById('ci-export')!.addEventListener('click', () => {
    if (!allColleges.length) return;
    const cell = (v: any) => `"${(v ?? '').toString().replace(/"/g,'""')}"`;
    const lines = [
      ['Starred','Name','Location','Type','Status','Notes','Date'].map(cell).join(','),
      ...allColleges.map(c => [
        c.starred ? 'Yes' : 'No', c.name, c.location ?? '', c.type ?? '',
        c.status ?? 'Researching', c.notes ?? '',
        new Date(c.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),
      ].map(cell).join(','))
    ];
    const blob = new Blob([lines.join('\n')], { type:'text/csv' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'colleges.csv'; a.click();
    URL.revokeObjectURL(url);
  });

  /* ── Import JSON ── */
  let pendingImport: any[] = [];

  function showError(msg: string) { errorEl.textContent = msg; errorEl.style.display = 'inline'; }

  document.getElementById('ci-import-btn')!.addEventListener('click', () => {
    (document.getElementById('ci-import-file') as HTMLInputElement).click();
  });

  document.getElementById('ci-import-file')!.addEventListener('change', async e => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    (e.target as HTMLInputElement).value = '';
    let parsed: any;
    try { parsed = JSON.parse(await file.text()); } catch {
      showError('Invalid JSON file — could not parse.'); return;
    }
    if (!Array.isArray(parsed)) { showError('JSON must be an array of objects.'); return; }
    const valid = parsed.filter((c: any) => c && typeof c.name === 'string' && c.name.trim());
    if (!valid.length) { showError('No valid items found. Each item needs at least a "name" string.'); return; }
    pendingImport = valid;
    const preview = valid.slice(0, 3).map((c: any) => c.name.trim()).join(', ');
    document.getElementById('ci-import-msg')!.textContent =
      `${valid.length} college${valid.length !== 1 ? 's' : ''}: ${preview}${valid.length > 3 ? '…' : ''}`;
    document.getElementById('ci-import-preview')!.style.display = 'flex';
  });

  document.getElementById('ci-import-confirm')!.addEventListener('click', async () => {
    if (!familyId || !pendingImport.length) return;
    const btn = document.getElementById('ci-import-confirm') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Importing…';
    const VALID_TYPES    = new Set(['Ivy League','Liberal Arts','Research University','State University','Other']);
    const VALID_STATUSES = new Set(['Researching','Applying','Applied','Accepted','Waitlisted','Deferred','Rejected']);
    const rows = pendingImport.map((c: any) => ({
      family_id:   familyId,
      name:        c.name.trim(),
      location:    c.location    ? String(c.location).trim()  || null : null,
      type:        VALID_TYPES.has(c.type)      ? c.type     : null,
      status:      VALID_STATUSES.has(c.status) ? c.status   : 'Researching',
      notes:       c.notes       ? String(c.notes).trim()    || null : null,
      starred:     !!c.starred,
      shortlisted: !!c.shortlisted,
    }));
    const { error } = await supabase.from('colleges').insert(rows);
    btn.disabled = false; btn.textContent = 'Import';
    document.getElementById('ci-import-preview')!.style.display = 'none';
    pendingImport = [];
    if (error) { showError('Import failed: ' + error.message); return; }
    await loadColleges();
  });

  document.getElementById('ci-import-cancel')!.addEventListener('click', () => {
    document.getElementById('ci-import-preview')!.style.display = 'none';
    pendingImport = [];
  });

  /* ── Load ── */
  async function loadColleges() {
    if (!familyId) return;
    const { data, error } = await supabase.from('colleges').select('*')
      .eq('family_id', familyId).order('created_at', { ascending: false });
    if (error) {
      cardsEl.innerHTML = '<p class="ci-msg" style="color:var(--sl-color-red)">Failed to load.</p>';
      return;
    }
    allColleges = data ?? [];
    render();
  }

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      document.addEventListener('data-loaded', async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', s.user.id).single();
          familyId = p?.family_id ?? '';
          await loadColleges();
        }
      }, { once: true });
      return;
    }
    const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', session.user.id).single();
    familyId = p?.family_id ?? '';
    await loadColleges();
  }

  init();
</script>

<style is:global>
  #ci-wrap { max-width: 100%; }

  /* ── Form ── */
  .ci-form {
    display: flex; flex-direction: column; gap: 0.75rem;
    padding: 1.25rem; border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem; background: var(--sl-color-bg-nav); margin-bottom: 1.5rem;
  }
  .ci-form__fields {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: 0.75rem; align-items: end;
  }
  .ci-form__field  { display: flex; flex-direction: column; gap: 0.25rem; }
  .ci-label {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--sl-color-gray-2);
  }
  .ci-input, .ci-select, .ci-textarea {
    padding: 0.5rem 0.65rem; border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.375rem; background: var(--sl-color-bg);
    color: var(--sl-color-text); font-size: 0.875rem; font-family: inherit; width: 100%;
  }
  .ci-input:focus, .ci-select:focus, .ci-textarea:focus {
    outline: 2px solid var(--sl-color-accent); border-color: var(--sl-color-accent);
  }
  .ci-textarea { resize: vertical; min-height: 72px; }
  .ci-form__actions { display: flex; align-items: center; gap: 0.65rem; flex-wrap: wrap; }
  .ci-btn {
    padding: 0.45rem 1rem; border-radius: 0.375rem; font-size: 0.85rem;
    font-family: inherit; cursor: pointer; border: 1px solid transparent; white-space: nowrap;
  }
  .ci-btn--primary { background: var(--sl-color-accent); color: #fff; border-color: var(--sl-color-accent); }
  .ci-btn--primary:hover { opacity: 0.88; }
  .ci-btn--save    { background: #16a34a; border-color: #16a34a; color: #fff; }
  .ci-btn--export  { background: transparent; border-color: var(--sl-color-accent); color: var(--sl-color-accent); }
  .ci-btn--export:hover { background: var(--sl-color-accent); color: #fff; }
  .ci-btn--cancel  { background: transparent; border-color: var(--sl-color-gray-4); color: var(--sl-color-gray-2); }
  .ci-btn--cancel:hover { border-color: #ef4444; color: #ef4444; }
  .ci-btn--import  { background: transparent; border-color: var(--sl-color-gray-4); color: var(--sl-color-gray-2); }
  .ci-btn--import:hover { border-color: var(--sl-color-accent); color: var(--sl-color-accent); }
  .ci-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .ci-error { font-size: 0.82rem; color: #ef4444; }
  .ci-import-preview {
    display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    margin-top: 0.5rem; padding: 0.6rem 0.9rem;
    background: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.4rem; font-size: 0.82rem;
  }
  .ci-import-msg { color: var(--sl-color-gray-2); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ci-import-format { margin-top: 0.5rem; font-size: 0.8rem; color: var(--sl-color-gray-2); }
  .ci-import-format summary {
    cursor: pointer; user-select: none; color: var(--sl-color-gray-3); font-size: 0.75rem; padding: 0.2rem 0;
  }
  .ci-import-format summary:hover { color: var(--sl-color-accent); }
  .ci-import-pre {
    margin: 0.4rem 0 0; padding: 0.75rem 1rem;
    background: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem; font-size: 0.75rem; line-height: 1.6;
    overflow-x: auto; white-space: pre; color: var(--sl-color-text);
  }

  /* ── Toolbar ── */
  .ci-toolbar { display: flex; align-items: center; margin-bottom: 0.65rem; }
  .ci-count { font-size: 0.82rem; color: var(--sl-color-gray-2); }

  /* ── Cards ── */
  .ci-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
  }
  .ci-msg { padding: 2rem; text-align: center; color: var(--sl-color-gray-2); }

  .ci-card {
