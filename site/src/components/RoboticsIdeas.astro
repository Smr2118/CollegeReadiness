---
---

<div id="ri-wrap">

  <!-- Add / Edit form -->
  <form id="ri-form" class="ri-form">
    <div class="ri-form__fields">
      <div class="ri-form__field ri-form__field--title">
        <label class="ri-label" for="ri-title">Idea / Point</label>
        <input
          id="ri-title"
          class="ri-input"
          type="text"
          placeholder="e.g. Use a swerve drive for better maneuverability"
          required
        />
      </div>
      <div class="ri-form__field ri-form__field--cat">
        <label class="ri-label" for="ri-category">Category</label>
        <select id="ri-category" class="ri-select">
          <option value="">— Pick a category —</option>
          <option>Mechanism Design</option>
          <option>Programming</option>
          <option>Strategy</option>
          <option>Outreach</option>
          <option>Team</option>
          <option>Other</option>
        </select>
      </div>
    </div>
    <div class="ri-form__field">
      <label class="ri-label" for="ri-details">Details &amp; Notes</label>
      <textarea
        id="ri-details"
        class="ri-textarea"
        placeholder="Sketches, references, pros/cons, next steps…"
        rows="3"
      ></textarea>
    </div>
    <div class="ri-form__actions">
      <button type="submit" class="ri-btn ri-btn--primary" id="ri-submit">Add Idea</button>
      <button type="button" class="ri-btn ri-btn--export" id="ri-export">⬇ Export CSV</button>
      <button type="button" class="ri-btn ri-btn--cancel" id="ri-cancel" style="display:none">Cancel</button>
      <span id="ri-error" class="ri-error" style="display:none"></span>
    </div>
  </form>

  <!-- Filter bar -->
  <div class="ri-filter-bar" id="ri-filter-bar" style="display:none">
    <span class="ri-filter-label">Filter:</span>
    <div id="ri-filter-chips" class="ri-filter-chips">
      <button class="ri-chip ri-chip--active" data-cat="">All</button>
    </div>
  </div>

  <!-- Ideas list -->
  <div id="ri-list" class="ri-list">
    <p id="ri-loading" class="ri-empty">Loading…</p>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  let familyId  = '';
  let editingId: number | null = null;
  let allIdeas: any[] = [];
  let activeCategory = '';

  const form       = document.getElementById('ri-form')     as HTMLFormElement;
  const titleEl    = document.getElementById('ri-title')    as HTMLInputElement;
  const categoryEl = document.getElementById('ri-category') as HTMLSelectElement;
  const detailsEl  = document.getElementById('ri-details')  as HTMLTextAreaElement;
  const submitBtn  = document.getElementById('ri-submit')   as HTMLButtonElement;
  const cancelBtn  = document.getElementById('ri-cancel')   as HTMLButtonElement;
  const errorEl    = document.getElementById('ri-error')    as HTMLElement;
  const listEl     = document.getElementById('ri-list')     as HTMLElement;
  const filterBar  = document.getElementById('ri-filter-bar')    as HTMLElement;
  const filterChips = document.getElementById('ri-filter-chips') as HTMLElement;

  /* ── Category colour map ── */
  const CAT_COLOR: Record<string, string> = {
    'Mechanism Design': '#f59e0b',
    'Programming':      '#3b82f6',
    'Strategy':         '#ef4444',
    'Outreach':         '#22c55e',
    'Team':             '#8b5cf6',
    'Other':            '#94a3b8',
  };

  function catColor(cat: string | null) {
    return CAT_COLOR[cat ?? ''] ?? '#94a3b8';
  }

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  /* ── Render ── */
  function renderIdeas() {
    const filtered = activeCategory
      ? allIdeas.filter(t => t.category === activeCategory)
      : allIdeas;

    if (filtered.length === 0) {
      listEl.innerHTML = '<p class="ri-empty">No ideas yet. Add one above.</p>';
      return;
    }

    listEl.innerHTML = filtered.map(t => {
      const color = catColor(t.category);
      return `
        <div class="ri-card" data-id="${t.id}" style="--cat-color:${color}">
          <div class="ri-card__header">
            <p class="ri-card__title">${esc(t.title)}</p>
            <div class="ri-card__meta">
              ${t.category ? `<span class="ri-card__cat" style="background:${color}20;color:${color};border-color:${color}40">${esc(t.category)}</span>` : ''}
              <span class="ri-card__date">${formatDate(t.created_at)}</span>
            </div>
          </div>
          ${t.details ? `<p class="ri-card__details">${esc(t.details)}</p>` : ''}
          <div class="ri-card__footer">
            <button class="ri-action ri-action--edit" data-id="${t.id}">Edit</button>
            <button class="ri-action ri-action--delete" data-id="${t.id}">Delete</button>
          </div>
        </div>`;
    }).join('');
  }

  /* ── Render filter chips ── */
  function renderFilters() {
    const categories = [...new Set(allIdeas.map(t => t.category).filter(Boolean))].sort();
    if (categories.length === 0) { filterBar.style.display = 'none'; return; }

    filterBar.style.display = 'flex';
    filterChips.innerHTML = `<button class="ri-chip${activeCategory === '' ? ' ri-chip--active' : ''}" data-cat="">All (${allIdeas.length})</button>` +
      categories.map(c => {
        const count = allIdeas.filter(t => t.category === c).length;
        const active = activeCategory === c ? ' ri-chip--active' : '';
        return `<button class="ri-chip${active}" data-cat="${esc(c)}" style="--chip-color:${catColor(c)}">${esc(c)} (${count})</button>`;
      }).join('');
  }

  /* ── Load ── */
  async function loadIdeas() {
    if (!familyId) return;
    const { data, error } = await supabase
      .from('robotics_ideas')
      .select('*')
      .eq('family_id', familyId)
      .order('created_at', { ascending: false });

    document.getElementById('ri-loading')?.remove();

    if (error) {
      listEl.innerHTML = '<p class="ri-empty" style="color:var(--sl-color-red)">Failed to load ideas.</p>';
      return;
    }
    allIdeas = data ?? [];
    renderFilters();
    renderIdeas();
  }

  /* ── Submit ── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!familyId) return;

    const title    = titleEl.value.trim();
    const category = categoryEl.value || null;
    const details  = detailsEl.value.trim() || null;
    if (!title) return;

    errorEl.style.display = 'none';
    submitBtn.disabled = true;

    if (editingId !== null) {
      const { error } = await supabase
        .from('robotics_ideas')
        .update({ title, category, details, updated_at: new Date().toISOString() })
        .eq('id', editingId)
        .eq('family_id', familyId);
      if (error) { showError(error.message); }
      else { resetForm(); await loadIdeas(); }
    } else {
      const { error } = await supabase
        .from('robotics_ideas')
        .insert({ family_id: familyId, title, category, details });
      if (error) { showError(error.message); }
      else { resetForm(); await loadIdeas(); }
    }
    submitBtn.disabled = false;
  });

  function showError(msg: string) {
    errorEl.textContent = msg;
    errorEl.style.display = 'inline';
  }

  function resetForm() {
    editingId = null;
    titleEl.value    = '';
    categoryEl.value = '';
    detailsEl.value  = '';
    submitBtn.textContent = 'Add Idea';
    submitBtn.classList.remove('ri-btn--save');
    cancelBtn.style.display = 'none';
  }

  cancelBtn.addEventListener('click', resetForm);

  /* ── Edit / Delete ── */
  listEl.addEventListener('click', async (e) => {
    const target = e.target as HTMLElement;

    if (target.classList.contains('ri-action--delete')) {
      const id = Number(target.dataset.id);
      if (!confirm('Delete this idea?')) return;
      await supabase.from('robotics_ideas').delete().eq('id', id).eq('family_id', familyId);
      await loadIdeas();
    }

    if (target.classList.contains('ri-action--edit')) {
      const id   = Number(target.dataset.id);
      const idea = allIdeas.find(t => t.id === id);
      if (!idea) return;

      editingId = id;
      titleEl.value    = idea.title;
      categoryEl.value = idea.category ?? '';
      detailsEl.value  = idea.details  ?? '';
      submitBtn.textContent = 'Save Changes';
      submitBtn.classList.add('ri-btn--save');
      cancelBtn.style.display = 'inline-block';
      titleEl.focus();
      titleEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  /* ── Filter chips ── */
  filterChips.addEventListener('click', (e) => {
    const chip = (e.target as Element).closest<HTMLElement>('.ri-chip');
    if (!chip) return;
    activeCategory = chip.dataset.cat ?? '';
    renderFilters();
    renderIdeas();
  });

  /* ── Export CSV ── */
  document.getElementById('ri-export')!.addEventListener('click', () => {
    if (allIdeas.length === 0) return;
    const csvCell = (v: any) => `"${(v ?? '').toString().replace(/"/g, '""')}"`;
    const headers = ['Category', 'Idea / Point', 'Details', 'Date'];
    const lines = [
      headers.map(csvCell).join(','),
      ...allIdeas.map(t => [
        t.category ?? '',
        t.title,
        t.details ?? '',
        new Date(t.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }),
      ].map(csvCell).join(','))
    ];
    const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'robotics-ideas.csv'; a.click();
    URL.revokeObjectURL(url);
  });

  /* ── Init ── */
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      document.addEventListener('data-loaded', async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          const { data: profile } = await supabase
            .from('user_profiles').select('family_id').eq('user_id', s.user.id).single();
          familyId = profile?.family_id ?? '';
          await loadIdeas();
        }
      }, { once: true });
      return;
    }
    const { data: profile } = await supabase
      .from('user_profiles').select('family_id').eq('user_id', session.user.id).single();
    familyId = profile?.family_id ?? '';
    await loadIdeas();
  }

  init();
</script>

<style>
  #ri-wrap { max-width: 780px; }

  /* ── Form ── */
  .ri-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
    border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
    margin-bottom: 1.5rem;
  }

  .ri-form__fields {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.75rem;
    align-items: end;
  }

  .ri-form__field { display: flex; flex-direction: column; gap: 0.25rem; }
  .ri-form__field--cat { min-width: 200px; }

  .ri-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-2);
  }

  .ri-input, .ri-select, .ri-textarea {
    padding: 0.5rem 0.65rem;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.375rem;
    background: var(--sl-color-bg);
    color: var(--sl-color-text);
    font-size: 0.875rem;
    font-family: inherit;
    width: 100%;
  }

  .ri-input:focus, .ri-select:focus, .ri-textarea:focus {
    outline: 2px solid var(--sl-color-accent);
    border-color: var(--sl-color-accent);
  }

  .ri-textarea { resize: vertical; min-height: 72px; }

  .ri-form__actions {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
  }

  .ri-btn {
    padding: 0.45rem 1rem;
    border-radius: 0.375rem;
    font-size: 0.85rem;
    font-family: inherit;
    cursor: pointer;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .ri-btn--primary {
    background: var(--sl-color-accent);
    color: #fff;
    border-color: var(--sl-color-accent);
  }
  .ri-btn--primary:hover { opacity: 0.88; }
  .ri-btn--save {
    background: #16a34a;
    border-color: #16a34a;
  }
  .ri-btn--export {
    background: transparent;
    border-color: var(--sl-color-accent);
    color: var(--sl-color-accent);
  }
  .ri-btn--export:hover {
    background: var(--sl-color-accent);
    color: #fff;
  }
  .ri-btn--cancel {
    background: transparent;
    border-color: var(--sl-color-gray-4);
    color: var(--sl-color-gray-2);
  }
  .ri-btn--cancel:hover { border-color: #ef4444; color: #ef4444; }
  .ri-btn:disabled { opacity: 0.5; cursor: not-allowed; }

  .ri-error { font-size: 0.82rem; color: #ef4444; }

  /* ── Filter bar ── */
  .ri-filter-bar {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .ri-filter-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-3);
    flex-shrink: 0;
  }

  .ri-filter-chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }

  .ri-chip {
    padding: 0.22rem 0.65rem;
    border-radius: 9999px;
    border: 1px solid var(--sl-color-gray-4);
    background: var(--sl-color-bg);
    color: var(--sl-color-gray-2);
    font-size: 0.75rem;
    cursor: pointer;
    transition: all 0.1s;
  }

  .ri-chip--active {
    background: var(--sl-color-accent);
    border-color: var(--sl-color-accent);
    color: #fff;
  }

  .ri-chip:not(.ri-chip--active):hover {
    border-color: var(--chip-color, var(--sl-color-accent));
    color: var(--chip-color, var(--sl-color-accent));
  }

  /* ── Cards ── */
  .ri-list { display: flex; flex-direction: column; gap: 0.75rem; }

  .ri-empty { color: var(--sl-color-gray-2); font-size: 0.9rem; }

  .ri-card {
    padding: 1rem 1.1rem;
    border: 1px solid var(--sl-color-gray-5);
    border-left: 4px solid var(--cat-color, var(--sl-color-gray-4));
    border-radius: 0.5rem;
    background: var(--sl-color-bg-nav);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .ri-card__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .ri-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--sl-color-text);
    margin: 0;
    flex: 1;
    line-height: 1.4;
  }

  .ri-card__meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .ri-card__cat {
    font-size: 0.72rem;
    font-weight: 600;
    padding: 0.15rem 0.55rem;
    border-radius: 9999px;
    border: 1px solid transparent;
    white-space: nowrap;
  }

  .ri-card__date {
    font-size: 0.72rem;
    color: var(--sl-color-gray-3);
    white-space: nowrap;
  }

  .ri-card__details {
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    line-height: 1.55;
    margin: 0;
    white-space: pre-wrap;
  }

  .ri-card__footer { display: flex; gap: 0.5rem; }

  .ri-action {
    font-size: 0.75rem;
    background: none;
    border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.3rem;
    padding: 0.18rem 0.55rem;
    cursor: pointer;
    color: var(--sl-color-text);
    font-family: inherit;
  }
  .ri-action--delete { color: #ef4444; border-color: #ef4444; }
  .ri-action:hover { opacity: 0.7; }

  @media (max-width: 600px) {
    .ri-form__fields { grid-template-columns: 1fr; }
    .ri-form__field--cat { min-width: unset; }
  }
</style>
