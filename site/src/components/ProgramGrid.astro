---
// Programs are now loaded from Supabase at runtime — no build-time import
---

<p class="results-count" id="pg-count">Loading…</p>

<div class="program-grid" id="pg-grid">
  <p id="pg-loading" style="color:var(--sl-color-gray-2);padding:2rem 0">Loading programs…</p>
</div>

<p id="pg-empty" style="display:none; color:var(--sl-color-gray-2); margin-top:2rem;">
  No programs match your filters. Try broadening your search.
</p>

<script>
  import { supabase } from '../lib/supabase';

  // ── Card template ────────────────────────────────────────────────────────
  function esc(s: string | null | undefined): string {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  function makeCard(p: any): string {
    const statusLabel: Record<string,string> = {
      open:'Open', closed:'Closed', nextyear:'Apply Next Year', conflict:'Conflict'
    };
    const tierLabel: Record<number,string> = {
      1:'T1 – Elite', 2:'T2 – Highly Selective', 3:'T3 – Moderate', 4:'T4 – Accessible'
    };
    const r = Math.round(p.rating ?? 0);
    const stars = '★'.repeat(r) + '☆'.repeat(5 - r);
    const costKey = (p.cost ?? '').toLowerCase().replace('/','').replace(' ','');
    const interestKey = `pc-interest-${p.name}`;
    const noteKey     = `pc-note-${p.name}`;
    const savedNote   = localStorage.getItem(noteKey) ?? '';
    const savedInt    = localStorage.getItem(interestKey) ?? '';

    const tagsHtml = (p.tags ?? []).map((t: string) =>
      `<span class="badge badge--tag">${esc(t)}</span>`).join('');
    const noteHtml = p.note
      ? `<div class="program-card__note program-card__note--${esc(p.note_type ?? 'info')}">${esc(p.note)}</div>`
      : '';
    const applyBtn = p.url && p.url.startsWith('http')
      ? `<a class="btn-link" href="${esc(p.url)}" target="_blank" rel="noopener">Apply →</a>`
      : '';

    const iv = (v: string) => savedInt === v ? ' active' : '';
    const chipDisabled = isReadOnly ? ' disabled' : '';
    const noteReadonly = isReadOnly ? ' readonly' : '';

    return `<div class="program-card"
      data-tier="${p.tier}"
      data-category="${esc(p.category)}"
      data-status="${esc(p.status)}"
      data-cost="${esc(p.cost)}"
      data-format="${esc(p.format)}"
      data-name="${esc((p.name ?? '').toLowerCase())}"
      data-tags="${esc((p.tags ?? []).join(' ').toLowerCase())}"
      data-org="${esc((p.org ?? '').toLowerCase())}"
      data-deadline="${esc(p.deadline ?? '')}"
      data-interest="${esc(savedInt)}"
      data-interest-key="${esc(interestKey)}">

      <button class="program-card__toggle" aria-expanded="false">
        <div class="program-card__toggle-left">
          <p class="program-card__name">${esc(p.name)}</p>
          <p class="program-card__org">${esc(p.org)}</p>
        </div>
        <div class="program-card__toggle-right">
          <span class="badge badge--${esc(p.status)}">${esc(statusLabel[p.status] ?? p.status)}</span>
          <span class="program-card__chevron">›</span>
        </div>
      </button>

      <div class="program-card__interest-row">
        <span class="program-card__interest-label">Interest:</span>
        <button class="interest-chip${iv('')}"${chipDisabled} data-iv="">—</button>
        <button class="interest-chip${iv('applied')}"${chipDisabled} data-iv="applied">✅ Applied</button>
        <button class="interest-chip${iv('applying')}"${chipDisabled} data-iv="applying">🔥 Applying</button>
        <button class="interest-chip${iv('researching')}"${chipDisabled} data-iv="researching">👀 Researching</button>
        <button class="interest-chip${iv('maybe')}"${chipDisabled} data-iv="maybe">🤔 Maybe</button>
        <button class="interest-chip${iv('skip')}"${chipDisabled} data-iv="skip">❌ Skip</button>
      </div>

      <div class="program-card__body">
        <div class="program-card__meta">
          <span class="badge badge--tier${p.tier}">${esc(tierLabel[p.tier] ?? '')}</span>
          <span class="badge badge--${esc(costKey)}">${esc(p.cost)}</span>
          <span class="badge badge--format">${esc(p.format)}</span>
          <span class="badge badge--format">📅 ${esc(p.duration)}</span>
          <span class="badge badge--format">🎓 ${esc(p.grades)}</span>
        </div>
        <div style="display:flex;align-items:center;gap:0.75rem;font-size:0.78rem;color:var(--sl-color-gray-2)">
          <span class="stars">${stars}</span>
          <span>Selectivity: ${esc(p.selectivity_label)}</span>
        </div>
        <p class="program-card__desc">${esc(p.description)}</p>
        ${noteHtml}
        <div class="program-card__tags">${tagsHtml}</div>
        <div class="program-card__notes-section">
          <label class="program-card__notes-label">My Notes</label>
          <textarea class="program-card__user-note"
            data-key="${esc(noteKey)}"
            placeholder="Add your personal notes, reminders, or application status…"
            rows="2"${noteReadonly}>${esc(savedNote)}</textarea>
        </div>
        <div class="program-card__footer">
          <div class="program-card__deadline">⏰ ${esc(p.deadline)}</div>
          ${applyBtn}
        </div>
      </div>
    </div>`;
  }

  // ── Readonly mode ────────────────────────────────────────────────────────
  let isReadOnly = document.body.dataset.readonly === 'true';

  document.addEventListener('app-readonly-state', (e: Event) => {
    isReadOnly = (e as CustomEvent).detail?.isReadOnly === true;
    if (isReadOnly) {
      document.querySelectorAll<HTMLButtonElement>('.interest-chip').forEach(btn => {
        btn.disabled = true;
      });
      document.querySelectorAll<HTMLTextAreaElement>('.program-card__user-note').forEach(ta => {
        ta.readOnly = true;
      });
    }
  });

  // ── Program data store (populated after Supabase load) ──────────────────
  let allPrograms: any[] = [];

  // ── State ────────────────────────────────────────────────────────────────
  const active: Record<string, Set<string>> = {
    status:   new Set(['open']),
    tier:     new Set(['all']),
    cost:     new Set(['all']),
    format:   new Set(['all']),
    category: new Set(['all']),
    interest: new Set(['all']),
  };
  let query   = '';
  let sortBy  = 'default';
  let originalOrder: Element[] = [];

  // ── Filter / Sort ────────────────────────────────────────────────────────
  function parseDeadline(text: string | null | undefined): number {
    if (!text) return Infinity;
    const m = text.match(/([A-Z][a-z]+ \d{1,2},?\s*\d{4})/);
    if (m) { const d = new Date(m[1]); if (!isNaN(d.getTime())) return d.getTime(); }
    return Infinity;
  }

  const interestOrder: Record<string,number> = { applied:0, applying:1, researching:2, maybe:3, '':4, skip:5 };

  function sortCards() {
    const grid = document.getElementById('pg-grid')!;
    const cards = Array.from(grid.querySelectorAll('.program-card'));
    if (sortBy === 'default') { originalOrder.forEach(c => grid.appendChild(c)); return; }
    if (sortBy === 'deadline') {
      cards.sort((a,b) => parseDeadline((a as HTMLElement).dataset.deadline) - parseDeadline((b as HTMLElement).dataset.deadline));
    } else if (sortBy === 'interest') {
      cards.sort((a,b) => {
        const ia = interestOrder[(a as HTMLElement).dataset.interest ?? ''] ?? 3;
        const ib = interestOrder[(b as HTMLElement).dataset.interest ?? ''] ?? 3;
        return ia - ib;
      });
    }
    cards.forEach(c => grid.appendChild(c));
  }

  function applyFilters() {
    const grid     = document.getElementById('pg-grid')!;
    const countEl  = document.getElementById('pg-count')!;
    const emptyEl  = document.getElementById('pg-empty')!;
    let visible = 0;
    grid.querySelectorAll<HTMLElement>('.program-card').forEach(el => {
      const matches =
        (active.status.has('all')   || active.status.has(el.dataset.status   ?? '')) &&
        (active.tier.has('all')     || active.tier.has(el.dataset.tier       ?? '')) &&
        (active.cost.has('all')     || active.cost.has(el.dataset.cost       ?? '')) &&
        (active.format.has('all')   || active.format.has(el.dataset.format   ?? '')) &&
        (active.category.has('all') || active.category.has(el.dataset.category ?? '')) &&
        (active.interest.has('all') || active.interest.has(el.dataset.interest ?? '')) &&
        (query === '' ||
          (el.dataset.name  ?? '').includes(query) ||
          (el.dataset.org   ?? '').includes(query) ||
          (el.dataset.tags  ?? '').includes(query));
      el.style.display = matches ? '' : 'none';
      if (matches) visible++;
    });
    countEl.textContent = `${visible} program${visible !== 1 ? 's' : ''}`;
    emptyEl.style.display = visible === 0 ? '' : 'none';
  }

  function refresh() { sortCards(); applyFilters(); }

  // ── Load from Supabase ───────────────────────────────────────────────────
  async function init() {
    const { data, error } = await supabase
      .from('programs')
      .select('*')
      .order('sort_order', { ascending: true });

    const grid    = document.getElementById('pg-grid')!;
    const loadMsg = document.getElementById('pg-loading');
    loadMsg?.remove();

    if (error || !data) {
      grid.innerHTML = '<p style="color:var(--sl-color-red)">Failed to load programs. Please refresh.</p>';
      return;
    }

    allPrograms    = data;
    grid.innerHTML = data.map(makeCard).join('');
    originalOrder  = Array.from(grid.querySelectorAll('.program-card'));

    document.getElementById('pg-count')!.textContent = `${data.length} programs`;
    refresh();
    document.dispatchEvent(new Event('data-loaded'));
  }

  // ── Event delegation ─────────────────────────────────────────────────────

  // Toggle expand / collapse
  document.addEventListener('click', e => {
    const btn = (e.target as Element).closest<HTMLButtonElement>('.program-card__toggle');
    if (!btn) return;
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    btn.closest('.program-card')?.classList.toggle('is-expanded', !expanded);
  });

  // Interest chips
  document.addEventListener('click', e => {
    const chip = (e.target as Element).closest<HTMLElement>('.interest-chip');
    if (!chip) return;
    if (isReadOnly) return;
    const row  = chip.closest('.program-card__interest-row');
    if (!row) return;
    const card = chip.closest<HTMLElement>('.program-card');
    if (!card) return;
    const val         = chip.dataset.iv ?? '';
    const interestKey = card.dataset.interestKey!;
    card.dataset.interest = val;
    localStorage.setItem(interestKey, val);
    row.querySelectorAll<HTMLElement>('.interest-chip').forEach(b => {
      b.classList.toggle('active', b.dataset.iv === val);
    });
    document.dispatchEvent(new CustomEvent('interest-changed', {
      detail: { programName: interestKey.replace('pc-interest-', ''), interest: val }
    }));
  });

  // localStorage notes
  document.addEventListener('input', e => {
    const ta = e.target as HTMLTextAreaElement;
    if (!ta.classList.contains('program-card__user-note')) return;
    if (isReadOnly) return;
    if (ta.dataset.key) localStorage.setItem(ta.dataset.key, ta.value);
  });

  // Filter chips (multi-select; "All" clears others)
  document.addEventListener('click', e => {
    const chip = (e.target as Element).closest<HTMLElement>('.filter-chip[data-filter]');
    if (!chip) return;
    const filter = chip.dataset.filter!;
    const value  = chip.dataset.value!;
    const current = active[filter];

    if (value === 'all') {
      current.clear();
      current.add('all');
    } else {
      current.delete('all');
      if (current.has(value)) {
        current.delete(value);
        if (current.size === 0) current.add('all');
      } else {
        current.add(value);
      }
    }

    document.querySelectorAll<HTMLElement>(`.filter-chip[data-filter="${filter}"]`).forEach(c => {
      c.classList.toggle('active', current.has(c.dataset.value ?? ''));
    });
    applyFilters();
  });

  // Sort dropdown
  document.addEventListener('change', e => {
    const sel = e.target as HTMLSelectElement;
    if (sel.id !== 'pg-sort') return;
    sortBy = sel.value;
    refresh();
  });

  // Search (debounced)
  let debounceTimer: ReturnType<typeof setTimeout>;
  document.addEventListener('input', e => {
    const el = e.target as HTMLInputElement;
    if (el.id !== 'pg-search') return;
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
      query = el.value.toLowerCase().trim();
      applyFilters();
    }, 200);
  });

  // Re-filter when Supabase user data loads (interest sync, etc.)
  document.addEventListener('interest-changed', applyFilters);
  document.addEventListener('data-loaded', refresh);

  // ── CSV Export ───────────────────────────────────────────────────────────
  function csvCell(val: any): string {
    const s = (val ?? '').toString().replace(/"/g, '""');
    return `"${s}"`;
  }

  document.addEventListener('click', e => {
    if ((e.target as Element).id !== 'pg-export') return;

    const grid = document.getElementById('pg-grid')!;
    const visibleNames = new Set(
      Array.from(grid.querySelectorAll<HTMLElement>('.program-card'))
        .filter(el => el.style.display !== 'none')
        .map(el => el.dataset.name ?? '')
    );

    const tierLabel: Record<number, string> = {
      1: 'T1 – Elite', 2: 'T2 – Highly Selective', 3: 'T3 – Moderate', 4: 'T4 – Accessible'
    };

    const rows = allPrograms.filter(p =>
      visibleNames.has((p.name ?? '').toLowerCase())
    );

    const headers = ['Name', 'Org', 'Status', 'Tier', 'Cost', 'Format', 'Duration',
                     'Grades', 'Deadline', 'Category', 'Tags', 'My Interest', 'URL', 'Description'];

    const lines = [
      headers.map(csvCell).join(','),
      ...rows.map(p => {
        const interest = localStorage.getItem(`pc-interest-${p.name}`) ?? '';
        return [
          p.name, p.org, p.status, tierLabel[p.tier] ?? p.tier,
          p.cost, p.format, p.duration, p.grades, p.deadline,
          p.category, (p.tags ?? []).join('; '), interest, p.url, p.description
        ].map(csvCell).join(',');
      })
    ];

    const blob = new Blob([lines.join('\n')], { type: 'text/csv' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href     = url;
    a.download = 'summer-programs.csv';
    a.click();
    URL.revokeObjectURL(url);
  });

  init();
</script>
