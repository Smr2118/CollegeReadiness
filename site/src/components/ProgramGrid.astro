---
import ProgramCard from './ProgramCard.astro';
import programData from '../data/programs.json';

const { programs, meta } = programData as any;
---

<!-- Filter Toolbar -->
<div class="filter-toolbar">
  <div class="filter-toolbar__top">
    <div class="filter-toolbar__row" style="flex:1">
      <span class="filter-toolbar__label">Search</span>
      <input
        class="filter-search"
        type="text"
        id="pg-search"
        placeholder="Search by name, org, or tag…"
        autocomplete="off"
      />
    </div>
    <button class="filter-toggle" id="pg-filter-toggle" aria-expanded="false">
      Filters <span class="filter-toggle__arrow">▼</span>
    </button>
  </div>

  <!-- Status always visible -->
  <div class="filter-toolbar__row">
    <span class="filter-toolbar__label">Status</span>
    <button class="filter-chip" data-filter="status" data-value="all">All</button>
    <button class="filter-chip active" data-filter="status" data-value="open">Open</button>
    <button class="filter-chip" data-filter="status" data-value="closed">Closed</button>
    <button class="filter-chip" data-filter="status" data-value="nextyear">Apply Next Year</button>
    <button class="filter-chip" data-filter="status" data-value="conflict">Conflict</button>
  </div>

  <div class="filter-toolbar__collapsible" id="pg-filter-collapsible">

  <div class="filter-toolbar__row">
    <span class="filter-toolbar__label">Tier</span>
    <button class="filter-chip active" data-filter="tier" data-value="all">All</button>
    <button class="filter-chip" data-filter="tier" data-value="1">T1 Elite</button>
    <button class="filter-chip" data-filter="tier" data-value="2">T2 Highly Selective</button>
    <button class="filter-chip" data-filter="tier" data-value="3">T3 Moderate</button>
    <button class="filter-chip" data-filter="tier" data-value="4">T4 Accessible</button>
  </div>

  <div class="filter-toolbar__row">
    <span class="filter-toolbar__label">Cost</span>
    <button class="filter-chip active" data-filter="cost" data-value="all">All</button>
    <button class="filter-chip" data-filter="cost" data-value="Free">Free</button>
    <button class="filter-chip" data-filter="cost" data-value="Stipend">Stipend</button>
    <button class="filter-chip" data-filter="cost" data-value="Paid">Paid (tuition)</button>
  </div>

  <div class="filter-toolbar__row">
    <span class="filter-toolbar__label">Format</span>
    <button class="filter-chip active" data-filter="format" data-value="all">All</button>
    {meta.formats.map((f: string) => (
      <button class="filter-chip" data-filter="format" data-value={f}>{f}</button>
    ))}
  </div>

  <div class="filter-toolbar__row">
    <span class="filter-toolbar__label">Category</span>
    <button class="filter-chip active" data-filter="category" data-value="all">All</button>
    {meta.categories.map((c: string) => (
      <button class="filter-chip" data-filter="category" data-value={c}>{c}</button>
    ))}
  </div>
  </div><!-- end collapsible -->
</div>

<p class="results-count" id="pg-count">{programs.length} programs</p>

<!-- Program Grid -->
<div class="program-grid" id="pg-grid">
  {programs.map((p: any) => <ProgramCard program={p} />)}
</div>

<p id="pg-empty" style="display:none; color:var(--sl-color-gray-2); margin-top:2rem;">
  No programs match your filters. Try broadening your search.
</p>

<script is:inline>
  (function () {
    const grid = document.getElementById('pg-grid');
    const countEl = document.getElementById('pg-count');
    const emptyEl = document.getElementById('pg-empty');
    const searchEl = document.getElementById('pg-search');
    if (!grid || !countEl || !emptyEl || !searchEl) return;

    const cards = Array.from(grid.querySelectorAll('.program-card'));

    // Active filter state — default status to 'open'
    const active = {
      status: 'open',
      tier: 'all',
      cost: 'all',
      format: 'all',
      category: 'all',
    };
    let query = '';

    // Apply on load
    applyFilters();

    function applyFilters() {
      let visible = 0;
      cards.forEach(card => {
        const el = card;
        const matches =
          (active.status === 'all' || el.dataset.status === active.status) &&
          (active.tier === 'all' || el.dataset.tier === active.tier) &&
          (active.cost === 'all' || el.dataset.cost === active.cost) &&
          (active.format === 'all' || el.dataset.format === active.format) &&
          (active.category === 'all' || el.dataset.category === active.category) &&
          (query === '' ||
            el.dataset.name.includes(query) ||
            el.dataset.org.includes(query) ||
            el.dataset.tags.includes(query));

        el.style.display = matches ? '' : 'none';
        if (matches) visible++;
      });

      countEl.textContent = `${visible} program${visible !== 1 ? 's' : ''}`;
      emptyEl.style.display = visible === 0 ? '' : 'none';
    }

    // Chip click handlers
    document.querySelectorAll('.filter-chip[data-filter]').forEach(chip => {
      chip.addEventListener('click', () => {
        const filter = chip.dataset.filter;
        const value = chip.dataset.value;
        active[filter] = value;

        // Update active class within this filter group
        document.querySelectorAll(`.filter-chip[data-filter="${filter}"]`).forEach(c => {
          c.classList.toggle('active', c.dataset.value === value);
        });

        applyFilters();
      });
    });

    // Search handler (debounced)
    let debounceTimer;
    searchEl.addEventListener('input', () => {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(() => {
        query = searchEl.value.toLowerCase().trim();
        applyFilters();
      }, 200);
    });

    // Collapsible filter toggle
    const toggleBtn = document.getElementById('pg-filter-toggle');
    const collapsible = document.getElementById('pg-filter-collapsible');
    if (toggleBtn && collapsible) {
      toggleBtn.addEventListener('click', () => {
        const expanded = toggleBtn.getAttribute('aria-expanded') === 'true';
        toggleBtn.setAttribute('aria-expanded', String(!expanded));
        collapsible.classList.toggle('is-open', !expanded);
        const arrow = toggleBtn.querySelector('.filter-toggle__arrow');
        if (arrow) arrow.textContent = !expanded ? '▲' : '▼';
      });
    }
  })();
</script>
