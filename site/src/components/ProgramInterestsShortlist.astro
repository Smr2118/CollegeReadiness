---
---

<div id="pisl-wrap">
  <p class="pisl-hint">Programs pinned 📌 in <strong>Brainstorm → Programs of Interest</strong> appear here.</p>
  <div class="pisl-toolbar">
    <span id="pisl-count" class="pisl-count"></span>
  </div>
  <div class="pisl-table-wrap">
    <table class="pisl-table">
      <thead>
        <tr>
          <th class="pisl-th pisl-th--name">Program</th>
          <th class="pisl-th pisl-th--interest">Interest</th>
          <th class="pisl-th pisl-th--airisk">AI Risk</th>
          <th class="pisl-th pisl-th--prospects">Job Prospects</th>
          <th class="pisl-th pisl-th--difficulty">Admission</th>
          <th class="pisl-th pisl-th--years">Years</th>
          <th class="pisl-th pisl-th--date">Added</th>
          <th class="pisl-th pisl-th--actions"></th>
        </tr>
      </thead>
      <tbody id="pisl-tbody">
        <tr><td colspan="8" class="pisl-td-msg">Loading…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  let familyId = '';
  let items: any[] = [];

  const tbody   = document.getElementById('pisl-tbody')! as HTMLElement;
  const countEl = document.getElementById('pisl-count')! as HTMLElement;

  const INTEREST_COLOR: Record<string,string> = {
    'Very High': '#7c3aed', 'High': '#3b82f6', 'Medium': '#f59e0b', 'Low': '#94a3b8',
  };
  const AI_RISK_COLOR: Record<string,string> = {
    'High': '#ef4444', 'Medium': '#f97316', 'Low': '#22c55e', 'Minimal': '#94a3b8',
  };
  const PROSPECTS_COLOR: Record<string,string> = {
    'Excellent': '#22c55e', 'Good': '#3b82f6', 'Fair': '#f59e0b', 'Limited': '#ef4444',
  };
  const DIFFICULTY_COLOR: Record<string,string> = {
    'Very Hard': '#ef4444', 'Hard': '#f97316', 'Moderate': '#3b82f6', 'Accessible': '#22c55e',
  };

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
  }
  function badge(label: string, color: string) {
    return `<span class="pisl-badge" style="background:${color}18;color:${color};border-color:${color}40">${esc(label)}</span>`;
  }

  function render() {
    const sorted = [...items].sort((a, b) => {
      const order = ['Very High','High','Medium','Low'];
      const ai = order.indexOf(a.interest_level ?? '');
      const bi = order.indexOf(b.interest_level ?? '');
      if (ai !== bi) return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi);
      return a.name.localeCompare(b.name);
    });

    countEl.textContent = `${sorted.length} program${sorted.length !== 1 ? 's' : ''}`;

    if (sorted.length === 0) {
      tbody.innerHTML = '<tr><td colspan="8" class="pisl-td-msg">No programs shortlisted yet — pin 📌 programs in Brainstorm → Programs of Interest.</td></tr>';
      return;
    }

    tbody.innerHTML = sorted.map(p => {
      const ic  = INTEREST_COLOR[p.interest_level]        ?? '#94a3b8';
      const arc = AI_RISK_COLOR[p.ai_risk]                ?? '#94a3b8';
      const pc  = PROSPECTS_COLOR[p.job_prospects]        ?? '#94a3b8';
      const dc  = DIFFICULTY_COLOR[p.admission_difficulty] ?? '#94a3b8';
      const colleges: string[] = p.best_colleges ?? [];
      const collegeTags = colleges.slice(0, 3).map(c =>
        `<span class="pisl-college-tag">${esc(c)}</span>`
      ).join('') + (colleges.length > 3 ? `<span class="pisl-college-more">+${colleges.length - 3}</span>` : '');

      return `
        <tr class="pisl-row" data-id="${p.id}">
          <td class="pisl-td pisl-td--name">
            <span class="pisl-name">${esc(p.name)}</span>
            ${colleges.length ? `<div class="pisl-colleges">${collegeTags}</div>` : ''}
            ${p.admission_tips ? `<span class="pisl-tips">${esc(p.admission_tips)}</span>` : ''}
          </td>
          <td class="pisl-td">
            ${p.interest_level ? badge(p.interest_level, ic) : '<span class="pisl-none">—</span>'}
          </td>
          <td class="pisl-td">
            ${p.ai_risk ? badge(p.ai_risk, arc) : '<span class="pisl-none">—</span>'}
          </td>
          <td class="pisl-td">
            ${p.job_prospects ? badge(p.job_prospects, pc) : '<span class="pisl-none">—</span>'}
          </td>
          <td class="pisl-td">
            ${p.admission_difficulty ? badge(p.admission_difficulty, dc) : '<span class="pisl-none">—</span>'}
          </td>
          <td class="pisl-td pisl-td--years">
            ${p.years_of_study ? `<span class="pisl-years">${esc(p.years_of_study)} yr${p.years_of_study === '1' ? '' : 's'}</span>` : '<span class="pisl-none">—</span>'}
          </td>
          <td class="pisl-td pisl-td--date">${formatDate(p.created_at)}</td>
          <td class="pisl-td pisl-td--actions">
            <button class="pisl-remove" data-id="${p.id}">📌 Remove</button>
          </td>
        </tr>`;
    }).join('');
  }

  tbody.addEventListener('click', async e => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('.pisl-remove');
    if (!btn) return;
    const id = Number(btn.dataset.id);
    await supabase.from('program_interests').update({ shortlisted: false }).eq('id', id).eq('family_id', familyId);
    items = items.filter(p => p.id !== id);
    render();
  });

  async function load() {
    const { data, error } = await supabase.from('program_interests')
      .select('*').eq('family_id', familyId).eq('shortlisted', true)
      .order('created_at', { ascending: false });
    if (error) {
      tbody.innerHTML = '<tr><td colspan="8" class="pisl-td-msg" style="color:var(--sl-color-red)">Failed to load.</td></tr>';
      return;
    }
    items = data ?? [];
    render();
  }

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      document.addEventListener('data-loaded', async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', s.user.id).single();
          familyId = p?.family_id ?? '';
          await load();
        }
      }, { once: true });
      return;
    }
    const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', session.user.id).single();
    familyId = p?.family_id ?? '';
    await load();
  }

  init();
</script>

<style>
  #pisl-wrap { max-width: 100%; }

  .pisl-hint {
    font-size: 0.85rem; color: var(--sl-color-gray-2);
    margin-bottom: 1rem; padding: 0.65rem 0.9rem;
    background: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.4rem;
  }
  .pisl-toolbar { margin-bottom: 0.65rem; }
  .pisl-count { font-size: 0.82rem; color: var(--sl-color-gray-2); }

  .pisl-table-wrap { overflow-x: auto; }
  .pisl-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .pisl-th {
    padding: 0.45rem 0.75rem; text-align: left; font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--sl-color-gray-2);
    border-bottom: 2px solid var(--sl-color-gray-5); white-space: nowrap;
  }
  .pisl-th--interest   { width: 80px; }
  .pisl-th--airisk     { width: 80px; }
  .pisl-th--prospects  { width: 90px; }
  .pisl-th--difficulty { width: 90px; }
  .pisl-th--years      { width: 60px; }
  .pisl-th--date       { width: 88px; }
  .pisl-th--actions    { width: 100px; }

  .pisl-td {
    padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--sl-color-gray-6);
    vertical-align: middle;
  }
  .pisl-td--name { vertical-align: top; padding-top: 0.65rem; }
  .pisl-td--date { white-space: nowrap; color: var(--sl-color-gray-3); font-size: 0.8rem; }
  .pisl-td--years { text-align: center; }
  .pisl-td-msg   { padding: 2rem; text-align: center; color: var(--sl-color-gray-2); }

  .pisl-row:hover { background: var(--sl-color-gray-7, rgba(0,0,0,0.02)); }

  .pisl-name {
    display: block; font-weight: 700; color: var(--sl-color-text);
    line-height: 1.3; font-size: 0.9rem;
  }
  .pisl-colleges {
    display: flex; flex-wrap: wrap; gap: 0.25rem; margin-top: 0.3rem;
  }
  .pisl-college-tag {
    font-size: 0.66rem; padding: 0.08rem 0.4rem; border-radius: 9999px;
    background: var(--sl-color-gray-6); color: var(--sl-color-gray-1);
    border: 1px solid var(--sl-color-gray-5); font-weight: 500; white-space: nowrap;
  }
  .pisl-college-more {
    font-size: 0.66rem; color: var(--sl-color-gray-3); align-self: center;
  }
  .pisl-tips {
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; font-size: 0.75rem; color: var(--sl-color-gray-2);
    margin-top: 0.25rem; line-height: 1.4;
  }
  .pisl-years { font-size: 0.78rem; font-weight: 600; color: var(--sl-color-gray-2); }
  .pisl-none  { color: var(--sl-color-gray-4); }

  .pisl-badge {
    display: inline-block;
    font-size: 0.68rem; font-weight: 600; padding: 0.12rem 0.45rem;
    border-radius: 9999px; border: 1px solid transparent; white-space: nowrap;
  }

  .pisl-remove {
    font-size: 0.72rem; background: none; border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.25rem; padding: 0.15rem 0.55rem;
    cursor: pointer; color: var(--sl-color-gray-2); font-family: inherit;
    white-space: nowrap;
  }
  .pisl-remove:hover { border-color: #ef4444; color: #ef4444; }
</style>
