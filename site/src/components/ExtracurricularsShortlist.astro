---
---

<div id="ecsl-wrap">
  <p class="ecsl-hint">Items pinned 📌 in <strong>Ideas Board</strong> appear here.</p>
  <div class="ecsl-toolbar">
    <span id="ecsl-count" class="ecsl-count"></span>
  </div>
  <div class="ecsl-table-wrap">
    <table class="ecsl-table">
      <thead>
        <tr>
          <th class="ecsl-th ecsl-th--title">Idea</th>
          <th class="ecsl-th ecsl-th--priority">Priority</th>
          <th class="ecsl-th ecsl-th--tags">Tags</th>
          <th class="ecsl-th ecsl-th--status">Status</th>
          <th class="ecsl-th ecsl-th--date">Date</th>
          <th class="ecsl-th ecsl-th--actions"></th>
        </tr>
      </thead>
      <tbody id="ecsl-tbody">
        <tr><td colspan="6" class="ecsl-td-msg">Loading…</td></tr>
      </tbody>
    </table>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  let familyId = '';
  let items: any[] = [];

  const tbody   = document.getElementById('ecsl-tbody')! as HTMLElement;
  const countEl = document.getElementById('ecsl-count')! as HTMLElement;

  const PRIORITY_META: Record<string,{dot:string; label:string; color:string}> = {
    high:   { dot:'🔴', label:'High',   color:'#ef4444' },
    medium: { dot:'🟡', label:'Medium', color:'#f59e0b' },
    low:    { dot:'🟢', label:'Low',    color:'#22c55e' },
  };
  const STATUS_COLOR: Record<string, string> = {
    'Open': '#3b82f6', 'Interested': '#f59e0b', 'Cancelled': '#94a3b8', 'Complete': '#22c55e',
  };

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
  }

  function render() {
    countEl.textContent = `${items.length} item${items.length !== 1 ? 's' : ''}`;
    if (items.length === 0) {
      tbody.innerHTML = '<tr><td colspan="6" class="ecsl-td-msg">No items shortlisted yet — pin 📌 items in Ideas Board to add them here.</td></tr>';
      return;
    }
    tbody.innerHTML = items.map(i => {
      const pm  = PRIORITY_META[i.priority] ?? PRIORITY_META.medium;
      const sc  = STATUS_COLOR[i.status ?? 'Open'] ?? '#3b82f6';
      const tags = (i.tags ?? []).map((t: string) => `<span class="ecsl-tag">${esc(t)}</span>`).join('');
      return `
        <tr class="ecsl-row${i.status === 'Cancelled' ? ' ecsl-row--cancelled' : ''}${i.status === 'Complete' ? ' ecsl-row--complete' : ''}">
          <td class="ecsl-td ecsl-td--title">
            <span class="ecsl-title">${esc(i.title)}</span>
            ${i.notes ? `<span class="ecsl-sub">${esc(i.notes)}</span>` : ''}
          </td>
          <td class="ecsl-td ecsl-td--priority">
            <span class="ecsl-priority ecsl-priority--${i.priority ?? 'medium'}">${pm.dot} ${pm.label}</span>
          </td>
          <td class="ecsl-td ecsl-td--tags">
            <div class="ecsl-tags-wrap">${tags || '<span class="ecsl-none">—</span>'}</div>
          </td>
          <td class="ecsl-td ecsl-td--status">
            <span style="color:${sc};font-weight:600;font-size:0.8rem">${esc(i.status ?? 'Open')}</span>
          </td>
          <td class="ecsl-td ecsl-td--date">${formatDate(i.created_at)}</td>
          <td class="ecsl-td ecsl-td--actions">
            <button class="ecsl-remove" data-id="${i.id}">📌 Remove</button>
          </td>
        </tr>`;
    }).join('');
  }

  tbody.addEventListener('click', async e => {
    const btn = (e.target as HTMLElement).closest<HTMLElement>('.ecsl-remove');
    if (!btn) return;
    const id = Number(btn.dataset.id);
    await supabase.from('ideas').update({ shortlisted: false }).eq('id', id).eq('family_id', familyId);
    items = items.filter(i => i.id !== id);
    render();
  });

  async function load() {
    const { data, error } = await supabase.from('ideas')
      .select('*').eq('family_id', familyId).eq('shortlisted', true)
      .order('created_at', { ascending: false });
    if (error) {
      tbody.innerHTML = '<tr><td colspan="6" class="ecsl-td-msg" style="color:var(--sl-color-red)">Failed to load.</td></tr>';
      return;
    }
    items = data ?? [];
    render();
  }

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      document.addEventListener('data-loaded', async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', s.user.id).single();
          familyId = p?.family_id ?? '';
          await load();
        }
      }, { once: true });
      return;
    }
    const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', session.user.id).single();
    familyId = p?.family_id ?? '';
    await load();
  }

  init();
</script>

<style>
  #ecsl-wrap { max-width: 100%; }

  .ecsl-hint {
    font-size: 0.85rem; color: var(--sl-color-gray-2);
    margin-bottom: 1rem; padding: 0.65rem 0.9rem;
    background: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.4rem;
  }
  .ecsl-toolbar { margin-bottom: 0.65rem; }
  .ecsl-count { font-size: 0.82rem; color: var(--sl-color-gray-2); }

  .ecsl-table-wrap { overflow-x: auto; }
  .ecsl-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .ecsl-th {
    padding: 0.45rem 0.75rem; text-align: left; font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--sl-color-gray-2);
    border-bottom: 2px solid var(--sl-color-gray-5); white-space: nowrap;
  }
  .ecsl-th--priority { width: 90px; }
  .ecsl-th--tags     { width: 140px; }
  .ecsl-th--status   { width: 100px; }
  .ecsl-th--date     { width: 88px; }
  .ecsl-th--actions  { width: 110px; }

  .ecsl-td { padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--sl-color-gray-6); vertical-align: middle; }
  .ecsl-td--title { vertical-align: top; padding-top: 0.65rem; }
  .ecsl-td--tags  { vertical-align: top; padding-top: 0.65rem; }
  .ecsl-td--date  { white-space: nowrap; color: var(--sl-color-gray-3); font-size: 0.8rem; }
  .ecsl-td-msg    { padding: 2rem; text-align: center; color: var(--sl-color-gray-2); }

  .ecsl-row:hover { background: var(--sl-color-gray-7, rgba(0,0,0,0.02)); }
  .ecsl-row--cancelled .ecsl-title { opacity: 0.5; text-decoration: line-through; }
  .ecsl-row--complete  .ecsl-title { opacity: 0.7; }

  .ecsl-title { display: block; font-weight: 600; color: var(--sl-color-text); line-height: 1.4; }
  .ecsl-sub {
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; font-size: 0.78rem; color: var(--sl-color-gray-2);
    margin-top: 0.1rem; line-height: 1.4;
  }
  .ecsl-none { color: var(--sl-color-gray-4); }

  .ecsl-priority {
    font-size: 0.72rem; font-weight: 600; white-space: nowrap;
    padding: 0.15rem 0.5rem; border-radius: 9999px;
  }
  .ecsl-priority--high   { background: #fee2e2; color: #991b1b; }
  .ecsl-priority--medium { background: #fef3c7; color: #92400e; }
  .ecsl-priority--low    { background: #dcfce7; color: #166534; }

  .ecsl-tags-wrap { display: flex; flex-wrap: wrap; gap: 0.25rem; }
  .ecsl-tag {
    font-size: 0.7rem; padding: 0.1rem 0.45rem; border-radius: 9999px;
    background: var(--sl-color-gray-6); color: var(--sl-color-gray-1); font-weight: 500;
  }

  .ecsl-remove {
    font-size: 0.72rem; background: none; border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.25rem; padding: 0.15rem 0.55rem;
    cursor: pointer; color: var(--sl-color-gray-2); font-family: inherit;
  }
  .ecsl-remove:hover { border-color: #ef4444; color: #ef4444; }
</style>
