---
---

<!-- Login Modal -->
<div id="sb-modal" class="sb-modal" style="display:none">
  <div class="sb-modal__box">
    <h2 class="sb-modal__title">College Readiness Hub</h2>
    <p class="sb-modal__subtitle">Sign in to access the College Readiness Hub.</p>
    <form id="sb-login-form" class="sb-form">
      <input class="sb-input" type="email" id="sb-email" placeholder="Email" required autocomplete="email" />
      <input class="sb-input" type="password" id="sb-password" placeholder="Password" required autocomplete="current-password" />
      <button class="sb-btn" type="submit" id="sb-submit">Sign In</button>
      <p id="sb-error" class="sb-error" style="display:none"></p>
    </form>
  </div>
</div>

<!-- Family + sign-out indicator (bottom-right) -->
<div id="sb-user-bar" class="sb-user-bar" style="display:none">
  <span id="sb-family-badge" class="sb-family-badge"></span>
  <button id="sb-signout" class="sb-signout-btn" title="Sign out">Sign Out</button>
</div>

<script>
  import { supabase } from '../lib/supabase';

  const modal     = document.getElementById('sb-modal')!;
  const form      = document.getElementById('sb-login-form')!;
  const errorEl   = document.getElementById('sb-error')!;
  const submitBtn = document.getElementById('sb-submit') as HTMLButtonElement;
  const userBar   = document.getElementById('sb-user-bar')!;
  const familyBadge = document.getElementById('sb-family-badge')!;
  const signoutBtn  = document.getElementById('sb-signout') as HTMLButtonElement;

  // Move both elements to <body> so position:fixed is relative to the viewport,
  // not to the right-sidebar's fixed containing block.
  document.body.appendChild(modal);
  document.body.appendChild(userBar);

  // Resolved after sign-in
  let familyId    = '';
  let displayName = '';

  /* ── Auth helpers ── */
  function showModal() {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    userBar.style.display = 'none';
  }

  function hideModal(name: string, fid: string) {
    modal.style.display = 'none';
    document.body.style.overflow = '';
    familyBadge.textContent = name ? `👤 ${name}` : '';
    userBar.style.display = 'flex';
  }

  /* ── Load all saved data for this family from Supabase ── */
  async function loadData() {
    if (!familyId) return;
    const { data, error } = await supabase
      .from('program_data')
      .select('*')
      .eq('family_id', familyId);
    if (error || !data) return;

    data.forEach((row: any) => {
      // Populate note textarea
      const ta = document.querySelector<HTMLTextAreaElement>(
        `[data-key="pc-note-${row.program_name}"]`
      );
      if (ta && row.note) {
        ta.value = row.note;
        localStorage.setItem(`pc-note-${row.program_name}`, row.note);
      }

      // Populate interest
      const card = document.querySelector<HTMLElement>(
        `[data-interest-key="pc-interest-${row.program_name}"]`
      );
      if (card && row.interest !== undefined) {
        card.dataset.interest = row.interest;
        localStorage.setItem(`pc-interest-${row.program_name}`, row.interest);
        card.querySelectorAll<HTMLButtonElement>('.interest-chip').forEach(btn => {
          btn.classList.toggle('active', btn.dataset.iv === row.interest);
        });
      }
    });

    document.dispatchEvent(new CustomEvent('data-loaded'));
  }

  /* ── Upsert a single field for a program ── */
  async function upsert(programName: string, field: 'note' | 'interest', value: string) {
    if (!familyId) return;   // not signed in — skip sync
    await supabase.from('program_data').upsert(
      {
        program_name: programName,
        family_id: familyId,
        [field]: value,
        updated_at: new Date().toISOString(),
      },
      { onConflict: 'family_id,program_name' }
    );
  }

  /* ── Init ── */
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) { showModal(); return; }

    // user_profiles is the authoritative source; metadata is the fallback
    const { data: profile } = await supabase
      .from('user_profiles')
      .select('family_id, display_name, role')
      .eq('user_id', session.user.id)
      .single();

    familyId    = profile?.family_id    ?? session.user.user_metadata?.family_id    ?? '';
    displayName = profile?.display_name ?? session.user.user_metadata?.display_name ?? session.user.email ?? '';
    const role  = profile?.role ?? session.user.user_metadata?.role ?? 'member';

    // Show admin nav link only for admins
    if (role === 'admin') {
      document.querySelectorAll<HTMLElement>('li:has(a[href$="/admin/"])').forEach(el => {
        el.style.display = '';
      });
    }

    hideModal(displayName, familyId);
    await loadData();
  }

  /* ── Login form ── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.style.display = 'none';
    submitBtn.textContent = 'Signing in…';
    submitBtn.disabled = true;

    const email    = (document.getElementById('sb-email') as HTMLInputElement).value;
    const password = (document.getElementById('sb-password') as HTMLInputElement).value;

    const { data, error } = await supabase.auth.signInWithPassword({ email, password });

    submitBtn.textContent = 'Sign In';
    submitBtn.disabled = false;

    if (error) {
      errorEl.textContent = error.message;
      errorEl.style.display = 'block';
    } else {
      familyId    = data.session?.user.user_metadata?.family_id    ?? '';
      displayName = data.session?.user.user_metadata?.display_name ?? data.session?.user.email ?? '';
      hideModal(displayName, familyId);
      await loadData();
    }
  });

  /* ── Sign out ── */
  signoutBtn.addEventListener('click', async () => {
    await supabase.auth.signOut();
    familyId    = '';
    displayName = '';
    showModal();
  });

  /* ── Sync note changes to Supabase (debounced 1s) ── */
  const noteTimers: Record<string, ReturnType<typeof setTimeout>> = {};
  document.addEventListener('input', (e) => {
    const ta = (e.target as HTMLElement).closest<HTMLTextAreaElement>('.program-card__user-note');
    if (!ta?.dataset.key) return;
    const programName = ta.dataset.key.replace('pc-note-', '');
    clearTimeout(noteTimers[programName]);
    noteTimers[programName] = setTimeout(() => {
      upsert(programName, 'note', ta.value);
    }, 1000);
  });

  /* ── Sync interest changes to Supabase ── */
  document.addEventListener('interest-changed', (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail?.programName !== undefined) {
      upsert(detail.programName, 'interest', detail.interest);
    }
  });

  init();
</script>
