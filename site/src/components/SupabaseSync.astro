---
---

<!-- Login Modal -->
<div id="sb-modal" class="sb-modal" style="display:none">
  <div class="sb-modal__box">
    <h2 class="sb-modal__title">College Readiness Hub</h2>
    <p class="sb-modal__subtitle">Family Access — Sign in to continue</p>
    <form id="sb-login-form" class="sb-form">
      <input class="sb-input" type="email" id="sb-email" placeholder="Email" required autocomplete="email" />
      <input class="sb-input" type="password" id="sb-password" placeholder="Password" required autocomplete="current-password" />
      <button class="sb-btn" type="submit" id="sb-submit">Sign In</button>
      <p id="sb-error" class="sb-error" style="display:none"></p>
    </form>
  </div>
</div>

<!-- Sign out button (top-right of page) -->
<button id="sb-signout" class="sb-signout" style="display:none" title="Sign out">Sign Out</button>

<script>
  import { supabase } from '../lib/supabase';

  const modal    = document.getElementById('sb-modal')!;
  const form     = document.getElementById('sb-login-form')!;
  const errorEl  = document.getElementById('sb-error')!;
  const submitBtn = document.getElementById('sb-submit') as HTMLButtonElement;
  const signoutBtn = document.getElementById('sb-signout') as HTMLButtonElement;

  /* ── Auth helpers ── */
  function showModal() {
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    signoutBtn.style.display = 'none';
  }

  function hideModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
    signoutBtn.style.display = 'block';
  }

  /* ── Load all saved data from Supabase and apply to cards ── */
  async function loadData() {
    const { data, error } = await supabase.from('program_data').select('*');
    if (error || !data) return;

    data.forEach((row: any) => {
      // Populate note textarea
      const ta = document.querySelector<HTMLTextAreaElement>(
        `[data-key="pc-note-${row.program_name}"]`
      );
      if (ta && row.note) {
        ta.value = row.note;
        localStorage.setItem(`pc-note-${row.program_name}`, row.note);
      }

      // Populate interest
      const card = document.querySelector<HTMLElement>(
        `[data-interest-key="pc-interest-${row.program_name}"]`
      );
      if (card && row.interest !== undefined) {
        card.dataset.interest = row.interest;
        localStorage.setItem(`pc-interest-${row.program_name}`, row.interest);
        card.querySelectorAll<HTMLButtonElement>('.interest-chip').forEach(btn => {
          btn.classList.toggle('active', btn.dataset.iv === row.interest);
        });
      }
    });

    // Trigger filter/sort refresh
    document.dispatchEvent(new CustomEvent('data-loaded'));
  }

  /* ── Upsert a single field for a program ── */
  async function upsert(programName: string, field: 'note' | 'interest', value: string) {
    await supabase.from('program_data').upsert(
      { program_name: programName, [field]: value, updated_at: new Date().toISOString() },
      { onConflict: 'program_name' }
    );
  }

  /* ── Init ── */
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (session) {
      hideModal();
      await loadData();
    } else {
      showModal();
    }
  }

  /* ── Login form ── */
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    errorEl.style.display = 'none';
    submitBtn.textContent = 'Signing in…';
    submitBtn.disabled = true;

    const email    = (document.getElementById('sb-email') as HTMLInputElement).value;
    const password = (document.getElementById('sb-password') as HTMLInputElement).value;

    const { error } = await supabase.auth.signInWithPassword({ email, password });

    submitBtn.textContent = 'Sign In';
    submitBtn.disabled = false;

    if (error) {
      errorEl.textContent = error.message;
      errorEl.style.display = 'block';
    } else {
      hideModal();
      await loadData();
    }
  });

  /* ── Sign out ── */
  signoutBtn.addEventListener('click', async () => {
    await supabase.auth.signOut();
    showModal();
  });

  /* ── Sync note changes to Supabase (debounced 1s) ── */
  const noteTimers: Record<string, ReturnType<typeof setTimeout>> = {};
  document.addEventListener('input', (e) => {
    const ta = (e.target as HTMLElement).closest<HTMLTextAreaElement>('.program-card__user-note');
    if (!ta?.dataset.key) return;
    const programName = ta.dataset.key.replace('pc-note-', '');
    clearTimeout(noteTimers[programName]);
    noteTimers[programName] = setTimeout(() => {
      upsert(programName, 'note', ta.value);
    }, 1000);
  });

  /* ── Sync interest changes to Supabase ── */
  document.addEventListener('interest-changed', (e: Event) => {
    const detail = (e as CustomEvent).detail;
    if (detail?.programName !== undefined) {
      upsert(detail.programName, 'interest', detail.interest);
    }
  });

  init();
</script>
