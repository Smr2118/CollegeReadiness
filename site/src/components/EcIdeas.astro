---
---

<div id="ec-wrap">

  <!-- Add / Edit form -->
  <form id="ec-form" class="ec-form">
    <div class="ec-form__fields">
      <div class="ec-form__field ec-form__field--title">
        <label class="ec-label" for="ec-title">Activity / Idea</label>
        <input id="ec-title" class="ec-input" type="text"
          placeholder="e.g. Start a coding club at school" required />
      </div>
      <div class="ec-form__field">
        <label class="ec-label" for="ec-category">Category</label>
        <select id="ec-category" class="ec-select">
          <option value="">— Pick a category —</option>
          <option>Sports</option>
          <option>Arts</option>
          <option>Community Service</option>
          <option>Leadership</option>
          <option>Academic</option>
          <option>STEM</option>
          <option>Cultural</option>
          <option>Other</option>
        </select>
      </div>
      <div class="ec-form__field">
        <label class="ec-label" for="ec-status-form">Status</label>
        <select id="ec-status-form" class="ec-select">
          <option value="Open">Open</option>
          <option value="Interested">Interested</option>
          <option value="Pursuing">Pursuing</option>
          <option value="Complete">Complete</option>
          <option value="Cancelled">Cancelled</option>
        </select>
      </div>
    </div>
    <div class="ec-form__field">
      <label class="ec-label" for="ec-details">Details &amp; Notes</label>
      <textarea id="ec-details" class="ec-textarea"
        placeholder="Why this activity, next steps, relevant experience…" rows="3"></textarea>
    </div>
    <div class="ec-form__actions">
      <button type="submit" class="ec-btn ec-btn--primary" id="ec-submit">Add Idea</button>
      <button type="button" class="ec-btn ec-btn--export" id="ec-export">⬇ Export CSV</button>
      <button type="button" class="ec-btn ec-btn--import" id="ec-import-btn">⬆ Import JSON</button>
      <input type="file" id="ec-import-file" accept=".json" style="display:none" />
      <button type="button" class="ec-btn ec-btn--cancel" id="ec-cancel" style="display:none">Cancel</button>
      <span id="ec-error" class="ec-error" style="display:none"></span>
    </div>
    <div id="ec-import-preview" class="ec-import-preview" style="display:none">
      <span id="ec-import-msg" class="ec-import-msg"></span>
      <button type="button" class="ec-btn ec-btn--primary" id="ec-import-confirm">Import</button>
      <button type="button" class="ec-btn ec-btn--cancel" id="ec-import-cancel">Cancel</button>
    </div>
    <details class="ec-import-format">
      <summary>JSON format reference</summary>
      <pre class="ec-import-pre" is:raw>[
  {
    "title": "Start a coding club at school",  // required
    "category": "STEM",       // Sports | Arts | Community Service | Leadership | Academic | STEM | Cultural | Other
    "details": "Teach Python basics to classmates, mentor younger students",
    "status": "Open",         // Open | Interested | Pursuing | Complete | Cancelled
    "starred": false,
    "shortlisted": false
  }
]</pre>
    </details>
  </form>

  <!-- Cards area -->
  <div class="ec-toolbar">
    <span id="ec-count" class="ec-count"></span>
  </div>
  <div id="ec-cards" class="ec-cards">
    <p class="ec-msg">Loading…</p>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  let familyId   = '';
  let editingId: number | null = null;
  let allIdeas: any[] = [];
  let filterStatus  = 'all';
  let filterCat     = 'all';
  let filterStarred = false;
  let sortMode      = 'newest';

  const form         = document.getElementById('ec-form')        as HTMLFormElement;
  const titleEl      = document.getElementById('ec-title')       as HTMLInputElement;
  const categoryEl   = document.getElementById('ec-category')    as HTMLSelectElement;
  const statusFormEl = document.getElementById('ec-status-form') as HTMLSelectElement;
  const detailsEl    = document.getElementById('ec-details')     as HTMLTextAreaElement;
  const submitBtn    = document.getElementById('ec-submit')      as HTMLButtonElement;
  const cancelBtn    = document.getElementById('ec-cancel')      as HTMLButtonElement;
  const errorEl      = document.getElementById('ec-error')       as HTMLElement;
  const cardsEl      = document.getElementById('ec-cards')       as HTMLElement;
  const countEl      = document.getElementById('ec-count')       as HTMLElement;

  const CAT_COLOR: Record<string,string> = {
    'Sports':            '#ef4444',
    'Arts':              '#ec4899',
    'Community Service': '#22c55e',
    'Leadership':        '#f59e0b',
    'Academic':          '#3b82f6',
    'STEM':              '#8b5cf6',
    'Cultural':          '#f97316',
    'Other':             '#94a3b8',
  };

  const STATUS_COLOR: Record<string,string> = {
    'Open':      '#3b82f6',
    'Interested':'#f59e0b',
    'Pursuing':  '#8b5cf6',
    'Complete':  '#22c55e',
    'Cancelled': '#94a3b8',
  };

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
  }

  function visibleIdeas() {
    let list = allIdeas.filter(i => {
      if (filterStatus !== 'all' && i.status !== filterStatus) return false;
      if (filterCat    !== 'all' && i.category !== filterCat)  return false;
      if (filterStarred && !i.starred) return false;
      return true;
    });
    const statusOrder = ['Open','Interested','Pursuing','Complete','Cancelled'];
    list.sort((a, b) => {
      if (sortMode === 'newest') return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
      if (sortMode === 'oldest') return new Date(a.created_at).getTime() - new Date(b.created_at).getTime();
      if (sortMode === 'az')     return a.title.localeCompare(b.title);
      if (sortMode === 'za')     return b.title.localeCompare(a.title);
      if (sortMode === 'status') return statusOrder.indexOf(a.status ?? 'Open') - statusOrder.indexOf(b.status ?? 'Open');
      return 0;
    });
    return list;
  }

  function renderCards() {
    const ideas = visibleIdeas();
    countEl.textContent = `${ideas.length} idea${ideas.length !== 1 ? 's' : ''}`;

    if (ideas.length === 0) {
      cardsEl.innerHTML = '<p class="ec-msg">No ideas match. Try adjusting filters.</p>';
      return;
    }

    const cancelled = (i: any) => i.status === 'Cancelled';
    const complete  = (i: any) => i.status === 'Complete';

    cardsEl.innerHTML = ideas.map(i => {
      const catColor = CAT_COLOR[i.category] ?? '#94a3b8';
      const sc       = STATUS_COLOR[i.status ?? 'Open'] ?? '#3b82f6';
      return `
        <div class="ec-card${cancelled(i) ? ' ec-card--cancelled' : ''}${complete(i) ? ' ec-card--complete' : ''}" style="--cc:${catColor}" data-id="${i.id}">
          <div class="ec-card__top">
            <div class="ec-card__badges">
              ${i.category
                ? `<span class="ec-cat-badge" style="background:${catColor}20;color:${catColor};border-color:${catColor}40">${esc(i.category)}</span>`
                : ''}
              <select class="ec-status-sel" data-id="${i.id}" style="--sc:${sc}">
                <option value="Open"       ${(i.status ?? 'Open') === 'Open'       ? 'selected' : ''}>Open</option>
                <option value="Interested" ${i.status === 'Interested' ? 'selected' : ''}>Interested</option>
                <option value="Pursuing"   ${i.status === 'Pursuing'   ? 'selected' : ''}>Pursuing</option>
                <option value="Complete"   ${i.status === 'Complete'   ? 'selected' : ''}>Complete</option>
                <option value="Cancelled"  ${i.status === 'Cancelled'  ? 'selected' : ''}>Cancelled</option>
              </select>
            </div>
            <div class="ec-card__icons">
              <button class="ec-star${i.starred ? ' ec-star--on' : ''}" data-id="${i.id}" data-starred="${!!i.starred}" title="Star">${i.starred ? '★' : '☆'}</button>
              <button class="ec-pin${i.shortlisted ? ' ec-pin--on' : ''}" data-id="${i.id}" data-shortlisted="${!!i.shortlisted}" title="Toggle shortlist">📌</button>
            </div>
          </div>
          <div class="ec-card__title-row${i.details ? ' ec-card__title-row--toggle' : ''}" data-action="toggle">
            <p class="ec-card__title">${esc(i.title)}</p>
            ${i.details ? `<span class="ec-card__chevron">▶</span>` : ''}
          </div>
          ${i.details ? `<p class="ec-card__details">${esc(i.details)}</p>` : ''}
          <div class="ec-card__footer">
            <span class="ec-card__date">${formatDate(i.created_at)}</span>
            <div class="ec-card__actions">
              <button class="ec-act ec-act--edit" data-id="${i.id}">Edit</button>
              <button class="ec-act ec-act--delete" data-id="${i.id}">Delete</button>
            </div>
          </div>
        </div>`;
    }).join('');
  }

  document.addEventListener('click', e => {
    const chip = (e.target as Element).closest<HTMLElement>('.filter-chip[data-filter]');
    if (!chip) return;
    const filter = chip.dataset.filter!;
    const value  = chip.dataset.value!;
    if (filter === 'status') filterStatus = value;
    if (filter === 'cat')    filterCat    = value;
    document.querySelectorAll<HTMLElement>(`.filter-chip[data-filter="${filter}"]`).forEach(c =>
      c.classList.toggle('active', c.dataset.value === value));
    renderCards();
  });

  document.addEventListener('change', e => {
    const target = e.target as HTMLElement;
    if (target.id === 'bs-sort')    { sortMode = (target as HTMLSelectElement).value; renderCards(); }
    if (target.id === 'bs-starred') { filterStarred = (target as HTMLInputElement).checked; renderCards(); }
  });

  cardsEl.addEventListener('change', async e => {
    const sel = (e.target as HTMLElement).closest<HTMLSelectElement>('.ec-status-sel');
    if (!sel) return;
    const id     = Number(sel.dataset.id);
    const status = sel.value;
    sel.style.setProperty('--sc', STATUS_COLOR[status] ?? '#3b82f6');
    await supabase.from('ec_ideas').update({ status }).eq('id', id).eq('family_id', familyId);
    const i = allIdeas.find(i => i.id === id);
    if (i) { i.status = status; renderCards(); }
  });

  cardsEl.addEventListener('click', async e => {
    const target = e.target as HTMLElement;

    const toggleRow = target.closest('.ec-card__title-row--toggle');
    if (toggleRow) {
      toggleRow.closest('.ec-card')?.classList.toggle('ec-card--open');
      return;
    }

    const starBtn = target.closest<HTMLElement>('.ec-star');
    if (starBtn) {
      const id      = Number(starBtn.dataset.id);
      const starred = starBtn.dataset.starred !== 'true';
      await supabase.from('ec_ideas').update({ starred }).eq('id', id).eq('family_id', familyId);
      const i = allIdeas.find(i => i.id === id);
      if (i) { i.starred = starred; renderCards(); }
      return;
    }

    const pinBtn = target.closest<HTMLElement>('.ec-pin');
    if (pinBtn) {
      const id          = Number(pinBtn.dataset.id);
      const shortlisted = pinBtn.dataset.shortlisted !== 'true';
      await supabase.from('ec_ideas').update({ shortlisted }).eq('id', id).eq('family_id', familyId);
      const i = allIdeas.find(i => i.id === id);
      if (i) { i.shortlisted = shortlisted; renderCards(); }
      return;
    }

    if (target.classList.contains('ec-act--delete')) {
      const id = Number(target.dataset.id);
      if (!confirm('Delete this idea?')) return;
      await supabase.from('ec_ideas').delete().eq('id', id).eq('family_id', familyId);
      allIdeas = allIdeas.filter(i => i.id !== id);
      renderCards();
      return;
    }

    if (target.classList.contains('ec-act--edit')) {
      const id   = Number(target.dataset.id);
      const idea = allIdeas.find(i => i.id === id);
      if (!idea) return;
      editingId            = id;
      titleEl.value        = idea.title;
      categoryEl.value     = idea.category ?? '';
      statusFormEl.value   = idea.status   ?? 'Open';
      detailsEl.value      = idea.details  ?? '';
      submitBtn.textContent = 'Save Changes';
      submitBtn.classList.add('ec-btn--save');
      cancelBtn.style.display = 'inline-block';
      titleEl.focus();
      titleEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
  });

  form.addEventListener('submit', async e => {
    e.preventDefault();
    if (!familyId) return;
    const title    = titleEl.value.trim();
    const category = categoryEl.value || null;
    const status   = statusFormEl.value;
    const details  = detailsEl.value.trim() || null;
    if (!title) return;
    errorEl.style.display = 'none';
    submitBtn.disabled = true;

    if (editingId !== null) {
      const { error } = await supabase.from('ec_ideas')
        .update({ title, category, status, details, updated_at: new Date().toISOString() })
        .eq('id', editingId).eq('family_id', familyId);
      if (error) { errorEl.textContent = error.message; errorEl.style.display = 'inline'; }
      else { resetForm(); await loadIdeas(); }
    } else {
      const { error } = await supabase.from('ec_ideas')
        .insert({ family_id: familyId, title, category, status, details });
      if (error) { errorEl.textContent = error.message; errorEl.style.display = 'inline'; }
      else { resetForm(); await loadIdeas(); }
    }
    submitBtn.disabled = false;
  });

  function resetForm() {
    editingId = null;
    titleEl.value = ''; categoryEl.value = ''; statusFormEl.value = 'Open'; detailsEl.value = '';
    submitBtn.textContent = 'Add Idea';
    submitBtn.classList.remove('ec-btn--save');
    cancelBtn.style.display = 'none';
  }
  cancelBtn.addEventListener('click', resetForm);

  document.getElementById('ec-export')!.addEventListener('click', () => {
    if (!allIdeas.length) return;
    const cell = (v: any) => `"${(v ?? '').toString().replace(/"/g,'""')}"`;
    const lines = [
      ['Starred','Category','Activity / Idea','Details','Status','Date'].map(cell).join(','),
      ...allIdeas.map(i => [
        i.starred ? 'Yes' : 'No', i.category ?? '', i.title, i.details ?? '',
        i.status ?? 'Open',
        new Date(i.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),
      ].map(cell).join(','))
    ];
    const blob = new Blob([lines.join('\n')], { type:'text/csv' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'ec-ideas.csv'; a.click();
    URL.revokeObjectURL(url);
  });

  let pendingImport: any[] = [];

  function showEcError(msg: string) { errorEl.textContent = msg; errorEl.style.display = 'inline'; }

  document.getElementById('ec-import-btn')!.addEventListener('click', () => {
    (document.getElementById('ec-import-file') as HTMLInputElement).click();
  });

  document.getElementById('ec-import-file')!.addEventListener('change', async e => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (!file) return;
    (e.target as HTMLInputElement).value = '';
    let parsed: any;
    try { parsed = JSON.parse(await file.text()); } catch {
      showEcError('Invalid JSON file — could not parse.'); return;
    }
    if (!Array.isArray(parsed)) { showEcError('JSON must be an array of objects.'); return; }
    const valid = parsed.filter((i: any) => i && typeof i.title === 'string' && i.title.trim());
    if (!valid.length) { showEcError('No valid items found. Each item needs at least a "title" string.'); return; }
    pendingImport = valid;
    const preview = valid.slice(0, 3).map((i: any) => i.title.trim()).join(', ');
    document.getElementById('ec-import-msg')!.textContent =
      `${valid.length} item${valid.length !== 1 ? 's' : ''}: ${preview}${valid.length > 3 ? '…' : ''}`;
    document.getElementById('ec-import-preview')!.style.display = 'flex';
  });

  document.getElementById('ec-import-confirm')!.addEventListener('click', async () => {
    if (!familyId || !pendingImport.length) return;
    const btn = document.getElementById('ec-import-confirm') as HTMLButtonElement;
    btn.disabled = true; btn.textContent = 'Importing…';
    const VALID_CATS = new Set(['Sports','Arts','Community Service','Leadership','Academic','STEM','Cultural','Other']);
    const VALID_STATUSES = new Set(['Open','Interested','Pursuing','Complete','Cancelled']);
    const rows = pendingImport.map((i: any) => ({
      family_id:   familyId,
      title:       i.title.trim(),
      category:    VALID_CATS.has(i.category)     ? i.category : null,
      details:     i.details ? String(i.details).trim() || null : null,
      status:      VALID_STATUSES.has(i.status)   ? i.status   : 'Open',
      starred:     !!i.starred,
      shortlisted: !!i.shortlisted,
    }));
    const { error } = await supabase.from('ec_ideas').insert(rows);
    btn.disabled = false; btn.textContent = 'Import';
    document.getElementById('ec-import-preview')!.style.display = 'none';
    pendingImport = [];
    if (error) { showEcError('Import failed: ' + error.message); return; }
    await loadIdeas();
  });

  document.getElementById('ec-import-cancel')!.addEventListener('click', () => {
    document.getElementById('ec-import-preview')!.style.display = 'none';
    pendingImport = [];
  });

  async function loadIdeas() {
    if (!familyId) return;
    const { data, error } = await supabase.from('ec_ideas').select('*')
      .eq('family_id', familyId).order('created_at', { ascending: false });
    if (error) {
      cardsEl.innerHTML = '<p class="ec-msg" style="color:var(--sl-color-red)">Failed to load.</p>';
      return;
    }
    allIdeas = data ?? [];
    renderCards();
  }

  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      document.addEventListener('data-loaded', async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', s.user.id).single();
          familyId = p?.family_id ?? '';
          await loadIdeas();
        }
      }, { once: true });
      return;
    }
    const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', session.user.id).single();
    familyId = p?.family_id ?? '';
    await loadIdeas();
  }

  init();
</script>

<style is:global>
  #ec-wrap { max-width: 100%; }

  .ec-form {
    display: flex; flex-direction: column; gap: 0.75rem;
    padding: 1.25rem; border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.5rem; background: var(--sl-color-bg-nav); margin-bottom: 1.5rem;
  }
  .ec-form__fields { display: grid; grid-template-columns: 2fr 1fr 1fr; gap: 0.75rem; align-items: end; }
  .ec-form__field  { display: flex; flex-direction: column; gap: 0.25rem; }
  .ec-label {
    font-size: 0.7rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--sl-color-gray-2);
  }
  .ec-input, .ec-select, .ec-textarea {
    padding: 0.5rem 0.65rem; border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.375rem; background: var(--sl-color-bg);
    color: var(--sl-color-text); font-size: 0.875rem; font-family: inherit; width: 100%;
  }
  .ec-input:focus, .ec-select:focus, .ec-textarea:focus {
    outline: 2px solid var(--sl-color-accent); border-color: var(--sl-color-accent);
  }
  .ec-textarea { resize: vertical; min-height: 72px; }
  .ec-form__actions { display: flex; align-items: center; gap: 0.65rem; flex-wrap: wrap; }
  .ec-btn {
    padding: 0.45rem 1rem; border-radius: 0.375rem; font-size: 0.85rem;
    font-family: inherit; cursor: pointer; border: 1px solid transparent; white-space: nowrap;
  }
  .ec-btn--primary { background: var(--sl-color-accent); color: #fff; border-color: var(--sl-color-accent); }
  .ec-btn--primary:hover { opacity: 0.88; }
  .ec-btn--save { background: #16a34a; border-color: #16a34a; color: #fff; }
  .ec-btn--export { background: transparent; border-color: var(--sl-color-accent); color: var(--sl-color-accent); }
  .ec-btn--export:hover { background: var(--sl-color-accent); color: #fff; }
  .ec-btn--cancel { background: transparent; border-color: var(--sl-color-gray-4); color: var(--sl-color-gray-2); }
  .ec-btn--cancel:hover { border-color: #ef4444; color: #ef4444; }
  .ec-btn--import { background: transparent; border-color: var(--sl-color-gray-4); color: var(--sl-color-gray-2); }
  .ec-btn--import:hover { border-color: var(--sl-color-accent); color: var(--sl-color-accent); }
  .ec-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .ec-error { font-size: 0.82rem; color: #ef4444; }
  .ec-import-preview {
    display: flex; align-items: center; gap: 0.6rem; flex-wrap: wrap;
    margin-top: 0.5rem; padding: 0.6rem 0.9rem;
    background: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.4rem; font-size: 0.82rem;
  }
  .ec-import-msg { color: var(--sl-color-gray-2); flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .ec-import-format { margin-top: 0.5rem; font-size: 0.8rem; color: var(--sl-color-gray-2); }
  .ec-import-format summary {
    cursor: pointer; user-select: none; color: var(--sl-color-gray-3);
    font-size: 0.75rem; padding: 0.2rem 0;
  }
  .ec-import-format summary:hover { color: var(--sl-color-accent); }
  .ec-import-pre {
    margin: 0.4rem 0 0; padding: 0.75rem 1rem;
    background: var(--sl-color-bg-nav); border: 1px solid var(--sl-color-gray-5);
    border-radius: 0.375rem; font-size: 0.75rem; line-height: 1.6;
    overflow-x: auto; white-space: pre; color: var(--sl-color-text);
  }

  .ec-toolbar { display: flex; align-items: center; margin-bottom: 0.65rem; }
  .ec-count { font-size: 0.82rem; color: var(--sl-color-gray-2); }

  /* Card grid */
  .ec-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1rem; }
  .ec-msg   { color: var(--sl-color-gray-2); font-size: 0.9rem; padding: 2rem 0; text-align: center; }

  .ec-card {
    border: 1px solid var(--sl-color-gray-5); border-radius: 0.5rem;
    background: var(--sl-color-bg-nav); padding: 0.9rem 1rem;
    display: flex; flex-direction: column; gap: 0.5rem;
    border-left: 4px solid var(--cc, #94a3b8);
    transition: box-shadow 0.15s;
  }
  .ec-card:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
  .ec-card--cancelled .ec-card__title { opacity: 0.5; text-decoration: line-through; }
  .ec-card--complete  .ec-card__title { opacity: 0.7; }

  .ec-card__top { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem; }
  .ec-card__badges { display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap; flex: 1; min-width: 0; }
  .ec-card__icons  { display: flex; gap: 0.15rem; flex-shrink: 0; }

  .ec-cat-badge {
    font-size: 0.68rem; font-weight: 600; padding: 0.12rem 0.45rem;
    border-radius: 9999px; border: 1px solid transparent; white-space: nowrap;
  }

  .ec-status-sel {
    padding: 0.18rem 0.4rem; border-radius: 0.3rem;
