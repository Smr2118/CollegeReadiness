---
import MobileTableOfContents from 'virtual:starlight/components/MobileTableOfContents';
import TableOfContents from 'virtual:starlight/components/TableOfContents';
import programData from '../data/programs.json';

const isProgramsPage = Astro.url.pathname.includes('/programs');
const { toc } = Astro.locals.starlightRoute;
const { meta } = programData as any;
---

<!-- Left sidebar toggle -->
<button id="sidebar-toggle" class="sidebar-toggle" title="Collapse/expand navigation" aria-label="Toggle sidebar">
  <span class="sidebar-toggle__icon">‹</span>
</button>

<!-- Right sidebar (TOC) toggle -->
<button id="toc-toggle" class="toc-toggle" title="Collapse/expand outline" aria-label="Toggle outline">
  <span class="toc-toggle__icon">›</span>
</button>

<script is:inline>
  (function () {
    // ── Left sidebar ──
    const leftBtn = document.getElementById('sidebar-toggle');
    if (leftBtn) {
      const LEFT_KEY = 'sidebar-collapsed';
      if (localStorage.getItem(LEFT_KEY) === 'true') {
        document.documentElement.classList.add('sidebar-collapsed');
      }
      leftBtn.addEventListener('click', () => {
        const collapsed = document.documentElement.classList.toggle('sidebar-collapsed');
        localStorage.setItem(LEFT_KEY, String(collapsed));
      });
    }

    // ── Right sidebar (TOC or filter panel) ──
    const tocBtn = document.getElementById('toc-toggle');
    if (tocBtn) {
      // Move to <body> so it stays visible when .right-sidebar is display:none
      document.body.appendChild(tocBtn);

      const isProgramsPage = window.location.pathname.includes('/programs');

      if (isProgramsPage) {
        // Programs page: use separate key/class so TOC collapse on other pages
        // never hides the filter panel.
        const FILTER_KEY = 'filter-collapsed';
        if (localStorage.getItem(FILTER_KEY) === 'true') {
          document.documentElement.classList.add('filter-collapsed');
        }
        tocBtn.addEventListener('click', () => {
          const collapsed = document.documentElement.classList.toggle('filter-collapsed');
          localStorage.setItem(FILTER_KEY, String(collapsed));
        });
      } else {
        const TOC_KEY = 'toc-collapsed';
        if (localStorage.getItem(TOC_KEY) === 'true') {
          document.documentElement.classList.add('toc-collapsed');
        }
        tocBtn.addEventListener('click', () => {
          const collapsed = document.documentElement.classList.toggle('toc-collapsed');
          localStorage.setItem(TOC_KEY, String(collapsed));
        });
      }
    }
  })();
</script>

{isProgramsPage ? (
  <div class="right-sidebar-panel sl-hidden lg:sl-block">
    <div class="sl-container">
      <div class="filter-panel">

        <div class="filter-panel__section">
          <span class="filter-panel__label">Search</span>
          <input
            class="filter-search"
            type="text"
            id="pg-search"
            placeholder="Search…"
            autocomplete="off"
          />
        </div>

        <div class="filter-panel__section">
          <span class="filter-panel__label">Sort By</span>
          <select id="pg-sort" class="sort-select">
            <option value="default">Default</option>
            <option value="deadline">⏰ Deadline (earliest first)</option>
            <option value="interest">⭐ Interest (applying first)</option>
          </select>
        </div>

        <div class="filter-panel__section">
          <span class="filter-panel__label">Status</span>
          <div class="filter-panel__chips">
            <button class="filter-chip" data-filter="status" data-value="all">All</button>
            <button class="filter-chip active" data-filter="status" data-value="open">Open</button>
            <button class="filter-chip" data-filter="status" data-value="closed">Closed</button>
            <button class="filter-chip" data-filter="status" data-value="nextyear">Next Year</button>
            <button class="filter-chip" data-filter="status" data-value="conflict">Conflict</button>
          </div>
        </div>

        <div class="filter-panel__section">
          <span class="filter-panel__label">Tier</span>
          <div class="filter-panel__chips">
            <button class="filter-chip active" data-filter="tier" data-value="all">All</button>
            <button class="filter-chip" data-filter="tier" data-value="1">T1 Elite</button>
            <button class="filter-chip" data-filter="tier" data-value="2">T2 Selective</button>
            <button class="filter-chip" data-filter="tier" data-value="3">T3 Moderate</button>
            <button class="filter-chip" data-filter="tier" data-value="4">T4 Accessible</button>
          </div>
        </div>

        <div class="filter-panel__section">
          <span class="filter-panel__label">Cost</span>
          <div class="filter-panel__chips">
            <button class="filter-chip active" data-filter="cost" data-value="all">All</button>
            <button class="filter-chip" data-filter="cost" data-value="Free">Free</button>
            <button class="filter-chip" data-filter="cost" data-value="Stipend">Stipend</button>
            <button class="filter-chip" data-filter="cost" data-value="Paid">Paid</button>
          </div>
        </div>

        <div class="filter-panel__section">
          <span class="filter-panel__label">Format</span>
          <div class="filter-panel__chips">
            <button class="filter-chip active" data-filter="format" data-value="all">All</button>
            {meta.formats.map((f: string) => (
              <button class="filter-chip" data-filter="format" data-value={f}>{f}</button>
            ))}
          </div>
        </div>

        <div class="filter-panel__section">
          <span class="filter-panel__label">Category</span>
          <div class="filter-panel__chips">
            <button class="filter-chip active" data-filter="category" data-value="all">All</button>
            {meta.categories.map((c: string) => (
              <button class="filter-chip" data-filter="category" data-value={c}>{c}</button>
            ))}
          </div>
        </div>

        <div class="filter-panel__section">
          <span class="filter-panel__label">My Interest</span>
          <div class="filter-panel__chips">
            <button class="filter-chip active" data-filter="interest" data-value="all">All</button>
            <button class="filter-chip" data-filter="interest" data-value="applying">🔥 Applying</button>
            <button class="filter-chip" data-filter="interest" data-value="researching">👀 Researching</button>
            <button class="filter-chip" data-filter="interest" data-value="maybe">🤔 Maybe</button>
            <button class="filter-chip" data-filter="interest" data-value="skip">❌ Skip</button>
          </div>
        </div>

        <div class="filter-panel__section">
          <button id="pg-export" class="export-btn">⬇ Export CSV</button>
        </div>

      </div>
    </div>
  </div>
) : (
  toc && (
    <>
      <div class="lg:sl-hidden">
        <MobileTableOfContents />
      </div>
      <div class="right-sidebar-panel sl-hidden lg:sl-block">
        <div class="sl-container">
          <TableOfContents />
        </div>
      </div>
    </>
  )
)}

<style>
  .right-sidebar-panel {
    padding: 1rem var(--sl-sidebar-pad-x);
  }
  .sl-container {
    /* Use the Starlight default (18.75rem) directly so this doesn't shrink
       when --sl-sidebar-width is zeroed out for the left sidebar collapse. */
    width: calc(18.75rem - 2 * var(--sl-sidebar-pad-x));
  }
</style>
