---
---

<div id="ib-wrap">

  <!-- Toolbar -->
  <div class="ib-toolbar">
    <div></div>
    <div class="ib-toolbar-right">
      <button class="ib-btn ib-btn--export" id="ib-export">⬇ Export CSV</button>
      <button class="ib-btn ib-btn--primary" id="ib-add-btn">+ Add Idea</button>
    </div>
  </div>

  <!-- Add / Edit modal -->
  <div id="ib-modal" class="ib-modal" style="display:none">
    <div class="ib-modal__box">
      <h3 class="ib-modal__title" id="ib-modal-title">New Idea</h3>
      <form id="ib-form" class="ib-form">
        <div class="ib-form__row">
          <label class="ib-label" for="ib-title">Idea</label>
          <input id="ib-title" class="ib-input" type="text" placeholder="What's the idea?" required />
        </div>
        <div class="ib-form__row ib-form__row--split">
          <div>
            <label class="ib-label">Priority</label>
            <div class="ib-priority-group">
              <label class="ib-radio"><input type="radio" name="ib-priority" value="high" /> 🔴 High</label>
              <label class="ib-radio"><input type="radio" name="ib-priority" value="medium" checked /> 🟡 Medium</label>
              <label class="ib-radio"><input type="radio" name="ib-priority" value="low" /> 🟢 Low</label>
            </div>
          </div>
          <div>
            <label class="ib-label">Status</label>
            <select id="ib-status-form" class="ib-input">
              <option value="Open">Open</option>
              <option value="Interested">Interested</option>
              <option value="Cancelled">Cancelled</option>
              <option value="Complete">Complete</option>
            </select>
          </div>
        </div>
        <div class="ib-form__row">
          <label class="ib-label">Tags</label>
          <div class="ib-tag-group">
            {['Summer','Internship','EC','Essay','India','Research','Misc'].map(t => (
              <label class="ib-check"><input type="checkbox" name="ib-tag" value={t} />{t}</label>
            ))}
          </div>
        </div>
        <div class="ib-form__row">
          <label class="ib-label" for="ib-notes">Notes</label>
          <textarea id="ib-notes" class="ib-textarea" placeholder="Details, links, next steps…" rows="3"></textarea>
        </div>
        <div class="ib-form__actions">
          <button type="submit" class="ib-btn ib-btn--primary" id="ib-submit">Add Idea</button>
          <button type="button" class="ib-btn ib-btn--cancel" id="ib-modal-cancel">Cancel</button>
          <span id="ib-error" class="ib-error" style="display:none"></span>
        </div>
      </form>
    </div>
  </div>

  <!-- Layout: filter sidebar + table -->
  <div class="ib-layout">

    <!-- Left filter sidebar -->
    <aside class="ib-sidebar">
      <div class="ib-sidebar__section">
        <div class="ib-sidebar__label">Status</div>
        <div class="ib-sidebar__chips">
          <button class="ib-fchip ib-fchip--active" data-filter="status" data-value="all">All</button>
          <button class="ib-fchip" data-filter="status" data-value="Open">Open</button>
          <button class="ib-fchip" data-filter="status" data-value="Interested">Interested</button>
          <button class="ib-fchip" data-filter="status" data-value="Cancelled">Cancelled</button>
          <button class="ib-fchip" data-filter="status" data-value="Complete">Complete</button>
        </div>
      </div>
      <div class="ib-sidebar__section">
        <div class="ib-sidebar__label">Priority</div>
        <div class="ib-sidebar__chips">
          <button class="ib-fchip ib-fchip--active" data-filter="priority" data-value="all">All</button>
          <button class="ib-fchip" data-filter="priority" data-value="high">🔴 High</button>
          <button class="ib-fchip" data-filter="priority" data-value="medium">🟡 Medium</button>
          <button class="ib-fchip" data-filter="priority" data-value="low">🟢 Low</button>
        </div>
      </div>
      <div class="ib-sidebar__section">
        <div class="ib-sidebar__label">Tag</div>
        <div class="ib-sidebar__chips">
          <button class="ib-fchip ib-fchip--active" data-filter="tag" data-value="all">All</button>
          {['Summer','Internship','EC','Essay','India','Research','Misc'].map(t => (
            <button class="ib-fchip" data-filter="tag" data-value={t}>{t}</button>
          ))}
        </div>
      </div>
      <div class="ib-sidebar__section">
        <label class="ib-starred-toggle">
          <input type="checkbox" id="ib-starred-only" />
          <span>⭐ Starred only</span>
        </label>
      </div>
    </aside>

    <!-- Table area -->
    <div class="ib-main">
      <div class="ib-table-toolbar">
        <span id="ib-count" class="ib-count"></span>
        <select id="ib-sort" class="ib-sort-sel">
          <option value="newest">Newest first</option>
          <option value="oldest">Oldest first</option>
          <option value="az">Title A → Z</option>
          <option value="za">Title Z → A</option>
          <option value="priority">By priority</option>
          <option value="status">By status</option>
        </select>
      </div>
      <div class="ib-table-wrap">
        <table class="ib-table">
          <thead>
            <tr>
              <th class="ib-th ib-th--star">★</th>
              <th class="ib-th ib-th--title">Idea</th>
              <th class="ib-th ib-th--priority">Priority</th>
              <th class="ib-th ib-th--tags">Tags</th>
              <th class="ib-th ib-th--status">Status</th>
              <th class="ib-th ib-th--date">Date</th>
              <th class="ib-th ib-th--actions"></th>
            </tr>
          </thead>
          <tbody id="ib-tbody">
            <tr><td colspan="7" class="ib-td-msg">Loading…</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  import { supabase } from '../lib/supabase';

  let familyId  = '';
  let editingId: number | null = null;
  let allIdeas:  any[] = [];
  let filterStatus   = 'all';
  let filterPriority = 'all';
  let filterTag      = 'all';
  let filterStarred  = false;
  let sortMode       = 'newest';

  const tbody        = document.getElementById('ib-tbody')       as HTMLElement;
  const countEl      = document.getElementById('ib-count')       as HTMLElement;
  const modal        = document.getElementById('ib-modal')!;
  const form         = document.getElementById('ib-form')        as HTMLFormElement;
  const titleEl      = document.getElementById('ib-title')       as HTMLInputElement;
  const notesEl      = document.getElementById('ib-notes')       as HTMLTextAreaElement;
  const statusFormEl = document.getElementById('ib-status-form') as HTMLSelectElement;
  const submitBtn    = document.getElementById('ib-submit')      as HTMLButtonElement;
  const errorEl      = document.getElementById('ib-error')       as HTMLElement;
  const modalTitle   = document.getElementById('ib-modal-title')!;
  const sortSel      = document.getElementById('ib-sort')        as HTMLSelectElement;
  const starredCb    = document.getElementById('ib-starred-only') as HTMLInputElement;

  const PRIORITY_META: Record<string,{dot:string; label:string; color:string}> = {
    high:   { dot:'🔴', label:'High',   color:'#ef4444' },
    medium: { dot:'🟡', label:'Medium', color:'#f59e0b' },
    low:    { dot:'🟢', label:'Low',    color:'#22c55e' },
  };

  const STATUS_COLOR: Record<string, string> = {
    'Open':       '#3b82f6',
    'Interested': '#f59e0b',
    'Cancelled':  '#94a3b8',
    'Complete':   '#22c55e',
  };

  function esc(s: string | null | undefined) {
    return (s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }
  function formatDate(iso: string) {
    return new Date(iso).toLocaleDateString('en-US', { month:'short', day:'numeric', year:'numeric' });
  }

  function visibleIdeas() {
    let list = allIdeas.filter(i => {
      if (filterStatus   !== 'all' && i.status !== filterStatus)       return false;
      if (filterPriority !== 'all' && i.priority !== filterPriority)   return false;
      if (filterTag      !== 'all' && !(i.tags ?? []).includes(filterTag)) return false;
      if (filterStarred  && !i.starred)                                return false;
      return true;
    });
    const priorityOrder = ['high','medium','low'];
    const statusOrder   = ['Open','Interested','Complete','Cancelled'];
    list.sort((a, b) => {
      if (sortMode === 'newest')   return new Date(b.created_at).getTime() - new Date(a.created_at).getTime();
      if (sortMode === 'oldest')   return new Date(a.created_at).getTime() - new Date(b.created_at).getTime();
      if (sortMode === 'az')       return a.title.localeCompare(b.title);
      if (sortMode === 'za')       return b.title.localeCompare(a.title);
      if (sortMode === 'priority') return priorityOrder.indexOf(a.priority ?? 'medium') - priorityOrder.indexOf(b.priority ?? 'medium');
      if (sortMode === 'status')   return statusOrder.indexOf(a.status ?? 'Open') - statusOrder.indexOf(b.status ?? 'Open');
      return 0;
    });
    return list;
  }

  function renderTable() {
    const ideas = visibleIdeas();
    countEl.textContent = `${ideas.length} idea${ideas.length !== 1 ? 's' : ''}`;

    if (ideas.length === 0) {
      tbody.innerHTML = '<tr><td colspan="7" class="ib-td-msg">No ideas match. Try adjusting filters.</td></tr>';
      return;
    }

    tbody.innerHTML = ideas.map(i => {
      const pm  = PRIORITY_META[i.priority] ?? PRIORITY_META.medium;
      const sc  = STATUS_COLOR[i.status ?? 'Open'] ?? '#3b82f6';
      const tags = (i.tags ?? []).map((t: string) => `<span class="ib-tag">${esc(t)}</span>`).join('');
      return `
        <tr class="ib-row${i.status === 'Cancelled' ? ' ib-row--cancelled' : ''}${i.status === 'Complete' ? ' ib-row--complete' : ''}">
          <td class="ib-td ib-td--star">
            <button class="ib-star${i.starred ? ' ib-star--on' : ''}" data-id="${i.id}" data-starred="${!!i.starred}" title="Star">${i.starred ? '★' : '☆'}</button>
          </td>
          <td class="ib-td ib-td--title">
            <span class="ib-row-title">${esc(i.title)}</span>
            ${i.notes ? `<span class="ib-row-sub">${esc(i.notes)}</span>` : ''}
          </td>
          <td class="ib-td ib-td--priority">
            <span class="ib-priority-badge ib-priority-badge--${i.priority ?? 'medium'}" style="--pc:${pm.color}">${pm.dot} ${pm.label}</span>
          </td>
          <td class="ib-td ib-td--tags">
            <div class="ib-tags-wrap">${tags || '<span class="ib-none">—</span>'}</div>
          </td>
          <td class="ib-td ib-td--status">
            <select class="ib-status-sel" data-id="${i.id}" data-status="${i.status ?? 'Open'}" style="--sc:${sc}">
              <option value="Open"       ${(i.status ?? 'Open') === 'Open'       ? 'selected' : ''}>Open</option>
              <option value="Interested" ${i.status === 'Interested' ? 'selected' : ''}>Interested</option>
              <option value="Cancelled"  ${i.status === 'Cancelled'  ? 'selected' : ''}>Cancelled</option>
              <option value="Complete"   ${i.status === 'Complete'   ? 'selected' : ''}>Complete</option>
            </select>
          </td>
          <td class="ib-td ib-td--date">${formatDate(i.created_at)}</td>
          <td class="ib-td ib-td--actions">
            <button class="ib-act ib-act--edit"   data-id="${i.id}">Edit</button>
            <button class="ib-act ib-act--delete" data-id="${i.id}">Delete</button>
          </td>
        </tr>`;
    }).join('');
  }

  /* ── Filter sidebar ── */
  document.querySelector('.ib-sidebar')!.addEventListener('click', e => {
    const chip = (e.target as Element).closest<HTMLElement>('.ib-fchip');
    if (!chip) return;
    const filter = chip.dataset.filter!;
    const value  = chip.dataset.value!;
    if (filter === 'status')   filterStatus   = value;
    if (filter === 'priority') filterPriority = value;
    if (filter === 'tag')      filterTag      = value;
    document.querySelectorAll<HTMLElement>(`.ib-fchip[data-filter="${filter}"]`).forEach(c =>
      c.classList.toggle('ib-fchip--active', c.dataset.value === value));
    renderTable();
  });

  starredCb.addEventListener('change', () => { filterStarred = starredCb.checked; renderTable(); });
  sortSel.addEventListener('change',   () => { sortMode = sortSel.value; renderTable(); });

  /* ── Table interactions ── */
  tbody.addEventListener('change', async e => {
    const sel = (e.target as HTMLElement).closest<HTMLSelectElement>('.ib-status-sel');
    if (!sel) return;
    const id     = Number(sel.dataset.id);
    const status = sel.value;
    sel.dataset.status = status;
    sel.style.setProperty('--sc', STATUS_COLOR[status] ?? '#3b82f6');
    await supabase.from('ideas').update({ status }).eq('id', id).eq('family_id', familyId);
    const i = allIdeas.find(i => i.id === id);
    if (i) { i.status = status; renderTable(); }
  });

  tbody.addEventListener('click', async e => {
    const target = e.target as HTMLElement;

    const starBtn = target.closest<HTMLElement>('.ib-star');
    if (starBtn) {
      const id      = Number(starBtn.dataset.id);
      const starred = starBtn.dataset.starred !== 'true';
      await supabase.from('ideas').update({ starred }).eq('id', id).eq('family_id', familyId);
      const i = allIdeas.find(i => i.id === id);
      if (i) { i.starred = starred; renderTable(); }
      return;
    }

    if (target.classList.contains('ib-act--delete')) {
      const id = Number(target.dataset.id);
      if (!confirm('Delete this idea?')) return;
      await supabase.from('ideas').delete().eq('id', id).eq('family_id', familyId);
      allIdeas = allIdeas.filter(i => i.id !== id);
      renderTable();
    }

    if (target.classList.contains('ib-act--edit')) {
      const id   = Number(target.dataset.id);
      const idea = allIdeas.find(i => i.id === id);
      if (idea) openModal(idea);
    }
  });

  /* ── Modal ── */
  function openModal(idea?: any) {
    editingId = idea?.id ?? null;
    modalTitle.textContent  = idea ? 'Edit Idea' : 'New Idea';
    submitBtn.textContent   = idea ? 'Save Changes' : 'Add Idea';
    titleEl.value           = idea?.title ?? '';
    notesEl.value           = idea?.notes ?? '';
    statusFormEl.value      = idea?.status ?? 'Open';
    const priority = idea?.priority ?? 'medium';
    form.querySelectorAll<HTMLInputElement>('input[name="ib-priority"]').forEach(r => { r.checked = r.value === priority; });
    form.querySelectorAll<HTMLInputElement>('input[name="ib-tag"]').forEach(cb => { cb.checked = (idea?.tags ?? []).includes(cb.value); });
    errorEl.style.display = 'none';
    modal.style.display   = 'flex';
    document.body.style.overflow = 'hidden';
    setTimeout(() => titleEl.focus(), 50);
  }

  function closeModal() {
    modal.style.display = 'none';
    document.body.style.overflow = '';
    form.reset();
    editingId = null;
  }

  document.getElementById('ib-add-btn')!.addEventListener('click', () => openModal());
  document.getElementById('ib-modal-cancel')!.addEventListener('click', closeModal);
  modal.addEventListener('click', e => { if (e.target === modal) closeModal(); });

  /* ── Submit ── */
  form.addEventListener('submit', async e => {
    e.preventDefault();
    if (!familyId) return;
    const title    = titleEl.value.trim();
    const priority = form.querySelector<HTMLInputElement>('input[name="ib-priority"]:checked')?.value ?? 'medium';
    const tags     = [...form.querySelectorAll<HTMLInputElement>('input[name="ib-tag"]:checked')].map(c => c.value);
    const notes    = notesEl.value.trim() || null;
    const status   = statusFormEl.value;

    errorEl.style.display = 'none';
    submitBtn.disabled = true;
    const payload = { title, priority, tags, notes, status, updated_at: new Date().toISOString() };

    let error: any;
    if (editingId !== null) {
      ({ error } = await supabase.from('ideas').update(payload).eq('id', editingId).eq('family_id', familyId));
    } else {
      ({ error } = await supabase.from('ideas').insert({ ...payload, family_id: familyId }));
    }

    submitBtn.disabled = false;
    if (error) { errorEl.textContent = error.message; errorEl.style.display = 'inline'; return; }
    closeModal();
    await loadIdeas();
  });

  /* ── Export ── */
  document.getElementById('ib-export')!.addEventListener('click', () => {
    if (!allIdeas.length) return;
    const cell = (v: any) => `"${(v ?? '').toString().replace(/"/g,'""')}"`;
    const lines = [
      ['Starred','Idea','Priority','Tags','Status','Notes','Date'].map(cell).join(','),
      ...allIdeas.map(i => [
        i.starred ? 'Yes' : 'No', i.title, i.priority, (i.tags ?? []).join('; '),
        i.status ?? 'Open', i.notes ?? '',
        new Date(i.created_at).toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'}),
      ].map(cell).join(','))
    ];
    const blob = new Blob([lines.join('\n')], { type:'text/csv' });
    const url  = URL.createObjectURL(blob);
    const a    = document.createElement('a');
    a.href = url; a.download = 'ideas.csv'; a.click();
    URL.revokeObjectURL(url);
  });

  /* ── Load ── */
  async function loadIdeas() {
    const { data, error } = await supabase.from('ideas').select('*')
      .eq('family_id', familyId).order('created_at', { ascending: false });
    if (error) {
      tbody.innerHTML = '<tr><td colspan="7" class="ib-td-msg" style="color:var(--sl-color-red)">Failed to load.</td></tr>';
      return;
    }
    allIdeas = data ?? [];
    renderTable();
  }

  /* ── Init ── */
  async function init() {
    const { data: { session } } = await supabase.auth.getSession();
    if (!session) {
      document.addEventListener('data-loaded', async () => {
        const { data: { session: s } } = await supabase.auth.getSession();
        if (s) {
          const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', s.user.id).single();
          familyId = p?.family_id ?? '';
          await loadIdeas();
        }
      }, { once: true });
      return;
    }
    const { data: p } = await supabase.from('user_profiles').select('family_id').eq('user_id', session.user.id).single();
    familyId = p?.family_id ?? '';
    await loadIdeas();
  }

  init();
</script>

<style>
  #ib-wrap { max-width: 100%; }

  /* ── Toolbar ── */
  .ib-toolbar { display: flex; justify-content: flex-end; align-items: center; margin-bottom: 1rem; gap: 0.5rem; }
  .ib-toolbar-right { display: flex; align-items: center; gap: 0.5rem; }

  /* ── Buttons ── */
  .ib-btn {
    padding: 0.4rem 0.9rem; border-radius: 0.375rem; font-size: 0.85rem;
    font-family: inherit; cursor: pointer; border: 1px solid transparent; white-space: nowrap;
  }
  .ib-btn--primary { background: var(--sl-color-accent); color: #fff; border-color: var(--sl-color-accent); }
  .ib-btn--primary:hover { opacity: 0.88; }
  .ib-btn--export { background: transparent; border-color: var(--sl-color-accent); color: var(--sl-color-accent); }
  .ib-btn--export:hover { background: var(--sl-color-accent); color: #fff; }
  .ib-btn--cancel { background: transparent; border-color: var(--sl-color-gray-4); color: var(--sl-color-gray-2); }
  .ib-btn--cancel:hover { border-color: #ef4444; color: #ef4444; }
  .ib-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .ib-error { font-size: 0.82rem; color: #ef4444; }

  /* ── Layout ── */
  .ib-layout { display: flex; gap: 1.25rem; align-items: flex-start; }

  /* ── Sidebar ── */
  .ib-sidebar {
    width: 160px; flex-shrink: 0; position: sticky; top: 4rem;
    display: flex; flex-direction: column; gap: 1.25rem;
  }
  .ib-sidebar__section { display: flex; flex-direction: column; gap: 0.4rem; }
  .ib-sidebar__label {
    font-size: 0.67rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--sl-color-gray-3);
    padding-bottom: 0.2rem; border-bottom: 1px solid var(--sl-color-gray-6);
  }
  .ib-sidebar__chips { display: flex; flex-direction: column; gap: 0.22rem; }
  .ib-fchip {
    padding: 0.25rem 0.6rem; border-radius: 0.3rem; text-align: left;
    border: 1px solid transparent; background: transparent;
    color: var(--sl-color-gray-2); font-size: 0.8rem; cursor: pointer; transition: all 0.1s;
  }
  .ib-fchip--active { background: var(--sl-color-accent); color: #fff; border-color: var(--sl-color-accent); }
  .ib-fchip:not(.ib-fchip--active):hover { background: var(--sl-color-gray-6); color: var(--sl-color-text); }
  .ib-starred-toggle {
    display: flex; align-items: center; gap: 0.4rem;
    font-size: 0.82rem; cursor: pointer; color: var(--sl-color-gray-2);
  }

  /* ── Main ── */
  .ib-main { flex: 1; min-width: 0; }
  .ib-table-toolbar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.65rem; }
  .ib-count { font-size: 0.82rem; color: var(--sl-color-gray-2); }
  .ib-sort-sel {
    padding: 0.28rem 0.55rem; border: 1px solid var(--sl-color-gray-4);
    border-radius: 0.35rem; background: var(--sl-color-bg);
    color: var(--sl-color-text); font-size: 0.8rem; font-family: inherit; cursor: pointer;
  }

  /* ── Table ── */
  .ib-table-wrap { overflow-x: auto; }
  .ib-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
  .ib-th {
    padding: 0.45rem 0.75rem; text-align: left; font-size: 0.68rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.05em; color: var(--sl-color-gray-2);
    border-bottom: 2px solid var(--sl-color-gray-5); white-space: nowrap;
  }
  .ib-th--star     { width: 36px; text-align: center; }
  .ib-th--priority { width: 95px; }
  .ib-th--tags     { width: 140px; }
  .ib-th--status   { width: 130px; }
  .ib-th--date     { width: 88px; }
  .ib-th--actions  { width: 100px; }

  .ib-td { padding: 0.6rem 0.75rem; border-bottom: 1px solid var(--sl-color-gray-6); vertical-align: middle; }
  .ib-td--star   { text-align: center; }
  .ib-td--title  { vertical-align: top; padding-top: 0.65rem; }
  .ib-td--tags   { vertical-align: top; padding-top: 0.65rem; }
  .ib-td--date   { white-space: nowrap; color: var(--sl-color-gray-3); font-size: 0.8rem; }
  .ib-td-msg     { padding: 2rem; text-align: center; color: var(--sl-color-gray-2); }

  .ib-row:hover { background: var(--sl-color-gray-7, rgba(0,0,0,0.02)); }
  .ib-row--cancelled .ib-row-title { opacity: 0.5; text-decoration: line-through; }
  .ib-row--complete  .ib-row-title { opacity: 0.7; }

  .ib-row-title { display: block; font-weight: 600; color: var(--sl-color-text); line-height: 1.4; }
  .ib-row-sub {
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; font-size: 0.78rem; color: var(--sl-color-gray-2);
    margin-top: 0.1rem; line-height: 1.4;
  }
  .ib-none { color: var(--sl-color-gray-4); }

  .ib-star {
    background: none; border: none; cursor: pointer;
